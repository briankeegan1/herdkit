# herdkit — code only. Never commit secrets or per-machine state.
# NOTE: git treats an inline "# comment" as part of the pattern, so a commented ignore line
# silently matches nothing. Keep every comment on its OWN line — patterns stay bare.

# API-backend credentials (Linear/Jira/DevOps) — gitignored by contract.
.herd/secrets
*.log
.DS_Store

# worktree-pool / queue scratch (lives in a sibling -trees dir, never in the repo).
*-trees/

# Engine journal — append-only forensic log written to WORKTREES_DIR/.herd/ (already covered by
# *-trees/, but named explicitly so it stays ignored even if a project keeps .herd inside the tree).
.herd/journal.jsonl
.herd/journal-*.jsonl

# machine-local Claude Code state — never committed.
.claude/settings.local.json
.claude/settings.json

# Per-user / per-machine .herd/config overlay (HERD-47) — sourced AFTER .herd/config so its keys
# override the committed baseline; gitignored so a collaborator's local tuning never diverges main
# or dirties the ff-only `herd update` pull. The baseline .herd/config stays tracked.
.herd/config.local
