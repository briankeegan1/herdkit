# herdkit ‚Äî code only. Never commit secrets or per-machine state.
# NOTE: git treats an inline "# comment" as part of the pattern, so a commented ignore line
# silently matches nothing. Keep every comment on its OWN line ‚Äî patterns stay bare.

# API-backend credentials (Linear/Jira/DevOps) ‚Äî gitignored by contract.
.herd/secrets
*.log
.DS_Store

# worktree-pool / queue scratch (lives in a sibling -trees dir, never in the repo).
*-trees/

# Engine journal ‚Äî append-only forensic log written to WORKTREES_DIR/.herd/ (already covered by
# *-trees/, but named explicitly so it stays ignored even if a project keeps .herd inside the tree).
.herd/journal.jsonl
.herd/journal-*.jsonl

# Coordinator progress ledger (HERD-103) ‚Äî durable, per-machine coordinator state written to
# WORKTREES_DIR/.herd/ (covered by *-trees/, but named explicitly for a .herd-inside-the-tree layout).
.herd/ledger.jsonl

# Config-viability report (HERD-355) ‚Äî the machine-readable external-consistency snapshot the probes
# write to WORKTREES_DIR/.herd/ (covered by *-trees/, but named explicitly for a .herd-inside-the-tree
# layout). Regenerated live on every `herd doctor` / coupled-key `herd config set`; never committed.
.herd/config-viability.json

# Conformance run artifact (HERD-144) ‚Äî `herd conformance run` writes this machine-local, regenerable
# scorecard (capability‚Üíverdict‚Üísha‚Üítimestamp). Never committed; the committed proof map is
# templates/conformance.tsv, this is only the per-run verdict output.
.herd/conformance.json

# machine-local Claude Code state ‚Äî never committed.
.claude/settings.local.json
.claude/settings.json

# Rendered coordinator skill (HERD-214) ‚Äî `render_skill` regenerates it from
# templates/coordinator.md.tmpl + .herd/config on every init/update/reload/render, so a tracked copy
# meant EVERY one of those commands dirtied the checkout it ran in (six worktree-interference
# incidents in two days: unreapable worktrees, bogus stale-base holds, a blocked ff-only pull). Same
# doctrine as .herd/config.local: consumers share the TEMPLATE, each machine renders its own artifact.
.claude/commands/coordinator.md

# Per-user / per-machine .herd/config overlay (HERD-47) ‚Äî sourced AFTER .herd/config so its keys
# override the committed baseline; gitignored so a collaborator's local tuning never diverges main
# or dirties the ff-only `herd update` pull. The baseline .herd/config stays tracked.
.herd/config.local

# Scheduled/triggered-runs per-trigger state (HERD-169) ‚Äî last-run input snapshots + last-fired
# timestamps written under .herd/trigger-state/ by scripts/herd/triggers.sh. Runtime state, never
# committed (the committed data is .herd/triggers.tsv itself); regenerated on the next tick.
.herd/trigger-state/

# graphify call-graph output (HERD-61) ‚Äî the coordinator's pre-spawn impact/conflict analysis runs
# `graphify update --no-cluster` in the main checkout, which writes this machine-local, regenerable
# graph here. Never committed; keeps the analysis from dirtying the working tree.
graphify-out/

# Python bytecode cache (HERD-337) ‚Äî written by ENGINE_IMPL=python tick; never committed.
__pycache__/
