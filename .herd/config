# .herd/config — herdkit's OWN dogfood config (herd-on-herd, workspace wB).
# herdkit is developed using the herd. Commit this; it is zero-secret.
HERD_VERSION=1

PROJECT_ROOT="$HOME/source/herdkit"
WORKTREES_DIR="$HOME/source/herdkit-trees"
DEFAULT_BRANCH="origin/main"
WORKSPACE_NAME="herdkit"

BACKLOG_FILE="BACKLOG.md"
SCRIBE_BACKEND="linear"
SHARE_LINKS=""

# HEALTHCHECK = shellcheck over the scripts + bats over the tests (degrades to bash -n + the
# hermetic queue tests when those tools are absent).
HEALTHCHECK_CMD=".herd/healthcheck.project.sh"
# HEALTHCHECK_HEAVY_GLOB (HERD-65) — egrep of changed diff paths (repo-root-relative) that force the
# heavy profile; no match → the light per-file syntax gate (bash -n / py_compile). Chosen so
# engine-critical paths stay heavy while docs-only *.md and .herd/config VALUE-only diffs skip the
# ~9-min full suite (evidence: PR #179, a 2-line .herd/config diff, ran the hermetic suite twice).
#   HEAVY  : bin/ · scripts/ · tests/ · templates/ · .herd/healthcheck.project.sh (the gate itself)
#   light  : .herd/config value tweaks · docs/*.md (incl. the auto-committed docs/codemap.md refresh)
#            · README/BACKLOG/LICENSE · root install.sh/herd.sh (light still bash -n's changed *.sh)
# Matched by `printf '%s\n' "$changed" | grep -qE "$HEALTHCHECK_HEAVY_GLOB"` in scripts/herd/healthcheck.sh.
#
# CONFIG VALIDATION STAYS GATED. The config-validation MACHINERY — herd-config.sh (scripts/), its
# capabilities.tsv + config.example contract (templates/), and the test-config-*.sh suite (tests/) —
# is entirely under heavy paths, so any change to how config is parsed/validated (e.g. adding a key,
# which the caps-sync guard requires be mirrored into templates/capabilities.tsv) runs the full suite.
# A pure .herd/config value edit touches none of that machinery, so it is safe to run light. Note
# (verified): NEITHER profile fast-fails on a syntactically-broken .herd/config — healthcheck.sh
# sources it non-fatally — so routing value edits to light loses no value-level gate that ever existed;
# a broken config surfaces immediately at the next `herd` command. Keep this glob narrow: widen it
# (not shrink it) if a new engine surface lands outside these paths.
HEALTHCHECK_HEAVY_GLOB='^(bin|scripts|tests|templates)/|^\.herd/healthcheck\.project\.sh$'
APP_PREVIEW_CMD=""
SMOKE_CMD=""

MODEL_COORDINATOR="claude-opus-4-8"
MODEL_FEATURE="claude-opus-4-8"
# herdkit has no app lane — "quick" IS the engine lane, so it gets the feature tier.
MODEL_QUICK="claude-opus-4-8"
MODEL_SCRIBE="claude-sonnet-4-6"
MODEL_RESEARCH="claude-sonnet-4-6"
MODEL_REVIEW="claude-opus-4-8"
MODEL_RESOLVER="claude-sonnet-4-6"

# MODEL_ESCALATE_GLOB — deterministic model step-up (analogous to HEALTHCHECK_HEAVY_GLOB): when a
# lane's task text matches this egrep -i pattern, the lane forces the MODEL_FEATURE tier regardless
# of MODEL_QUICK or a per-spawn HERD_QUICK_MODEL/HERD_FEATURE_MODEL override. These are herdkit's
# judgment-heavy engine surfaces where the quick lane historically misbuilt (evidence: an engine PR
# touching cmd_reload/bin/herd routed through MODEL_QUICK=sonnet). Empty → off. (Here MODEL_QUICK is
# already opus so this is a belt-and-suspenders guard that also protects any cheaper per-spawn override.)
MODEL_ESCALATE_GLOB='bin/herd|scripts/herd/agent-watch|herd-review|cmd_reload'

DENY_PATHS=".herd/secrets"
REVIEW_CHECKLIST=".herd/review-checklist.md"
COORDINATOR_CMD="/coordinator"
WATCHER_AUTOMERGE="true"
# auto: watcher merges on its own once all gates (healthcheck + review) pass.
MERGE_POLICY="auto"

# Spawn-queue drain concurrency cap: the watcher pops at most
# (REVIEW_CONCURRENCY + SPAWN_AHEAD - active_builders) intents from the durable spawn queue
# each tick (spawn.sh → spawn-step.sh). Raise SPAWN_AHEAD to keep more builders ahead of the
# review gate; lower to 0 for strict no-surplus (never build past REVIEW_CONCURRENCY in-flight).
SPAWN_AHEAD=1
HERD_REPO="briankeegan1/herdkit"
# Dogfood: bounce BLOCK reviews straight to the builder agent (3-round cap, sha-keyed).
REVIEW_AUTOFIX="true"

# ─────────────────────────────────────────────────────────────────────────────
# Explicitly materialized config (2026-07-06). Every key below is written at its
# documented default from templates/capabilities.tsv EXCEPT the two overnight
# opt-ins at the bottom — so this block is behavior-neutral vs. leaving them unset,
# it just makes the full surface visible. Trade-off: these no longer track future
# engine-default changes; re-check after a `herd upgrade`.
# ─────────────────────────────────────────────────────────────────────────────

# — Backlog / token —
# off; no github-issues incoming inbox beneath the queue
BACKLOG_VIEW_EXTRAS=""
# standard | eco (eco flips built-in defaults to cheaper tiers)
TOKEN_MODE="standard"

# — App preview (herdkit has NO app lane; all inert while APP_PREVIEW_CMD is blank) —
APP_PREVIEW_SERVER_ARGS="--server.port {port} --server.headless true"
APP_PREVIEW_HEALTH_CMD=""
APP_PREVIEW_HEALTH_PATH="/"
APP_PREVIEW_PORT_BASE="8501"
# blank → interaction gate disabled (zero behavior change)
APP_SURFACE_GLOB=""
INTERACTION_TEST_CMD=""

# — Runtime driver: herdr multiplexer + Claude Code runtime (this box has herdr) —
HERD_DRIVER="herdr-claude"

# — PR flow / merge —
# merge | squash | rebase
MERGE_METHOD="merge"
# direct (open ready) | draft
PR_FLOW="direct"
# only consulted when PR_FLOW=draft
PR_READY_WHEN="builder"
# retain merged feature branches (today's behavior)
DELETE_BRANCH_ON_MERGE="false"
# pre-pr mode not wired yet; keep none
LOCAL_REVIEW="none"

# — Watcher lens / scope (solo defaults; unset behaves identically) —
WATCHER_VIEW="all"
WATCHER_VIEW_AUTHOR=""
WATCHER_VIEW_ASSIGNEE=""
WATCHER_VIEW_LABEL=""
WATCHER_VIEW_STATUS=""
WATCHER_VIEW_DEPS_LABEL="dependencies"
# solo: auto-merge own PRs; all = team mode (needs WATCHER_OWNER)
WATCHER_SCOPE="mine"
WATCHER_OWNER=""

# — Claiming / builder context (multi-operator baseline) —
# two operators active — spawns carrying a tracker id claim atomically
CLAIM_REQUIRED="on"
# builders ground on the committed docs/codemap.md
CONTEXT_PROVISION="codemap"

# — Review concurrency / tiering —
REVIEW_CONCURRENCY="2"
# keep 1: worktrees share one git object store
HEALTH_CONCURRENCY="1"
REFIX_MAX_ROUNDS="3"
# blank → every PR gets the full MODEL_REVIEW (Opus)
REVIEW_ESCALATE_GLOB=""
# only used once REVIEW_ESCALATE_GLOB is set
REVIEW_MODEL_CHEAP="claude-sonnet-4-6"
REVIEW_ESCALATE_MAXFILES="10"

# — Dependency watcher / usage-limit resume —
DEP_POLL_MIN="30"
DEP_POLL_MAX="300"
# 24h; 0 disables stall surfacing
DEP_STALE_TTL="86400"
# seconds after parsed reset before relaunch
HERD_LIMIT_RESUME_BUFFER="60"
# ~5h window when reset time can't be parsed
HERD_LIMIT_UNKNOWN_WAIT="18000"

# — Builder-tab UX / theme —
TASK_PANE_VIEW="on"
HERD_THEME="tokyonight"

# ── HERD-6 overnight-run opt-ins (NON-default: deliberately ON) ───────────────
# Unattended posture for the falsification run. Both ship DORMANT by default;
# activation requires a watcher restart (herd reload), so these are INERT until
# the control room is (re)launched. Turn OFF again after the overnight run.
# auto-resume a limit-parked coordinator at reset+buffer
COORDINATOR_WATCHDOG="on"
# restart a silently-dead EMPTY builder once (never blows away work)
DEAD_BUILDER_AUTORESPAWN="on"
