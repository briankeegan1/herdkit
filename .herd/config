# .herd/config — herdkit's OWN dogfood config (herd-on-herd, workspace wB).
# herdkit is developed using the herd. Commit this; it is zero-secret.
HERD_VERSION=1

PROJECT_ROOT="$HOME/source/herdkit"
WORKTREES_DIR="$HOME/source/herdkit-trees"
DEFAULT_BRANCH="origin/main"
WORKSPACE_NAME="herdkit"

BACKLOG_FILE="BACKLOG.md"
SCRIBE_BACKEND="file"
SHARE_LINKS=""

# HEALTHCHECK = shellcheck over the scripts + bats over the tests (degrades to bash -n + the
# hermetic queue tests when those tools are absent). No app preview — every lane is the quick
# lane, so HEALTHCHECK_HEAVY_GLOB is empty (every change runs the full healthcheck).
HEALTHCHECK_CMD=".herd/healthcheck.project.sh"
HEALTHCHECK_HEAVY_GLOB=""
APP_PREVIEW_CMD=""
SMOKE_CMD=""

MODEL_COORDINATOR="claude-opus-4-8"
MODEL_FEATURE="claude-opus-4-8"
# herdkit has no app lane — "quick" IS the engine lane, so it gets the feature tier.
MODEL_QUICK="claude-opus-4-8"
MODEL_SCRIBE="claude-sonnet-4-6"
MODEL_RESEARCH="claude-sonnet-4-6"
MODEL_REVIEW="claude-opus-4-8"
MODEL_RESOLVER="claude-sonnet-4-6"

# MODEL_ESCALATE_GLOB — deterministic model step-up (analogous to HEALTHCHECK_HEAVY_GLOB): when a
# lane's task text matches this egrep -i pattern, the lane forces the MODEL_FEATURE tier regardless
# of MODEL_QUICK or a per-spawn HERD_QUICK_MODEL/HERD_FEATURE_MODEL override. These are herdkit's
# judgment-heavy engine surfaces where the quick lane historically misbuilt (evidence: an engine PR
# touching cmd_reload/bin/herd routed through MODEL_QUICK=sonnet). Empty → off. (Here MODEL_QUICK is
# already opus so this is a belt-and-suspenders guard that also protects any cheaper per-spawn override.)
MODEL_ESCALATE_GLOB='bin/herd|scripts/herd/agent-watch|herd-review|cmd_reload'

DENY_PATHS=".herd/secrets"
REVIEW_CHECKLIST=".herd/review-checklist.md"
COORDINATOR_CMD="/coordinator"
WATCHER_AUTOMERGE="true"
# auto: watcher merges on its own once all gates (healthcheck + review) pass.
MERGE_POLICY="auto"
HERD_REPO="briankeegan1/herdkit"
# Dogfood: bounce BLOCK reviews straight to the builder agent (3-round cap, sha-keyed).
REVIEW_AUTOFIX="true"
