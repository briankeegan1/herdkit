#!/usr/bin/env bash
# herd — the herdkit CLI. Stands the herd workflow up in a project, upgrades the engine, and
# routes engine bugs back to the herdkit repo. Plain shell; the scout/interview may shell out to
# a one-shot `claude -p` where judgment helps, but the CLI itself stays heuristic + interactive.
#
#   herd init       stand up herdkit in a project (greenfield interview / brownfield scout):
#                   discover the work tracker, write .herd/config, render the coordinator skill.
#   herd upgrade    re-render the coordinator skill from the current template + bump HERD_VERSION,
#                   PRESERVING the project's .herd/config answers; warn on newly-added keys.
#   herd report     file a cross-repo issue against HERD_REPO (or any peer from .herd/links via
#                   --to <name>) via HERD_REPORT_BACKEND (default github), stamped with this
#                   project + the lane involved + the version pin. Dedups before filing.
#   herd link       manage the cross-repo link registry (.herd/links): list shows all configured
#                   peer repos. Use a link with: herd report --to <name> "<symptom>".
#   herd depend     record a WATCHED blocked-on dependency (<link>#<id>) in .herd/deps — dep-watcher
#                   polls it until the upstream item closes. `herd report --to --dep` files AND deps.
#   herd deps       list / rm / demote recorded dependencies — a dep is editable data, never stuck.
#   herd render     (internal) re-render only the coordinator skill from .herd/config.
#
# Engine contract version this CLI ships.
HERDKIT_CONTRACT_VERSION=1
set -euo pipefail

# Resolve the herdkit install root from this script's location (bin/herd → repo root).
# Follow any chain of symlinks to the REAL file first, so the documented symlink install
# (e.g. ln -s ~/source/herdkit/bin/herd /opt/homebrew/bin/herd) derives home from the real
# location, not the symlink's dir. macOS readlink has no -f, so resolve in pure bash.
herd_src="${BASH_SOURCE[0]}"
while [ -L "$herd_src" ]; do
  herd_target="$(readlink "$herd_src")"
  case "$herd_target" in
    /*) herd_src="$herd_target" ;;
    *)  herd_src="$(cd "$(dirname "$herd_src")" && cd "$(dirname "$herd_target")" && pwd)/$(basename "$herd_target")" ;;
  esac
done
HERDKIT_HOME="$(cd "$(dirname "$herd_src")/.." && pwd)"
SCRIPTS_DIR="$HERDKIT_HOME/scripts/herd"
TEMPLATES_DIR="$HERDKIT_HOME/templates"

# Engine journal helper (best-effort append + reader-path helpers). Defines functions only; the
# journal path resolves lazily from WORKTREES_DIR at call time, so sourcing before config is safe.
# shellcheck source=/dev/null
[ -f "$SCRIPTS_DIR/journal.sh" ] && . "$SCRIPTS_DIR/journal.sh"

# Cost summer/reader helpers (transcript-token pricing). Defines functions + constants only, sourced
# AFTER journal.sh (its documented order); gives cmd_cost the `herd cost --full` live-scan readers
# (_cost_transcript_dir + cost_report_full). No side effects at source time.
# shellcheck source=/dev/null
[ -f "$SCRIPTS_DIR/cost.sh" ] && . "$SCRIPTS_DIR/cost.sh"

# Shared EYES-ON-LAYOUT helper: pane classification (_reload_pane_role/_reload_tab_panes/
# _reload_tab_by_label), the layout_snapshot scan, layout_reconcile, and the single .herd-panes
# registry writer. Defines functions only; every pane-mutating path observes the live layout
# through it. cmd_reload and the herd pane subcommands consume it below; coordinator.sh sources it
# too, so "observe before you mutate" lives in one place.
# shellcheck source=/dev/null
. "$SCRIPTS_DIR/layout-reconcile.sh"

# Fleet fan-out helpers (herd fleet …): the DETERMINISTIC multi-project registry + rollup + bulk
# update/reload. Defines functions only; they call say/die/colour vars (defined just below) at run
# time, so sourcing here — before those are defined — is safe. See scripts/herd/fleet.sh.
# shellcheck source=/dev/null
[ -f "$SCRIPTS_DIR/fleet.sh" ] && . "$SCRIPTS_DIR/fleet.sh"

# Shared governance EXTRACTION + MAPPING helpers (_gov_map_file / _gov_statements / _gov_match). The
# read-only half of the HERD-119 adoption pass, factored out so the HERD-125 drift sweep re-extracts a
# CLAUDE.md/AGENTS.md change EXACTLY as init imported it. Defines functions only (TEMPLATES_DIR is set
# above, so _gov_map_file resolves the same table it always has). The init-only mutators + LLM
# fallback stay in this file, below.
# shellcheck source=/dev/null
. "$SCRIPTS_DIR/governance.sh"

# Runtime driver shim: the ONE seam binding the runtime-specific control surface (multiplexer + agent
# runtime) to a concrete backend, dispatched on HERD_DRIVER. Defines functions only (side-effect-free),
# and — like fleet.sh — late-binds herd_resolve_workspace_id / WORKTREES_DIR at call time, so sourcing
# here before those are wired is safe. Lets the coordinator relaunch (_pane_agent_start) and the fleet
# room route their agent launches through herd_driver_launch_agent instead of raw `herdr agent start`.
# shellcheck source=/dev/null
[ -f "$SCRIPTS_DIR/driver.sh" ] && . "$SCRIPTS_DIR/driver.sh"

# `herd status` helpers: the DETERMINISTIC, READ-ONLY one-shot health snapshot for THIS project
# (watcher liveness, in-flight builders + DEAD detection, open PRs + gate state, backlog counts).
# Defines functions only — its _status_watcher_pids late-binds _list_project_watchers (defined far
# below), so sourcing here is safe. See scripts/herd/status.sh.
# shellcheck source=/dev/null
[ -f "$SCRIPTS_DIR/status.sh" ] && . "$SCRIPTS_DIR/status.sh"

# CLI palette — themed via HERD_THEME (default tokyonight, byte-identical to the historical 16-color
# c_* set). theme.sh + herd_theme_load_cli set c_bold/c_dim/c_grn/c_yel/c_red/c_rst; the config-loading
# readers (status/cost/why) re-invoke herd_theme_load_cli after loading .herd/config so a project's
# HERD_THEME recolors them. Blanked to "" under NO_COLOR or a non-TTY stdout (plain output). If
# theme.sh is somehow absent the vars stay empty and every surface degrades to plain — never a crash.
c_bold=""; c_dim=""; c_grn=""; c_yel=""; c_red=""; c_rst=""
if [ -f "$SCRIPTS_DIR/theme.sh" ]; then
  # shellcheck source=/dev/null
  . "$SCRIPTS_DIR/theme.sh"
  herd_theme_load_cli
fi
say()  { printf '%s\n' "$*"; }
ok()   { printf '%s✅ %s%s\n' "$c_grn" "$*" "$c_rst"; }
warn() { printf '%s⚠️  %s%s\n' "$c_yel" "$*" "$c_rst" >&2; }
die()  { printf '%s❌ %s%s\n' "$c_red" "$*" "$c_rst" >&2; exit 1; }
ask()  { # ask "<prompt>" "<default>" → echoes the answer (default on empty / non-interactive)
  local prompt="$1" def="${2:-}" ans=""
  if [ -t 0 ] && [ -z "${HERD_NONINTERACTIVE:-}" ]; then
    printf '%s%s%s' "$c_bold" "$prompt" "$c_rst" >&2
    [ -n "$def" ] && printf ' %s[%s]%s' "$c_dim" "$def" "$c_rst" >&2
    printf ': ' >&2
    read -r ans || true
  fi
  printf '%s' "${ans:-$def}"
}

# _ground_interactive — true when the grounding interview should prompt: a real stdin TTY (or the
# HERD_GROUND_ASSUME_TTY test seam, which lets a hermetic non-tty test drive scripted answers), and
# NOT the HERD_NONINTERACTIVE scripted-init mode. A plain non-tty scripted `herd init` is false, so
# the interview is skipped cleanly (zero prompts) — matching ask()'s own interactivity contract.
_ground_interactive() {
  { [ -t 0 ] || [ -n "${HERD_GROUND_ASSUME_TTY:-}" ]; } && [ -z "${HERD_NONINTERACTIVE:-}" ]
}

# _ground_ask <prompt> <default> — like ask(), but interactive under _ground_interactive (so the
# grounding interview reads scripted answers from stdin under the HERD_GROUND_ASSUME_TTY test seam
# even without a real TTY). Returns the default without reading when non-interactive.
_ground_ask() {
  local prompt="$1" def="${2:-}" ans=""
  if _ground_interactive; then
    printf '%s%s%s' "$c_bold" "$prompt" "$c_rst" >&2
    [ -n "$def" ] && printf ' %s[%s]%s' "$c_dim" "$def" "$c_rst" >&2
    printf ': ' >&2
    read -r ans || true
  fi
  printf '%s' "${ans:-$def}"
}

# _ground_yes <answer> — success for an affirmative interview answer (y / yes, case-insensitive).
_ground_yes() { case "$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')" in y|yes) return 0 ;; *) return 1 ;; esac; }

# _ensure_gitignored <project_root> <pattern> — append <pattern> to the project's .gitignore unless
# already present (idempotent). Used for per-machine / secret files that must never be committed.
_ensure_gitignored() {
  local gi="$1/.gitignore" pat="$2"
  { [ -f "$gi" ] && grep -qxF "$pat" "$gi"; } && return 0
  printf '%s\n' "$pat" >> "$gi"
  ok "added $pat to .gitignore"
}

# render_skill <project_root> <config_file> — render templates/coordinator.md.tmpl into the
# project's .claude/commands/<name>.md, substituting {{TOKENS}} from the config. Pure bash string
# replacement (no sed) so values containing / & | are safe.
render_skill() {
  local root="$1" cfg="$2"
  # Load the config in a subshell-safe way: source it to read the answers. HERD-47: after the
  # committed baseline, also source the sibling per-user overlay .herd/config.local (when present) so
  # the rendered skill reflects the EFFECTIVE config — matching herd-config.sh's baseline-then-overlay
  # precedence, so a machine-scoped render key (e.g. HERD_DRIVER) set with `config set` is honored.
  # shellcheck source=/dev/null
  ( . "$cfg"
    _rs_local="$(dirname "$cfg")/config.local"; [ -f "$_rs_local" ] && . "$_rs_local"
    : "${WORKSPACE_NAME:=$(basename "$root")}"
    : "${PROJECT_ROOT:=$root}"
    : "${DEFAULT_BRANCH:=origin/main}"
    : "${BACKLOG_FILE:=BACKLOG.md}"
    : "${DENY_PATHS:=}"
    : "${HERD_REPO:=}"
    : "${COORDINATOR_CMD:=/coordinator}"
    local name="${COORDINATOR_CMD#/}"; name="${name:-coordinator}"
    local out_dir="$root/.claude/commands"
    mkdir -p "$out_dir"
    local out="$out_dir/$name.md"

    # ── Driver: the runtime-specific control surface (multiplexer + agent runtime). HERD_DRIVER
    # (default herdr-claude, the only driver shipped) selects templates/drivers/<driver>.driver,
    # whose DRIVER_* bindings are substituted into the {{DRIVER_*}} tokens below — the SAME token
    # machinery as the other keys. Default renders the skill functionally identical to before the
    # abstraction (see docs/driver-abstraction.md). Unknown value ⇒ loud error listing what ships.
    : "${HERD_DRIVER:=herdr-claude}"
    local _drivers_dir="${HERD_DRIVERS_DIR:-$TEMPLATES_DIR/drivers}"
    local _driver_file="$_drivers_dir/$HERD_DRIVER.driver"
    if [ ! -f "$_driver_file" ]; then
      local _avail=''
      if [ -d "$_drivers_dir" ]; then
        local _f
        for _f in "$_drivers_dir"/*.driver; do
          [ -e "$_f" ] || continue
          _f="${_f##*/}"; _avail="${_avail:+$_avail, }${_f%.driver}"
        done
      fi
      die "unknown HERD_DRIVER '$HERD_DRIVER' — no driver definition at $_driver_file. Available drivers: ${_avail:-<none>}"
    fi
    # shellcheck source=/dev/null
    . "$_driver_file"
    # The DRIVER_* keys the sourced driver actually defines — a driver missing one the template
    # tokenizes leaves its {{DRIVER_*}} token unsubstituted, caught by the completeness lint below.
    local _dvars; _dvars="$(compgen -v DRIVER_ 2>/dev/null || true)"

    # Build {{CAPABILITIES}} from templates/capabilities.tsv as a COMPACT one-line-per-item index
    # (name + a terse gloss) rather than the full catalog. The verbose description + when_to_surface
    # for every row is inlined on EVERY coordinator session otherwise (~50KB / ~12.5K tokens, ~72% of
    # the rendered skill); this index cuts that recurring per-session tax while keeping the full
    # reference REACHABLE via the pointer below (docs/capabilities-overview.md + capabilities.tsv,
    # which carries the same when_to_surface column). A coordinator loads this index by default and
    # reads the full doc only when it needs the detail. Deterministic + byte-stable for a manifest.
    local CAPABILITIES _caps_file="${HERD_CAPABILITIES_FILE:-$TEMPLATES_DIR/capabilities.tsv}"
    local _caps_ref="$TEMPLATES_DIR/capabilities.tsv"
    local _caps_doc="$HERDKIT_HOME/docs/capabilities-overview.md"
    CAPABILITIES=''
    if [ -f "$_caps_file" ]; then
      # Preamble: pointer to the full reference, then the live-state surface. Interpolates the two
      # absolute doc paths; the rest is written so its backticks stay literal.
      CAPABILITIES='## Herdkit capabilities — compact index

_A one-line index of every command, lane, config key, lever, convention, env var, and reference. For
the full description **and** when-to-use guidance of any item, read `'"$_caps_doc"'`
(curated narrative) or its machine-readable source of truth `'"$_caps_ref"'`
(one row per item, with a `when_to_surface` column). Load those only when you need the detail — this
index is enough to know what exists._

_On every invocation, read live state to surface what is configured:_
- Run `herd link list` — shows peers in `.herd/links` (enables `herd report --to <name>`)
- Run `[ -f .herd/deps ] && cat .herd/deps` — upstream blockers tracked by dep-watcher
- Check `MERGE_POLICY` in `.herd/config`: empty/auto → watcher auto-merges; approve → use `herd-approve.sh`; observe → watcher never merges'
      # Group by kind in a fixed order (one header per section), each row a terse bullet. _req absorbs
      # the optional 5th "requires" column so it never leaks into the gloss.
      local _kind _hdr _section _n _k _d _w _req _g
      for _kind in command lane config lever convention env reference; do
        case "$_kind" in
          command)    _hdr="### Commands (\`herd <subcommand>\`)" ;;
          lane)       _hdr="### Lanes (\`bash ${SCRIPTS_DIR}/<lane>.sh\`)" ;;
          config)     _hdr="### Config keys (\`.herd/config\`)" ;;
          lever)      _hdr="### State files and levers" ;;
          convention) _hdr="### Conventions" ;;
          env)        _hdr="### Environment variables" ;;
          reference)  _hdr="### Reference" ;;
        esac
        _section=''
        while IFS=$'\t' read -r _n _k _d _w _req; do
          [ "$_n" = "name" ] && continue
          [ -z "$_n" ] && continue
          [ "$_k" != "$_kind" ] && continue
          # Terse gloss: first sentence of the description, capped at 120 chars on a word boundary.
          _g="${_d%%. *}"
          # A first-sentence split lands mid-abbreviation on "e.g."/"i.e." — detect the dangling
          # fragment and fall back to a hard cap of the full description instead.
          case "$_g" in *[Ee].[Gg]|*[Ii].[Ee]) _g="$_d" ;; esac
          if [ "${#_g}" -gt 120 ]; then _g="${_g:0:120}"; _g="${_g% *}"; _g="${_g}…"; fi
          _section="${_section}"$'\n'"- \`${_n}\` — ${_g}"
        done < "$_caps_file"
        [ -n "$_section" ] && CAPABILITIES="${CAPABILITIES}"$'\n\n'"${_hdr}${_section}"
      done
    fi

    # bash 5.2 turned ON `patsub_replacement` by default: an unquoted `&` in the REPLACEMENT string of
    # a `${var//pat/repl}` expansion now expands to the MATCHED text (sed-like), where every earlier
    # bash treated it literally. The token substitutions below feed values that legitimately contain
    # `&` (e.g. the {{CAPABILITIES}} index carries `[ -f .herd/deps ] && cat …`), so on bash 5.2 each
    # `&` was rewritten to the matched `{{CAPABILITIES}}` token — re-injecting the very token the
    # completeness lint then flags, breaking `herd render` on Git Bash / any bash ≥ 5.2. Disable the
    # option here (subshell-scoped) so these replacements stay LITERAL on every bash. Guarded so it is a
    # harmless no-op on bash < 5.2 where the option does not exist.
    shopt -u patsub_replacement 2>/dev/null || true
    local line _dk
    while IFS= read -r line || [ -n "$line" ]; do
      # Driver tokens FIRST, so a driver value that itself contains a {{TOKEN}} (e.g. {{SCRIPTS_DIR}})
      # is resolved by the passes below. Only keys the driver defined are substituted; a token whose
      # capability the driver omits survives to the completeness lint.
      for _dk in $_dvars; do
        line="${line//\{\{$_dk\}\}/${!_dk}}"
      done
      line="${line//\{\{WORKSPACE_NAME\}\}/$WORKSPACE_NAME}"
      line="${line//\{\{PROJECT_ROOT\}\}/$PROJECT_ROOT}"
      line="${line//\{\{DEFAULT_BRANCH\}\}/$DEFAULT_BRANCH}"
      line="${line//\{\{BACKLOG_FILE\}\}/$BACKLOG_FILE}"
      line="${line//\{\{SCRIPTS_DIR\}\}/$SCRIPTS_DIR}"
      line="${line//\{\{DENY_PATHS\}\}/$DENY_PATHS}"
      line="${line//\{\{HERD_REPO\}\}/$HERD_REPO}"
      line="${line//\{\{COORDINATOR_CMD\}\}/$COORDINATOR_CMD}"
      line="${line//\{\{CAPABILITIES\}\}/$CAPABILITIES}"
      printf '%s\n' "$line"
    done < "$TEMPLATES_DIR/coordinator.md.tmpl" > "$out"

    # Completeness lint: no {{TOKEN}} may survive — a driver missing a tokenized capability, or an
    # unknown config token, must fail LOUDLY here rather than emit a broken skill (mirrors the
    # hermetic "no leftover {{tokens}}" render check).
    if grep -qE '\{\{[A-Za-z_][A-Za-z0-9_]*\}\}' "$out"; then
      local _left; _left="$(grep -oE '\{\{[A-Za-z_][A-Za-z0-9_]*\}\}' "$out" | sort -u | tr '\n' ' ')"
      die "coordinator render left unsubstituted token(s): ${_left}— driver '$HERD_DRIVER' or .herd/config is missing a binding for them"
    fi
    printf '%s' "$out"
  )
}

# ── scout: cheap heuristics about the repo, printed for the interview defaults ─────────────────
scout_repo() {
  local root="$1" lang="unknown" backlog="" tracker_hint=""
  [ -f "$root/package.json" ] && lang="node"
  { [ -f "$root/pyproject.toml" ] || [ -f "$root/requirements.txt" ] || [ -f "$root/setup.py" ]; } && lang="python"
  [ -f "$root/go.mod" ] && lang="go"
  [ -f "$root/Cargo.toml" ] && lang="rust"
  { [ -f "$root/pom.xml" ] || [ -f "$root/build.gradle" ] || [ -f "$root/build.gradle.kts" ]; } && lang="java"
  for f in BACKLOG.md TODO.md ROADMAP.md CHANGELOG.md; do
    [ -f "$root/$f" ] && backlog="${backlog:+$backlog }$f"
  done
  [ -d "$root/.github" ] && tracker_hint="github"
  { grep -rqs -iE 'LINEAR_|linear\.app' "$root" 2>/dev/null; } && tracker_hint="${tracker_hint:+$tracker_hint,}linear?"
  { grep -rqs -iE 'JIRA_|atlassian' "$root" 2>/dev/null; } && tracker_hint="${tracker_hint:+$tracker_hint,}jira?"
  printf 'lang=%s\nbacklog=%s\ntracker=%s\n' "$lang" "$backlog" "$tracker_hint"
}

# ── stack-aware init: map scout's detected lang → the healthcheck template to seed ──────────────
# Threads scout's `lang` through to the per-project healthcheck so a non-Python/Node consumer gets a
# runnable heavy-profile gate in their own toolchain instead of the reference stack's Python example (the
# single highest-leverage external-consumer fix — see docs/external-consumer-audit.md, leaks D & B).
# python and unknown BOTH map to the existing healthcheck.project.sh so today's behavior is preserved
# exactly. Prints the template basename under $TEMPLATES_DIR.
_healthcheck_template_for() {
  case "$1" in
    node)  printf 'healthcheck.node.sh' ;;
    go)    printf 'healthcheck.go.sh' ;;
    rust)  printf 'healthcheck.rust.sh' ;;
    java)  printf 'healthcheck.java.sh' ;;
    *)     printf 'healthcheck.project.sh' ;;   # python / unknown — unchanged default
  esac
}

# ── GitHub detection: repo-aware config defaults from branch protection (init-only) ─────────────
# When a GitHub remote AND an authenticated gh CLI both exist, query the repo + its default-branch
# protection to DERIVE SAFE config defaults. The safe direction is human-in-the-loop: a protected
# default branch that requires PR review ⇒ MERGE_POLICY=approve (NEVER auto — auto-merging without
# sign-off against a protected branch is the unsafe direction); the repo's allowed merge methods
# constrain the MERGE_METHOD suggestion; required status checks are surfaced for the watcher's
# mergeability gate. Everything else keeps today's defaults.
#
# detect_github prints a `key=value` contract on stdout — the same shape scout_repo uses, parsed by
# the interview. It DEGRADES GRACEFULLY: no remote / no gh / unauthenticated ⇒ a single
# `skip=<reason>` line and nothing else, so init NEVER hard-fails from detection. Every gh call
# tolerates a non-zero exit (404 no-protection / 403 no-access) — absence of protection is a valid
# finding, not an error. Bypass entirely with HERD_SKIP_GH_DETECT=1 (tests / offline).

# _gh_repo_slug <root> <default_branch_ref> — resolve owner/repo from the remote behind the default
# branch (DEFAULT_BRANCH=origin/main → remote 'origin'). Prints owner/repo for a github.com remote
# (SSH scp-form, ssh://, or https://), empty for a non-GitHub host or no remote.
_gh_repo_slug() {
  local root="$1" ref="$2" remote url path owner repo
  remote="${ref%%/*}"; [ -n "$remote" ] && [ "$remote" != "$ref" ] || remote="origin"
  url="$(git -C "$root" remote get-url "$remote" 2>/dev/null || true)"
  [ -n "$url" ] || return 0
  case "$url" in *github.com*) ;; *) return 0 ;; esac
  path="${url#*github.com}"          # strip protocol + host, leaving ':owner/repo.git' or '/owner/repo.git'
  path="${path#:}"; path="${path#/}" # drop the scp-form ':' or the url path '/'
  path="${path%.git}"
  owner="${path%%/*}"; repo="${path#*/}"; repo="${repo%%/*}"
  [ -n "$owner" ] && [ -n "$repo" ] && [ "$owner" != "$path" ] && printf '%s/%s' "$owner" "$repo"
}

# _gh_repo_field <json> <key> — echo a top-level string field from repo JSON ('' on miss/bad JSON).
_gh_repo_field() {
  printf '%s' "$1" | KEY="$2" python3 -c 'import os,sys,json
try: d=json.load(sys.stdin)
except Exception: d={}
v=d.get(os.environ["KEY"],"") if isinstance(d,dict) else ""
print(v if v is not None else "")' 2>/dev/null || true
}

# _gh_merge_methods <repo-json> — echo the allowed merge methods as a comma list (merge,squash,rebase).
_gh_merge_methods() {
  printf '%s' "$1" | python3 -c 'import sys,json
try: d=json.load(sys.stdin)
except Exception: d={}
if not isinstance(d,dict): d={}
m=[]
if d.get("allow_merge_commit"): m.append("merge")
if d.get("allow_squash_merge"): m.append("squash")
if d.get("allow_rebase_merge"): m.append("rebase")
print(",".join(m))' 2>/dev/null || true
}

# _gh_protection <protection-json> — parse the branch-protection payload into three key=value lines:
#   reviews_required=<0|1>   the required_pull_request_reviews block is present (human review gated)
#   reviews=<n>              required_approving_review_count
#   checks=<c1,c2,...>       required status-check contexts (legacy .contexts and newer .checks)
_gh_protection() {
  printf '%s' "$1" | python3 -c 'import sys,json
try: d=json.load(sys.stdin)
except Exception: d={}
if not isinstance(d,dict): d={}
pr=d.get("required_pull_request_reviews")
req=1 if isinstance(pr,dict) else 0
cnt=(pr.get("required_approving_review_count") or 0) if isinstance(pr,dict) else 0
sc=d.get("required_status_checks") or {}
ctx=[]
if isinstance(sc,dict):
    ctx=list(sc.get("contexts") or [])
    for c in (sc.get("checks") or []):
        if isinstance(c,dict) and c.get("context"): ctx.append(c["context"])
seen=[]; [seen.append(c) for c in ctx if c and c not in seen]
print("reviews_required=%d"%req)
print("reviews=%d"%int(cnt))
print("checks=%s"%",".join(seen))' 2>/dev/null || true
}

detect_github() {
  local root="$1" ref="$2"
  [ "${HERD_SKIP_GH_DETECT:-}" = "1" ] && { printf 'skip=detection disabled (HERD_SKIP_GH_DETECT=1)\n'; return 0; }

  local slug; slug="$(_gh_repo_slug "$root" "$ref")"
  [ -n "$slug" ]                          || { printf 'skip=no GitHub remote found\n'; return 0; }
  command -v gh >/dev/null 2>&1           || { printf 'skip=gh CLI not installed\n'; return 0; }
  gh auth status >/dev/null 2>&1          || { printf 'skip=gh not authenticated (run: gh auth login)\n'; return 0; }

  # Default branch: the segment after remote/ in the ref (origin/main → main); the repo API below
  # overrides it with the canonical name when reachable.
  local branch="${ref#*/}"; { [ -n "$branch" ] && [ "$branch" != "$ref" ]; } || branch="main"

  # (1) Repo metadata — allowed merge methods + canonical default branch. 403/404 tolerated.
  local repo_json="" repo_ok=0 mm="" api_branch
  if repo_json="$(gh api "repos/$slug" 2>/dev/null)"; then
    repo_ok=1
    api_branch="$(_gh_repo_field "$repo_json" default_branch)"
    [ -n "$api_branch" ] && branch="$api_branch"
    mm="$(_gh_merge_methods "$repo_json")"
  fi

  # (2) Branch protection on the default branch. A non-zero exit (404 = unprotected, 403 = no access)
  #     is a valid finding, not an error.
  local prot_json="" protected=0 reviews_required=0 reviews=0 checks="" parsed
  if prot_json="$(gh api "repos/$slug/branches/$branch/protection" 2>/dev/null)"; then
    protected=1
    parsed="$(_gh_protection "$prot_json")"
    reviews_required="$(printf '%s' "$parsed" | sed -n 's/^reviews_required=//p')"
    reviews="$(printf '%s' "$parsed" | sed -n 's/^reviews=//p')"
    checks="$(printf '%s' "$parsed" | sed -n 's/^checks=//p')"
  fi

  # (3) CODEOWNERS presence — the local working tree (init runs inside the repo checkout).
  local codeowners=0 f
  for f in .github/CODEOWNERS CODEOWNERS docs/CODEOWNERS; do
    [ -f "$root/$f" ] && { codeowners=1; break; }
  done

  # (4) Derive SAFE defaults. Required human review ⇒ approve (never auto). Allowed merge methods
  #     constrain the suggested method (prefer merge > squash > rebase among those allowed); when the
  #     repo API was unreachable, keep today's default of a merge commit.
  local policy="auto" method="merge"
  [ "${reviews_required:-0}" = "1" ] && policy="approve"
  case ",${mm}," in
    *,merge,*)  method="merge"  ;;
    *,squash,*) method="squash" ;;
    *,rebase,*) method="rebase" ;;
  esac

  printf 'slug=%s\n'          "$slug"
  printf 'branch=%s\n'        "$branch"
  printf 'repo_ok=%s\n'       "$repo_ok"
  printf 'protected=%s\n'     "$protected"
  printf 'reviews_required=%s\n' "${reviews_required:-0}"
  printf 'reviews=%s\n'       "${reviews:-0}"
  printf 'checks=%s\n'        "$checks"
  printf 'codeowners=%s\n'    "$codeowners"
  printf 'merge_methods=%s\n' "$mm"
  printf 'policy=%s\n'        "$policy"
  printf 'method=%s\n'        "$method"
}

# ── init grounding interview (HERD-80) ────────────────────────────────────────────────────────────
# Nothing at `herd init` tells a new project that builder grounding (codemap / CONTEXT_PROVISION),
# coordinator tooling (graphify / GRAPHIFY_BIN), builder MCP wiring (MCP_PROVISION), or the efficiency
# levers even EXIST — the operator only finds them by reading capabilities.tsv. This closes that gap
# with the SAME suggest-never-auto-write contract as `herd config sync`: every source is OFFERED, and
# applied ONLY on an explicit yes, ONLY through the validated `herd config set` (manifest validation,
# machine-scope routing, secret refusal). Nothing here is auto-written. Runs LAST in cmd_init, after
# the config exists (config set requires it). A scripted / non-tty init skips the whole block cleanly
# (_ground_interactive false) so `herd init` stays fully non-interactive for automation.
_init_grounding_interview() {
  local project_root="$1"
  _ground_interactive || return 0   # scripted / non-tty init: skip cleanly, zero prompts, nothing written

  say ""
  say "${c_bold}Grounding & tooling${c_rst} ${c_dim}(all optional — nothing is written unless you say yes)${c_rst}"

  # (a) Builder grounding: generate THIS project's code map now (consumer-project mode, HERD-79) and
  #     point every spawned builder at it via CONTEXT_PROVISION=codemap, so builders load the committed
  #     map instead of re-exploring the tree each session. The map is only pointed-to once it exists.
  say ""
  say "  ${c_dim}Builders re-explore the repo each session unless you ground them with a code map.${c_rst}"
  if _ground_yes "$(_ground_ask "Generate docs/codemap.md now and set CONTEXT_PROVISION=codemap? (y/N)" "n")"; then
    if ( cd "$project_root" && cmd_codemap </dev/null ) && [ -f "$project_root/docs/codemap.md" ]; then
      ( cd "$project_root" && cmd_config_set CONTEXT_PROVISION codemap )
    else
      warn "codemap generation did not produce docs/codemap.md — leaving CONTEXT_PROVISION unset; run 'herd codemap' then 'herd config set CONTEXT_PROVISION codemap' later"
    fi
  else
    say "  ${c_dim}skipped — later: herd codemap && herd config set CONTEXT_PROVISION codemap${c_rst}"
  fi

  # (b) Coordinator tooling: graphify powers the coordinator's pre-spawn cross-worktree overlap read.
  #     If it is on PATH, offer to pin GRAPHIFY_BIN — a MACHINE-scoped key, so `herd config set` routes
  #     it to the gitignored .herd/config.local (we also ensure that overlay is gitignored in the
  #     consumer). If absent, print the PyPI install hint instead of writing anything.
  say ""
  local gpath; gpath="$(command -v graphify 2>/dev/null || true)"
  if [ -n "$gpath" ]; then
    if _ground_yes "$(_ground_ask "graphify found at $gpath — set GRAPHIFY_BIN (per-machine → .herd/config.local) for the coordinator's pre-spawn overlap read? (y/N)" "n")"; then
      ( cd "$project_root" && cmd_config_set GRAPHIFY_BIN "$gpath" )
      _ensure_gitignored "$project_root" '.herd/config.local'
    else
      say "  ${c_dim}skipped — later: herd config set GRAPHIFY_BIN $gpath${c_rst}"
    fi
  else
    say "  ${c_dim}graphify not on PATH — the coordinator's pre-spawn overlap read stays off (optional accelerator).${c_rst}"
    say "  ${c_dim}Install: pipx install graphifyy  (PyPI 'graphifyy'), then: herd config set GRAPHIFY_BIN ~/.local/bin/graphify${c_rst}"
  fi

  # (c) Builder MCP tools: wire an MCP server into every builder worktree (context7 = live library
  #     docs, most valuable on real code CONSUMER projects). Blank keeps today's byte-identical
  #     settings.json. Applied via the validated setter (MCP_PROVISION), committed baseline.
  say ""
  local mcp; mcp="$(_ground_ask "MCP_PROVISION — wire an MCP server into each builder worktree (e.g. 'context7' for live library docs; blank = none)" "")"
  if [ -n "$mcp" ]; then
    ( cd "$project_root" && cmd_config_set MCP_PROVISION "$mcp" )
  else
    say "  ${c_dim}skipped — later: herd config set MCP_PROVISION context7${c_rst}"
  fi

  # (d) Efficiency levers — SURFACE ONLY (one-line measured rationale each). Never auto-set: two are
  #     watcher-affecting (a set would restart a not-yet-running control room mid-init), and the point
  #     here is awareness. Each is applied later with the same validated `herd config set`.
  say ""
  say "  ${c_bold}Efficiency levers${c_rst} ${c_dim}(surface-only — set any later with 'herd config set <KEY> <VALUE>'):${c_rst}"
  say "  ${c_dim}• REVIEW_ESCALATE_GLOB — reserve the expensive Opus review for engine-critical paths; docs/test-only diffs skip review. The single biggest recurring engine cost.${c_rst}"
  say "  ${c_dim}• HEALTHCHECK_HEAVY_GLOB — blank runs the full suite on every diff; scope it to your source globs so trivial diffs take the light profile.${c_rst}"
  say "  ${c_dim}• DOCTOR_STARTUP_HINT=on — reminds you at control-room startup which optional tools are missing and what each degrades.${c_rst}"
}

# ── governance adoption (HERD-119) ────────────────────────────────────────────────────────────────
# `herd init`'s OPT-IN adoption pass imports gates/conventions from an OPTIONAL CLAUDE.md / AGENTS.md.
# BINDING CONSTRAINT: CLAUDE.md is ONE source among many (defaults, interview, profile, manual
# `herd config set`) — never required, never load-bearing. No file present ⇒ the pass returns before
# any prompt or write, so init is BYTE-IDENTICAL. Every accepted proposal applies ONLY through the
# validated `herd config set` (or an append to the REVIEW_CHECKLIST file); declining all leaves the
# config exactly as the interview wrote it. Deterministic-first (templates/governance-map.tsv), with a
# cleanly-stubbable LLM fallback for fuzzy phrasing. Fail-soft: unparseable prose is silently skipped.
#
# The read-only extraction + mapping half (_gov_map_file / _gov_statements / _gov_match) lives in
# scripts/herd/governance.sh, sourced near the top of this file and SHARED with the HERD-125 drift
# sweep. The init-only mutators + the default-off LLM fallback below are NOT shared.

# _gov_llm_classify <statement> — LLM FALLBACK for fuzzy phrasing the deterministic table missed.
# CLEANLY STUBBABLE and DEFAULT-OFF: unless HERD_GOV_LLM=1 AND `claude` is on PATH it prints nothing,
# so extraction is fully deterministic (and hermetic tests get a stable, model-free mapping). When
# enabled it asks the model to map the sentence to at most one surface, echoing the SAME
# "surface<TAB>target<TAB>label" contract the table uses; any non-conforming reply is dropped.
_gov_llm_classify() {
  [ "${HERD_GOV_LLM:-}" = "1" ] || return 0
  command -v claude >/dev/null 2>&1 || return 0
  local stmt="$1" reply surface rest
  reply="$(claude -p "Map this project-governance sentence to AT MOST ONE herd enforcement surface, or reply NONE. Reply with a single line: '<surface>\t<target>\t<label>' where surface is one of config-key|provisioning|hook. config-key target is SPACE-separated KEY=VALUE using only these keys: PUSH_GATE MERGE_POLICY MERGE_METHOD PR_FLOW PR_READY_WHEN DELETE_BRANCH_ON_MERGE ATTRIBUTION_POLICY COMMIT_CONVENTION. provisioning target is 'review-checklist'. Reply NONE if unsure. Sentence: $stmt" 2>/dev/null || true)"
  reply="$(printf '%s' "$reply" | head -1)"
  case "$reply" in ''|NONE|none) return 0 ;; esac
  surface="${reply%%$'\t'*}"; rest="${reply#*$'\t'}"
  case "$surface" in
    config-key|provisioning|hook) [ "$rest" != "$reply" ] && printf '%s' "$reply" ;;
  esac
  return 0
}

# _gov_is_convention <statement> — deterministic heuristic distinguishing an unmatched coding/STYLE
# convention (→ provisioning) from noise (→ gap report). Only reached AFTER the table and the LLM
# fallback both miss.
_gov_is_convention() {
  printf '%s' "$1" | grep -qiE '\b(prefer|preferred|use|using|avoid|style|format|formatting|naming|indent|indentation|tabs?|spaces|convention|conventions|docstring|comment|comments|type[- ]?hint|typed|snake_case|camelcase|line[- ]length|import|imports)\b' 2>/dev/null
}

# _gov_review_checklist_path <project_root> — the repo-relative REVIEW_CHECKLIST path from .herd/config
# (default .herd/review-checklist.md when unset).
_gov_review_checklist_path() {
  local root="$1" p=""
  # shellcheck source=/dev/null
  [ -f "$root/.herd/config" ] && p="$( . "$root/.herd/config" 2>/dev/null; printf '%s' "${REVIEW_CHECKLIST:-}" )"
  printf '%s' "${p:-.herd/review-checklist.md}"
}

# _gov_apply_config <project_root> <KEY=VALUE...> — apply each accepted config-key pair through the
# VALIDATED setter. HERD_INIT_DEFER_APPLY suppresses the watcher-restart / re-render side-effect: init
# runs BEFORE the control room exists, so the value is simply written and takes effect on first launch.
_gov_apply_config() {
  local root="$1" pairs="$2" kv key val
  for kv in $pairs; do
    key="${kv%%=*}"; val="${kv#*=}"
    { [ -n "$key" ] && [ "$key" != "$kv" ]; } || continue
    ( cd "$root" && export HERD_INIT_DEFER_APPLY=1 && cmd_config_set "$key" "$val" ) || true
  done
}

# _gov_apply_provision <project_root> <statement> — route an unmappable coding/style convention into
# the REVIEW_CHECKLIST file (created with a header on first use), so the pre-merge review gate verifies
# it. The provisioning surface's session-grounding sibling (CONTEXT_PROVISION notes) plugs in here later.
_gov_apply_provision() {
  local root="$1" line="$2" rel dest
  rel="$(_gov_review_checklist_path "$root")"
  dest="$root/$rel"
  mkdir -p "$(dirname "$dest")" 2>/dev/null || true
  if [ ! -f "$dest" ]; then
    {
      printf '# Review checklist\n\n'
      printf '> Project risk checklist injected into the pre-merge review gate (REVIEW_CHECKLIST).\n'
      printf '> Seeded by governance adoption from an adopted CLAUDE.md/AGENTS.md convention.\n\n'
    } > "$dest"
  fi
  printf -- '- [ ] %s\n' "$line" >> "$dest"
  ok "appended convention to $rel"
}

# _init_governance_adoption <project_root> — the opt-in adoption pass. Runs AFTER the config exists
# (config set requires it) and only under _ground_interactive (a scripted/non-tty init skips cleanly).
# No CLAUDE.md/AGENTS.md ⇒ returns before any prompt or write (byte-identical init).
_init_governance_adoption() {
  local root="$1"
  _ground_interactive || return 0

  # Collect the OPTIONAL governance sources actually present. None ⇒ nothing to do, zero output.
  # (No bash arrays anywhere in this function — an empty-array expansion under `set -u` aborts on
  # bash 3.2 / macOS; the file's established idiom is newline-delimited strings.)
  local names=""
  [ -f "$root/CLAUDE.md" ] && names="CLAUDE.md"
  [ -f "$root/AGENTS.md" ] && names="${names:+$names, }AGENTS.md"
  [ -n "$names" ] || return 0

  say ""
  say "${c_bold}Governance adoption${c_rst} ${c_dim}(optional — CLAUDE.md/AGENTS.md is ONE source; nothing is written unless you accept a proposal)${c_rst}"
  if ! _ground_yes "$(_ground_ask "Found $names — scan for governance rules to propose as herd config? (y/N)" "n")"; then
    say "  ${c_dim}skipped — later: re-run 'herd init' or set gates manually with 'herd config set'${c_rst}"
    return 0
  fi

  # Deterministic-first extraction. Each statement → a (surface,target,label,evidence) proposal, a
  # style-convention (→ provisioning), or a gap. Proposals accumulate as newline-delimited TAB records
  # (no arrays), deduped by surface+target (first evidence kept) so the same gate is proposed once.
  local proposals="" gaps="" seen="" stmt m surface target label
  while IFS= read -r stmt; do
    [ -n "$stmt" ] || continue
    m="$(_gov_match "$stmt")"
    [ -n "$m" ] || m="$(_gov_llm_classify "$stmt")"
    if [ -z "$m" ]; then
      if _gov_is_convention "$stmt"; then
        m="$(printf 'provisioning\treview-checklist\tCoding/style convention')"
      else
        gaps="${gaps}${stmt}"$'\n'
        continue
      fi
    fi
    surface="${m%%$'\t'*}"; m="${m#*$'\t'}"
    target="${m%%$'\t'*}"; label="${m#*$'\t'}"
    case "$seen" in *"|${surface}::${target}|"*) continue ;; esac
    seen="${seen}|${surface}::${target}|"
    proposals="${proposals}$(printf '%s\t%s\t%s\t%s' "$surface" "$target" "$label" "$stmt")"$'\n'
  done <<< "$(_gov_statements "$root/CLAUDE.md" "$root/AGENTS.md")"

  # Present each proposal: QUOTE the source sentence as evidence; per-proposal accept / edit / decline.
  # config-key applies via the validated setter; provisioning appends to REVIEW_CHECKLIST; hook rows
  # are RECOGNIZED but not applied (the 'Governance hook-rendering' follow-up consumes them). Iterate by
  # line INDEX (not a pipe/here-string around the loop) so _ground_ask keeps reading the real stdin.
  local applied=0 deferred="" rec evidence ans i np
  np="$(printf '%s' "$proposals" | grep -c . || true)"
  for (( i=1; i<=np; i++ )); do
    rec="$(printf '%s' "$proposals" | sed -n "${i}p")"
    IFS=$'\t' read -r surface target label evidence <<< "$rec"
    [ -n "$surface" ] || continue
    say ""
    say "  ${c_bold}${label}${c_rst}"
    say "  ${c_dim}evidence: \"${evidence}\"${c_rst}"
    case "$surface" in
      config-key)
        say "  ${c_dim}→ proposes (config-key surface): herd config set ${target}${c_rst}"
        ans="$(_ground_ask "  accept / edit / decline? (a/e/N)" "n")"
        case "$(printf '%s' "$ans" | tr '[:upper:]' '[:lower:]')" in
          a|accept) _gov_apply_config "$root" "$target"; applied=$((applied+1)) ;;
          e|edit)
            local edited; edited="$(_ground_ask "  enter KEY=VALUE pair(s)" "$target")"
            if [ -n "$edited" ]; then _gov_apply_config "$root" "$edited"; applied=$((applied+1)); else say "  ${c_dim}declined (empty)${c_rst}"; fi ;;
          *) say "  ${c_dim}declined${c_rst}" ;;
        esac ;;
      provisioning)
        say "  ${c_dim}→ proposes (provisioning surface): append to the REVIEW_CHECKLIST risk checklist${c_rst}"
        ans="$(_ground_ask "  accept / decline? (a/N)" "n")"
        case "$(printf '%s' "$ans" | tr '[:upper:]' '[:lower:]')" in
          a|accept) _gov_apply_provision "$root" "$evidence"; applied=$((applied+1)) ;;
          *) say "  ${c_dim}declined${c_rst}" ;;
        esac ;;
      hook)
        say "  ${c_dim}→ hook surface (session-time Claude Code hook) — recognized; rendering ships in the 'Governance hook-rendering' follow-up, not applied here${c_rst}"
        deferred="${deferred}  • ${label} (hook: ${target})"$'\n' ;;
    esac
  done

  if [ -n "$deferred" ]; then
    say ""
    say "  ${c_bold}Recognized hook rules${c_rst} ${c_dim}(deferred to 'Governance hook-rendering'):${c_rst}"
    printf '%s' "$deferred" | while IFS= read -r d; do [ -n "$d" ] && say "  ${c_dim}${d}${c_rst}"; done
  fi

  # Gap report — statements that mapped to NO governance surface, left as prose.
  if [ -n "$gaps" ]; then
    say ""
    local gapn; gapn="$(printf '%s' "$gaps" | grep -c . || true)"
    say "  ${c_bold}Gap report${c_rst} ${c_dim}— ${gapn} statement(s) mapped to no governance surface (left as prose):${c_rst}"
    printf '%s' "$gaps" | while IFS= read -r g; do [ -n "$g" ] && say "  ${c_dim}• ${g}${c_rst}"; done
  fi

  say ""
  if [ "$applied" -gt 0 ]; then ok "governance adoption: applied $applied proposal(s)"; else say "  ${c_dim}governance adoption: nothing applied${c_rst}"; fi
}

cmd_init() {
  local root; root="$(pwd)"
  [ -d "$root/.git" ] || warn "no .git here — herdkit expects a git repo at $root"

  # Dependency doctor FIRST — catch a broken environment (the issue #31 class: a missing/mis-encoded
  # load-bearing dep that silently truncates the control room) BEFORE we write any config. HARD-gates
  # on a missing required dep; HERD_SKIP_DOCTOR=1 bypasses (tests / known-good environments).
  # shellcheck source=/dev/null
  . "$SCRIPTS_DIR/herd-preflight.sh"
  if ! herd_doctor; then
    die "herd doctor found missing/broken required dependencies (above) — fix them, then re-run 'herd init'.  (bypass: HERD_SKIP_DOCTOR=1)"
  fi
  say ""

  say "${c_bold}herd init${c_rst} — standing up the herd workflow in $root"
  say ""

  # 1. Scout.
  local s; s="$(scout_repo "$root")"
  local lang backlog tracker
  lang="$(printf '%s' "$s" | sed -n 's/^lang=//p')"
  backlog="$(printf '%s' "$s" | sed -n 's/^backlog=//p')"
  tracker="$(printf '%s' "$s" | sed -n 's/^tracker=//p')"
  say "${c_dim}scout: language=${lang:-unknown}  backlog-files=[${backlog:-none}]  tracker-signals=[${tracker:-none}]${c_rst}"
  # Optional one-shot Claude scout pass (judgment, not heuristics) — best-effort, never blocks.
  if command -v claude >/dev/null 2>&1 && [ -z "${HERD_NONINTERACTIVE:-}" ]; then
    local want; want="$(ask "Run a one-shot Claude scout to propose conventions? (y/N)" "n")"
    if [ "$want" = "y" ] || [ "$want" = "Y" ]; then
      say "${c_dim}(scouting — read-only; this can take a moment)${c_rst}"
      claude -p "Scout this repo at $root for a multi-agent workflow config. In <=10 lines report: the default branch, the test/lint command to use as a healthcheck, whether there is an app preview command, the privacy/gitignored dirs, and which work tracker it uses. Read-only." 2>/dev/null || warn "scout pass skipped (claude error)"
    fi
  fi
  say ""

  # 2. Interview (detected values as defaults).
  local def_branch; def_branch="$(git -C "$root" symbolic-ref --quiet --short HEAD 2>/dev/null || echo main)"
  local project_root worktrees default_branch workspace
  project_root="$(ask "PROJECT_ROOT" "$root")"
  worktrees="$(ask "WORKTREES_DIR (worktree pool, sibling, never committed)" "${project_root}-trees")"
  default_branch="$(ask "DEFAULT_BRANCH (remote/branch to fork+push)" "origin/$def_branch")"
  workspace="$(ask "WORKSPACE_NAME (herdr label)" "$(basename "$project_root")")"

  # 2b. GitHub detection — repo-aware SAFE defaults from branch protection on the default branch.
  #     Uses the resolved DEFAULT_BRANCH to find the remote; degrades to today's defaults (auto/merge)
  #     when there is no remote / no gh / gh is unauthenticated. Never hard-fails init.
  say ""
  say "${c_bold}GitHub detection${c_rst}"
  local det det_policy="auto" det_method="merge" det_skip=""
  det="$(detect_github "$project_root" "$default_branch")"
  det_skip="$(printf '%s' "$det" | sed -n 's/^skip=//p')"
  if [ -n "$det_skip" ]; then
    say "  ${c_dim}skipped — ${det_skip}; using defaults (MERGE_POLICY=auto, MERGE_METHOD=merge)${c_rst}"
  else
    local d_slug d_branch d_protected d_revreq d_reviews d_checks d_codeowners d_methods
    d_slug="$(printf '%s' "$det" | sed -n 's/^slug=//p')"
    d_branch="$(printf '%s' "$det" | sed -n 's/^branch=//p')"
    d_protected="$(printf '%s' "$det" | sed -n 's/^protected=//p')"
    d_revreq="$(printf '%s' "$det" | sed -n 's/^reviews_required=//p')"
    d_reviews="$(printf '%s' "$det" | sed -n 's/^reviews=//p')"
    d_checks="$(printf '%s' "$det" | sed -n 's/^checks=//p')"
    d_codeowners="$(printf '%s' "$det" | sed -n 's/^codeowners=//p')"
    d_methods="$(printf '%s' "$det" | sed -n 's/^merge_methods=//p')"
    det_policy="$(printf '%s' "$det" | sed -n 's/^policy=//p')"; : "${det_policy:=auto}"
    det_method="$(printf '%s' "$det" | sed -n 's/^method=//p')"; : "${det_method:=merge}"
    say "  repo:            $d_slug"
    if [ "$d_protected" = "1" ]; then
      if [ "${d_revreq:-0}" = "1" ]; then
        say "  default branch:  $d_branch ${c_grn}(protected · ${d_reviews:-0} required review$([ "${d_reviews:-0}" = "1" ] || printf 's'))${c_rst}"
      else
        say "  default branch:  $d_branch ${c_grn}(protected · no required review)${c_rst}"
      fi
      say "  required checks: ${d_checks:-none}"
    else
      say "  default branch:  $d_branch ${c_dim}(no branch protection detected)${c_rst}"
    fi
    say "  CODEOWNERS:      $([ "$d_codeowners" = "1" ] && printf 'present' || printf 'none')"
    say "  merge methods:   ${d_methods:-unknown}"
    say "  ${c_bold}→ derived:${c_rst}       MERGE_POLICY=${c_bold}${det_policy}${c_rst}  MERGE_METHOD=${c_bold}${det_method}${c_rst}"
    [ "$det_policy" = "approve" ] && say "  ${c_dim}(required review ⇒ approve, not auto — merges wait for explicit sign-off)${c_rst}"
  fi

  # 3. Work-tracker discovery dialogue.
  say ""
  say "${c_bold}Work tracker${c_rst}"
  local backlog_file="BACKLOG.md" backend="file" make_backlog=""
  if [ -n "$backlog" ]; then
    local first; first="$(printf '%s' "$backlog" | awk '{print $1}')"
    say "  Found: $backlog"
    local use; use="$(ask "Use '$first' as the work tracker? (Y/n)" "y")"
    if [ "$use" = "y" ] || [ "$use" = "Y" ]; then
      backlog_file="$first"
      case "$first" in CHANGELOG.md) backend="changelog" ;; *) backend="file" ;; esac
    else
      make_backlog=1
    fi
  else
    say "  No BACKLOG.md / TODO.md / CHANGELOG found."
    # A .github/ dir (surfaced by scout as tracker=github) makes GitHub Issues the natural default.
    local gh_hint="" def_choice="1"
    case "$tracker" in *github*) gh_hint=" (detected .github/)"; def_choice="2" ;; esac
    local choice
    choice="$(ask "Tracker: [1] create BACKLOG.md (recommended)  [2] GitHub Issues$gh_hint  [3] file backend at a custom path" "$def_choice")"
    case "$choice" in
      2)
        if command -v gh >/dev/null 2>&1; then
          backend="github"
          ok "GitHub Issues work tracker (SCRIBE_BACKEND=github) — items become issues; no BACKLOG.md."
        else
          warn "GitHub Issues selected but 'gh' CLI not found — falling back to a file BACKLOG.md."
          make_backlog=1
        fi
        ;;
      3) backlog_file="$(ask "BACKLOG_FILE (repo-relative)" "BACKLOG.md")"; make_backlog=1 ;;
      *) make_backlog=1 ;;
    esac
  fi
  # Explicit opt-in for an API backend. Linear ships (Phase 3) when a key is available; the other
  # API trackers remain "coming soon" and fall back to the file backend.
  local api linear_key=""; api="$(ask "Do you use Linear / Jira / Azure DevOps? (name one, or blank)" "")"
  if [ -n "$api" ]; then
    case "$(printf '%s' "$api" | tr '[:upper:]' '[:lower:]')" in
      *linear*)
        # Prefer a key already in the environment; else prompt. The key is stored in .herd/secrets
        # (gitignored) below — NEVER echoed into .herd/config.
        linear_key="${LINEAR_API_KEY:-}"
        [ -n "$linear_key" ] || linear_key="$(ask "Linear API key (→ .herd/secrets, gitignored; blank to skip)" "")"
        if [ -n "$linear_key" ]; then
          backend="linear"; make_backlog=""   # API backend — no tracked file to seed.
          ok "Linear work tracker (SCRIBE_BACKEND=linear) — items become Linear issues; key → .herd/secrets."
        else
          warn "Linear selected but no API key provided — using the file backend for now; add LINEAR_API_KEY to .herd/secrets and set SCRIBE_BACKEND=linear later."
        fi
        ;;
      *)
        warn "$api adapter is 'coming soon' (Phase 3). v1 ships file backends only — using the file backend; you can switch SCRIBE_BACKEND later and add creds to .herd/secrets."
        ;;
    esac
  fi

  # 4. Health + preview.
  say ""
  local healthcheck heavy_glob preview deny
  healthcheck="$(ask "HEALTHCHECK_CMD (exit 0 clean / 1 code error / 2 data-env; blank = syntax-only)" ".herd/healthcheck.project.sh")"
  heavy_glob="$(ask "HEALTHCHECK_HEAVY_GLOB (diff paths forcing the heavy profile; blank = always heavy)" "")"
  preview="$(ask "APP_PREVIEW_CMD (live preview; blank = none → quick-only)" "")"
  deny="$(ask "DENY_PATHS (never-committed dirs)" "")"

  local herd_repo; herd_repo="$(ask "HERD_REPO (where engine bugs escalate)" "briankeegan1/herdkit")"

  # 4b. Merge policy + method — seeded from GitHub detection (protected + required review ⇒ approve).
  #     The human can still override either here; detection only chooses the SAFE default.
  say ""
  say "${c_bold}Merge policy${c_rst}"
  local merge_policy merge_method
  merge_policy="$(ask "MERGE_POLICY (auto merges on green / approve holds for sign-off / observe never merges)" "$det_policy")"
  merge_method="$(ask "MERGE_METHOD (merge | squash | rebase)" "$det_method")"

  # 4c. PR flow — how builders open PRs. SAFE DEFAULTS preserve today's EXACT behavior: direct PRs
  #     opened ready, builder-owned readiness, branches retained on merge, and no pre-PR local review.
  say ""
  say "${c_bold}PR flow${c_rst}"
  local pr_flow pr_ready delete_branch local_review
  pr_flow="$(ask "PR_FLOW (direct = open PRs ready to merge | draft = open as draft, held by the watcher until marked ready)" "direct")"
  pr_ready="$(ask "PR_READY_WHEN (who marks a DRAFT PR ready: builder = self after healthcheck | coordinator | human; only used when PR_FLOW=draft)" "builder")"
  delete_branch="$(ask "DELETE_BRANCH_ON_MERGE (delete the head branch after merge: true | false)" "false")"
  # LOCAL_REVIEW is written + documented here, but its pre-pr behavior is DEFERRED to a follow-up lane
  # (that wiring touches the review gate / agent-watch.sh / herd-review.sh, owned elsewhere).
  local_review="$(ask "LOCAL_REVIEW (none | pre-pr — pre-pr wiring is deferred; leave 'none')" "none")"

  # 5. Write .herd/config.
  mkdir -p "$project_root/.herd"
  local cfg="$project_root/.herd/config"
  if [ -f "$cfg" ]; then
    local ov; ov="$(ask ".herd/config already exists — overwrite? (y/N)" "n")"
    [ "$ov" = "y" ] || [ "$ov" = "Y" ] || die "aborted; existing .herd/config left untouched"
  fi
  cat > "$cfg" <<EOF
# .herd/config — generated by 'herd init'. Commit this (code-shaped config, zero-secret).
HERD_VERSION=$HERDKIT_CONTRACT_VERSION

PROJECT_ROOT="$project_root"
WORKTREES_DIR="$worktrees"
DEFAULT_BRANCH="$default_branch"
WORKSPACE_NAME="$workspace"

BACKLOG_FILE="$backlog_file"
SCRIBE_BACKEND="$backend"
SHARE_LINKS=""

HEALTHCHECK_CMD="$healthcheck"
HEALTHCHECK_HEAVY_GLOB="$heavy_glob"
APP_PREVIEW_CMD="$preview"
SMOKE_CMD=""

# model map — eco-leaning STARTER defaults. Opus is now an ESCALATION tier, not a default:
# reach it deterministically via MODEL_ESCALATE_GLOB (feature lane) / REVIEW_ESCALATE_GLOB
# (review gate), not by paying for it on every quick/feature/review run.
MODEL_COORDINATOR="claude-opus-4-8"
MODEL_FEATURE="claude-sonnet-4-6"
MODEL_QUICK="claude-haiku-4-5"
MODEL_SCRIBE="claude-sonnet-4-6"
MODEL_RESEARCH="claude-sonnet-4-6"
MODEL_REVIEW="claude-sonnet-4-6"

DENY_PATHS="$deny"
REVIEW_CHECKLIST=".herd/review-checklist.md"
COORDINATOR_CMD="/coordinator"

# Merge gate — MERGE_POLICY: auto (merge on green) | approve (hold for sign-off) | observe (never).
# Seeded by 'herd init' GitHub detection: a protected default branch requiring PR review defaults to
# 'approve' (never 'auto' — merging without human sign-off against a protected branch is unsafe).
MERGE_POLICY="$merge_policy"
MERGE_METHOD="$merge_method"
WATCHER_AUTOMERGE="true"
HERD_REPO="$herd_repo"

# PR flow — how builders open PRs. SAFE DEFAULTS (direct + builder) preserve today's EXACT behavior:
# a plain 'gh pr create'. Only the LANE RULES text (herd-quick.sh / herd-feature.sh) reads these.
#   PR_FLOW:       direct (open PRs ready, today's behavior) | draft (builder opens 'gh pr create
#                  --draft'; the watcher already HOLDS draft PRs until they are marked ready).
#   PR_READY_WHEN: who promotes a DRAFT to ready — builder (self, once the healthcheck passes) |
#                  coordinator | human. Only consulted when PR_FLOW=draft.
PR_FLOW="$pr_flow"
PR_READY_WHEN="$pr_ready"
# DELETE_BRANCH_ON_MERGE — delete the head branch after a merge. Default false preserves today's
# behavior (the watcher retains branches on merge).
DELETE_BRANCH_ON_MERGE="$delete_branch"
# LOCAL_REVIEW — none (default) | pre-pr. NOTE: the pre-pr review behavior is NOT wired yet (that
# touches the review gate / agent-watch.sh / herd-review.sh, owned by another lane); this key is
# documented and written but not yet consumed. Deferred follow-up: wire pre-pr local review.
LOCAL_REVIEW="$local_review"
EOF
  ok "wrote $cfg"

  # API-backend credentials live in .herd/secrets (gitignored), never in the committed config.
  if [ "$backend" = "linear" ] && [ -n "$linear_key" ]; then
    local secrets="$project_root/.herd/secrets"
    {
      printf '# .herd/secrets — API-backend credentials. GITIGNORED. Never commit.\n'
      printf 'LINEAR_API_KEY=%q\n' "$linear_key"
    } > "$secrets"
    chmod 600 "$secrets" 2>/dev/null || true
    ok "wrote $secrets (gitignored)"
    _ensure_gitignored "$project_root" '.herd/secrets'
  fi

  # Seed a BACKLOG.md if we promised to create one.
  if [ -n "$make_backlog" ] && [ ! -f "$project_root/$backlog_file" ]; then
    cat > "$project_root/$backlog_file" <<EOF
# $workspace — backlog

> Single source of truth for planned work. The coordinator owns this file; the async scribe is
> the only automated writer. 🔜 planned · 🚧 in progress · ✅ shipped.

## Now

## Next

## Recently shipped
EOF
    ok "seeded $backlog_file"
  fi

  # 5b. Seed the per-project healthcheck from the template matching scout's detected lang, so a
  # Go/Rust/Java (or Node) consumer gets a heavy-profile gate in their OWN toolchain rather than the
  # reference stack's Python example. Only when HEALTHCHECK_CMD still points at the default path and no script
  # exists yet — NEVER clobbers a consumer's own healthcheck. python/unknown map to the current
  # healthcheck.project.sh, so Python consumers are unchanged. (external-consumer-audit.md, leaks D,B.)
  if [ "$healthcheck" = ".herd/healthcheck.project.sh" ]; then
    local hc_target="$project_root/.herd/healthcheck.project.sh"
    local hc_tmpl; hc_tmpl="$(_healthcheck_template_for "$lang")"
    if [ ! -e "$hc_target" ] && [ -f "$TEMPLATES_DIR/$hc_tmpl" ]; then
      cp "$TEMPLATES_DIR/$hc_tmpl" "$hc_target"
      chmod +x "$hc_target" 2>/dev/null || true
      ok "seeded .herd/healthcheck.project.sh from $hc_tmpl (lang=${lang:-unknown})"
    fi
  fi

  # 6. Render the coordinator skill.
  local skill; skill="$(render_skill "$project_root" "$cfg")"
  ok "rendered coordinator skill → $skill"

  # 6b. Governance adoption (HERD-119): OPT-IN import of gates/conventions from an OPTIONAL CLAUDE.md /
  #     AGENTS.md. One source among many — suggest-never-auto-write, applied only through the validated
  #     `herd config set` on accept. No such file ⇒ returns silently (byte-identical init). Skipped on a
  #     scripted / non-tty init. Fail-soft: any internal error never aborts init.
  _init_governance_adoption "$project_root" || true

  # 7. Grounding interview (HERD-80): OFFER codemap/CONTEXT_PROVISION, graphify/GRAPHIFY_BIN, MCP wiring
  #    and surface the efficiency levers. Suggest-never-auto-write — applies only on an explicit yes via
  #    the validated `herd config set`. Skipped cleanly on a scripted / non-tty init.
  _init_grounding_interview "$project_root"

  say ""
  ok "herd init complete."
  say "  Next:  cd $project_root && bash $SCRIPTS_DIR/coordinator.sh   # launch the control room"
  say "  Skill: /coordinator (regenerate after an engine bump with: herd upgrade)"
}

# ── herd upgrade migrations ─────────────────────────────────────────────────────────────────────
# When the engine contract version bumps vN→vM, breaking changes to a consumer's .herd/config are
# INHERITED by running ordered migration scripts — one per contract step — so the consumer's custom
# answers are transformed in place rather than clobbered. Migrations live in $HERDKIT_HOME/migrations
# (override with HERD_MIGRATIONS_DIR — the hermetic-test seam) and are named `v<N>-to-v<N+1>.sh`.
#
# MIGRATION CONTRACT — each script is invoked as:  bash migrations/vN-to-vM.sh <project-root>
#   • The runner provides, via the environment:
#       HERD_CONFIG            — absolute path to <project-root>/.herd/config
#       _config_file_value <cfg> <KEY>          — read a key's value ('' when unset)   [exported fn]
#       _config_put_value  <cfg> <KEY> <VALUE>  — idempotent, comment-preserving write  [exported fn]
#     Reuse those helpers — the SAME primitives `herd config` uses — never hand-parse the config.
#   • MUST make TARGETED, IDEMPOTENT edits to .herd/config only (re-running must be a safe no-op):
#     add or rewrite specific keys; NEVER delete or overwrite a consumer's custom keys/answers.
#   • MUST NOT touch DENY_PATHS or .herd/secrets.
#   • Exit 0 on success (including an already-applied no-op); non-zero on an UNRESOLVABLE conflict —
#     the runner then RESTORES the pre-upgrade config and aborts the whole upgrade (rollback-safe),
#     leaving HERD_VERSION un-bumped so a fixed re-run retries the same step.
_migrations_dir() { printf '%s' "${HERD_MIGRATIONS_DIR:-$HERDKIT_HOME/migrations}"; }

# run_migrations <project-root> <cfg> <old-version> <target-version>
# Applies every pending migration from old→target in ascending order, exactly once. A contract step
# with no script is skipped (not every bump needs a config change). old>=target (or a non-numeric
# version) is a clean no-op — preserving today's no-migration upgrade behavior verbatim.
run_migrations() {
  local root="$1" cfg="$2" old="$3" target="$4"
  # Only ever migrate FORWARD, and only across sane integer versions.
  case "$old$target" in *[!0-9]*) return 0 ;; esac
  [ "$old" -lt "$target" ] 2>/dev/null \
    || { say "  ${c_dim}(already at v${target} — no pending migrations)${c_rst}"; return 0; }
  local dir; dir="$(_migrations_dir)"
  [ -d "$dir" ] || { say "  ${c_dim}(no migrations dir at $dir — nothing to migrate)${c_rst}"; return 0; }

  # Discover the pending, PRESENT migration scripts for each contract step in ascending order.
  local pending="" v mig
  for (( v=old; v<target; v++ )); do
    mig="$dir/v$v-to-v$((v+1)).sh"
    [ -f "$mig" ] && pending="${pending:+$pending }$mig"
  done
  if [ -z "$pending" ]; then
    say "  ${c_dim}(no pending migrations for v${old} -> v${target})${c_rst}"
    return 0
  fi

  # Rollback-safe: snapshot the config before any migration runs, restore it if one fails.
  local backup; backup="$(mktemp)"; cp "$cfg" "$backup"
  # Hand every migration the config path + the shared read/write primitives (the front-door helpers).
  export HERD_CONFIG="$cfg"
  export -f _config_file_value _config_put_value

  say "${c_bold}Applying pending migrations (v${old} -> v${target}):${c_rst}"
  local failed="" label
  for mig in $pending; do
    label="$(basename "$mig" .sh)"
    if bash "$mig" "$root"; then
      ok "migration $label applied"
    else
      failed="$label"
      break
    fi
  done

  if [ -n "$failed" ]; then
    cp "$backup" "$cfg"; rm -f "$backup"
    die "migration $failed failed — restored .herd/config and aborted upgrade (HERD_VERSION un-bumped)"
  fi
  rm -f "$backup"
}

cmd_upgrade() {
  local root; root="$(pwd)"
  local cfg="$root/.herd/config"
  [ -f "$cfg" ] || die "no .herd/config at $root — run 'herd init' first"
  # OLD version pinned in the project (BEFORE any bump) and the NEW target this upgrade drives to.
  # HERD_TARGET_VERSION overrides the CLI's shipped contract version (advanced / hermetic-test seam).
  local cur; cur="$(. "$cfg"; printf '%s' "${HERD_VERSION:-0}")"
  local target="${HERD_TARGET_VERSION:-$HERDKIT_CONTRACT_VERSION}"
  if [ "$cur" -gt "$HERDKIT_CONTRACT_VERSION" ] 2>/dev/null; then
    warn "project pinned HERD_VERSION=$cur is NEWER than this CLI's contract ($HERDKIT_CONTRACT_VERSION) — upgrade your herdkit install."
  fi
  # Inherit breaking contract changes: run the ordered, pending migrations vCUR→vTARGET, preserving
  # the consumer's custom answers. A no-op when nothing is pending — today's behavior, unchanged.
  run_migrations "$root" "$cfg" "$cur" "$target"
  # Adopt purely-additive keys the canonical template gained since this project was set up (issue #74).
  # Sequence matters: migrations ran FIRST (they may rename/transform keys), so we only append keys
  # STILL missing afterward — never overwriting or reordering a key the consumer already set, and never
  # touching DENY_PATHS / .herd/secrets. HERD_CONFIG_TEMPLATE overrides the canonical template (test seam).
  local template="${HERD_CONFIG_TEMPLATE:-$TEMPLATES_DIR/config.example}"
  local adopted; adopted="$(_config_adopt_additive "$cfg" "$template")"
  if [ -n "$adopted" ]; then
    local adopted_n; adopted_n="$(printf '%s' "$adopted" | wc -w | tr -d ' ')"
    say "herd upgrade: adopted $adopted_n new config keys: $adopted"
  fi
  # Warn on config keys this contract expects but the project's config is missing (post-migration).
  local expected="HEALTHCHECK_CMD HEALTHCHECK_HEAVY_GLOB SMOKE_CMD SHARE_LINKS REVIEW_CHECKLIST COORDINATOR_CMD WATCHER_AUTOMERGE HERD_REPO"
  local missing="" k
  for k in $expected; do
    grep -qE "^[[:space:]]*$k=" "$cfg" || missing="${missing:+$missing }$k"
  done
  [ -n "$missing" ] && warn "config is missing keys this version uses (defaults apply; add them to .herd/config): $missing"
  # Bump HERD_VERSION to the target (or append if absent).
  if grep -qE '^[[:space:]]*HERD_VERSION=' "$cfg"; then
    local tmp; tmp="$(mktemp)"
    sed -E "s/^([[:space:]]*HERD_VERSION=).*/\1$target/" "$cfg" > "$tmp" && mv "$tmp" "$cfg"
  else
    printf 'HERD_VERSION=%s\n' "$target" >> "$cfg"
  fi
  ok "HERD_VERSION → $target"
  local skill; skill="$(render_skill "$root" "$cfg")"
  ok "re-rendered coordinator skill → $skill"
  # After the re-render, surface engine config keys this project still hasn't assigned so a new knob
  # is visible the moment it arrives (HERD-38). READ-ONLY summary — never writes; `|| true` so a
  # missing-key gate result never aborts the upgrade (also covers `herd update`, which delegates here).
  say ""
  say "${c_bold}herd config sync${c_rst} — engine config keys vs .herd/config:"
  _config_sync_report "$cfg" "$(_config_caps_file)" "$(_config_example_file)" || true
}

cmd_render() {
  local root; root="$(pwd)"
  local cfg="$root/.herd/config"
  [ -f "$cfg" ] || die "no .herd/config at $root — run 'herd init' first"
  local skill; skill="$(render_skill "$root" "$cfg")"
  ok "rendered coordinator skill → $skill"
}

# ── herd governance hooks render: emit SESSION-TIME Claude Code hooks from the governance map (HERD-131)
# Dual-surface enforcement: the governance rules the merge-time watcher gate enforces ALSO bind
# session-time as Claude Code PreToolUse hooks — blocking a violation at the keyboard, early and cheap.
# Consumes EVERY surface==hook row of templates/governance-map.tsv (HERD-119); each rendered hook runs
# scripts/herd/governance-hook.sh <target> against the tool payload. PROPOSE-then-write like every
# governance write: each hook is shown, the operator accepts per-hook, and accepted entries MERGE into
# .claude/settings.local.json (or --shared → .claude/settings.json) preserving ALL existing entries.
# Every generated matcher-group carries a "herd-governance" marker key, so a re-render strips ONLY its
# own prior entries and re-adds the current selection — idempotent, never clobbering user hooks.
# Fail-soft: no map / no hook rows / non-interactive → clean no-op, no file written.
_GOV_HOOK_MARKER="herd-governance"

cmd_governance() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    hooks) _gov_hooks "$@" ;;
    ''|help|-h|--help)
      say "usage: herd governance hooks render [--shared]"
      say "  Render session-time Claude Code hooks from the governance map's hook rows: propose each,"
      say "  accept per-hook, and merge accepted entries into .claude/settings.local.json (default) or"
      say "  .claude/settings.json (--shared), preserving existing entries. Idempotent re-render." ;;
    *) die "unknown: herd governance $sub (try: herd governance hooks render)" ;;
  esac
}

_gov_hooks() {
  local action="${1:-}"; shift || true
  case "$action" in
    render) _gov_hooks_render "$@" ;;
    ''|help|-h|--help) say "usage: herd governance hooks render [--shared]" ;;
    *) die "unknown: herd governance hooks $action (try: herd governance hooks render)" ;;
  esac
}

_gov_hooks_render() {
  local shared="" a
  for a in "$@"; do
    case "$a" in
      --shared) shared=1 ;;
      -*) die "unknown flag: $a (usage: herd governance hooks render [--shared])" ;;
      *)  die "unexpected argument: $a (usage: herd governance hooks render [--shared])" ;;
    esac
  done

  local root map
  root="$(pwd)"
  map="$(_gov_map_file)"
  # Fail-soft: no map → clean no-op (byte-identical for projects that never provisioned one).
  [ -f "$map" ] || { say "  ${c_dim}governance hooks: no map at $map — nothing to render${c_rst}"; return 0; }

  # Collect surface==hook rows as target<TAB>label, in file order. The renderer consumes EVERY hook
  # row (unlike adoption's first-match _gov_match); the pattern column is irrelevant here.
  local rows="" pattern surface target label
  while IFS=$'\t' read -r pattern surface target label; do
    case "$pattern" in ''|'#'*|'pattern') continue ;; esac
    [ "$surface" = "hook" ] || continue
    [ -n "$target" ] || continue
    rows="${rows}${target}"$'\t'"${label}"$'\n'
  done < "$map"

  if [ -z "$rows" ]; then
    say "  ${c_dim}governance hooks: no hook rows in the map — nothing to render${c_rst}"
    return 0
  fi

  # Target settings file: the per-machine local overlay by default; --shared → the committed baseline.
  local relfile settings
  if [ -n "$shared" ]; then relfile=".claude/settings.json"; else relfile=".claude/settings.local.json"; fi
  settings="$root/$relfile"

  # PROPOSE-then-write: writes REQUIRE an interactive operator (never auto-write). Non-interactive →
  # clean no-op so a scripted/CI invocation changes nothing.
  if ! _ground_interactive; then
    say "  ${c_dim}governance hooks: non-interactive — nothing written (run from a terminal to accept per-hook)${c_rst}"
    return 0
  fi

  say ""
  say "${c_bold}Governance hooks${c_rst} ${c_dim}(session-time Claude Code hooks — propose-then-write; merged into ${relfile}, existing entries preserved)${c_rst}"

  local accepted="" np i rec cmd ans
  np="$(printf '%s' "$rows" | grep -c . || true)"
  for (( i=1; i<=np; i++ )); do
    rec="$(printf '%s' "$rows" | sed -n "${i}p")"
    IFS=$'\t' read -r target label <<< "$rec"
    [ -n "$target" ] || continue
    cmd="bash $SCRIPTS_DIR/governance-hook.sh $target"
    say ""
    say "  ${c_bold}${label}${c_rst}"
    say "  ${c_dim}→ PreToolUse[Bash] hook: ${cmd}${c_rst}"
    ans="$(_ground_ask "  accept? (a/N)" "n")"
    case "$(printf '%s' "$ans" | tr '[:upper:]' '[:lower:]')" in
      a|accept|y|yes) accepted="${accepted}${target}"$'\n'; say "  ${c_dim}accepted${c_rst}" ;;
      *) say "  ${c_dim}declined${c_rst}" ;;
    esac
  done

  say ""
  # Write when there is something to add, OR when the file already carries our marker (so declining a
  # previously-accepted hook cleanly removes it). A fresh decline-all never creates a file.
  if [ -n "$accepted" ] || { [ -f "$settings" ] && grep -q "$_GOV_HOOK_MARKER" "$settings" 2>/dev/null; }; then
    _gov_hooks_merge "$settings" "$accepted"
  else
    say "  ${c_dim}governance hooks: nothing accepted — no file written${c_rst}"
  fi
}

# _gov_hooks_merge <settings-file> <accepted-targets-newline> — merge the accepted hook targets into
# the settings JSON, preserving every existing entry. Strips our previously-rendered marker groups
# from every hook event first (idempotent re-render), then re-adds the current selection in a stable
# (sorted) order. A malformed settings file is refused, never clobbered.
_gov_hooks_merge() {
  local settings="$1" accepted="$2"
  command -v python3 >/dev/null 2>&1 || die "governance hooks render requires python3"
  mkdir -p "$(dirname "$settings")" 2>/dev/null || true
  SETTINGS="$settings" MARKER="$_GOV_HOOK_MARKER" HOOKSCRIPT="$SCRIPTS_DIR/governance-hook.sh" \
  ACCEPTED="$accepted" python3 -c '
import json, os, shlex, sys
settings = os.environ["SETTINGS"]
marker   = os.environ["MARKER"]
hookscript = os.environ["HOOKSCRIPT"]
accepted = [t for t in os.environ.get("ACCEPTED", "").splitlines() if t.strip()]
try:
    with open(settings) as f:
        data = json.load(f)
    if not isinstance(data, dict):
        data = {}
except FileNotFoundError:
    data = {}
except Exception:
    sys.stderr.write("governance hooks: %s is not valid JSON — refusing to overwrite\n" % settings)
    sys.exit(1)
hooks = data.get("hooks")
if not isinstance(hooks, dict):
    hooks = {}
# Strip our previously-rendered marker groups from every event (idempotent re-render); drop an event
# that we emptied so re-render stays byte-stable.
for ev in list(hooks.keys()):
    arr = hooks.get(ev)
    if not isinstance(arr, list):
        continue
    kept = [g for g in arr if not (isinstance(g, dict) and marker in g)]
    if kept:
        hooks[ev] = kept
    else:
        del hooks[ev]
for target in sorted(set(accepted)):
    cmd = "bash %s %s" % (shlex.quote(hookscript), shlex.quote(target))
    hooks.setdefault("PreToolUse", []).append({
        "matcher": "Bash",
        marker: target,
        "hooks": [{"type": "command", "command": cmd}],
    })
if hooks:
    data["hooks"] = hooks
elif "hooks" in data:
    del data["hooks"]
with open(settings, "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
' || die "governance hooks: merge into $settings failed"
  local nacc; nacc="$(printf '%s' "$accepted" | grep -c . || true)"
  if [ "$nacc" -gt 0 ]; then
    ok "governance hooks: merged $nacc hook(s) → $settings"
  else
    say "  ${c_dim}governance hooks: removed prior generated entries → $settings${c_rst}"
  fi
}

# ── herd codemap: regenerate docs/codemap.md, a native map of the repo's tree ────────────────────
# Delegates to scripts/herd/codemap.sh, which regenerates the committed, deterministic docs/codemap.md
# — module roles, who-imports/sources-whom, and config-key → consumer wiring — for coordinator/builder
# agents to load as context instead of re-exploring the repo. It auto-detects the tree it is run in
# (HERD-79): in the herdkit ENGINE repo it maps the engine (bin/herd + scripts/herd/*.sh + templates/)
# byte-identically to before; in a CONSUMING project it maps THAT project's own source tree,
# language-aware (node/python/go/rust/java). Idempotent; no .herd/config value is required either way.
# `herd codemap --check` is a read-only staleness probe: it regenerates to a temp file and diffs it
# against the committed map WITHOUT writing it, exiting 0 when fresh / non-zero when stale.
cmd_codemap() { bash "$SCRIPTS_DIR/codemap.sh" "$@"; }

# ── herd symbol-index: regenerate docs/symbol-index.md, the native def→caller index ──────────────
# The function-level companion to `herd codemap`. Delegates to scripts/herd/symbol-index.sh, which
# scans THIS engine repo (bin/herd + scripts/herd/**) and regenerates the committed, deterministic
# docs/symbol-index.md — every shell function's definition site(s) and cross-file call sites — so a
# builder can answer "who calls _backend_update_state" with one lookup and the coordinator can
# sharpen its overlap read to symbol level. Idempotent; maps the engine, needs no .herd/config.
# `herd symbol-index --check` is a read-only staleness probe (0 fresh / non-zero stale), like codemap.
cmd_symbol_index() { bash "$SCRIPTS_DIR/symbol-index.sh" "$@"; }

# ── herd ledger: the coordinator progress ledger read/write surface (HERD-103) ───────────────────
# Durable, cross-session coordinator state (per work-item: slug/worktree/PR, sequencing, planned
# markers) keyed by tracker id, so a coordinator or a second operator RESUMES with an accurate
# picture instead of re-deriving it every session. Coordinator-side only — NOT a watcher gate.
# Delegates to scripts/herd/ledger.sh; state lives in the local (never-committed) worktree pool at
# WORKTREES_DIR/.herd/ledger.jsonl. Default-dormant: with no writes, no file exists and nothing runs.
cmd_ledger() { bash "$SCRIPTS_DIR/ledger.sh" "$@"; }

# ── herd advise: a mid-flight strong-model second opinion for a builder (HERD-101) ───────────────
# A builder on a cheaper tier calls `herd advise "<question>" [context…]` to pull a ONE-SHOT read
# from a strong advisor model (MODEL_ADVISE, default the MODEL_FEATURE/Opus tier) WITHOUT escalating
# its whole lane. The advice is printed to stdout for the builder to read; no agent, no tab, no repo
# mutation. Delegates to scripts/herd/herd-advise.sh, which is ADDITIVE + FAIL-SOFT: an absent
# advisor model or a failed model call degrades to a clear one-line message, never a hard error.
cmd_advise() { bash "$SCRIPTS_DIR/herd-advise.sh" "$@"; }

# ── herd config: view / validate / set .herd/config keys, aware of what each change requires ─────
# `herd config list|get|set` is the safe, validated front door to .herd/config. The known-key set and
# per-key metadata — including the optional 5th "requires" column (watcher | render | blank) — are
# SOURCED from templates/capabilities.tsv (the manifest that already documents every config key), so
# nothing is hardcoded here and validation stays in lockstep with the engine. After a successful
# `set`, the command DOES what the change requires, reusing the existing mechanisms: a
# watcher-affecting key restarts the watcher via `herd reload` (the shared _stop_project_watcher +
# relaunch path keyed on .watcher-<slug>.pid); a coordinator-facing key re-renders the coordinator
# skill via render_skill. It NEVER touches DENY_PATHS or .herd/secrets, and masks secret-shaped
# values in list/get.

# Capabilities manifest path (key set + metadata); HERD_CAPABILITIES_FILE overrides it for tests.
_config_caps_file() { printf '%s' "${HERD_CAPABILITIES_FILE:-$TEMPLATES_DIR/capabilities.tsv}"; }

# _config_key_requires <caps> <KEY> → prints the requires token (watcher | render | '') for the
# matching kind==config row; prints nothing and exits 1 when KEY is NOT a known config key. Exact
# key match, so REVIEW_CONCURRENCY never matches REVIEW_CONCURRENCY_X.
_config_key_requires() {
  awk -F'\t' -v k="$2" '
    $2=="config" && $1==k { r=$5; gsub(/[[:space:]]+$/,"",r); print r; found=1; exit }
    END { exit(found?0:1) }' "$1"
}

# _config_key_scope <caps> <KEY> → print the key's WRITE SCOPE (HERD-47): "machine" for keys that
# hold per-user/per-machine state and therefore DEFAULT to the gitignored .herd/config.local overlay
# (driver binding, model tiers / token budget, operator-posture opt-ins), or "project" for keys that
# belong in the committed .herd/config baseline. Read from the OPTIONAL 6th column of
# capabilities.tsv; a config row without it — or any non-config/unknown key — is "project" (the safe,
# backward-compatible default: writes still land in the shared baseline unless --local is passed).
_config_key_scope() {
  local s
  s="$(awk -F'\t' -v k="$2" '$2=="config" && $1==k { s=$6; gsub(/[[:space:]]+$/,"",s); print s; exit }' "$1")"
  case "$s" in machine) printf 'machine' ;; *) printf 'project' ;; esac
}

# ── herd config sync support (HERD-38) ────────────────────────────────────────────────────────────
# Canonical defaults template (KEY=value / commented-default lines with the real default VALUES that
# capabilities.tsv only documents in prose). HERD_CONFIG_EXAMPLE_FILE overrides it for tests, mirroring
# HERD_CAPABILITIES_FILE — the same file cmd_upgrade already treats as the default source (#74).
_config_example_file() { printf '%s' "${HERD_CONFIG_EXAMPLE_FILE:-$TEMPLATES_DIR/config.example}"; }

# _config_manifest_config_keys <caps> — print, in manifest order, the key name of every kind==config
# row (column 1). This is the AUTHORITATIVE config-key set the engine documents.
_config_manifest_config_keys() {
  awk -F'\t' '$2=="config" { print $1 }' "$1"
}

# _config_when_to_surface <caps> <KEY> — print the when-to-surface guidance (column 4) for KEY's
# kind==config row; empty when KEY is not a config row. First match wins.
_config_when_to_surface() {
  awk -F'\t' -v k="$2" '$2=="config" && $1==k { print $4; exit }' "$1"
}

# _config_example_default <example> <KEY> — print the default VALUE the defaults template documents for
# KEY, read from either an active `KEY=value` line OR a commented `# KEY=value` default line (the form
# config.example uses to document an optional key's default). One layer of surrounding double-quotes is
# stripped and any trailing ` # comment` removed, so a quoted value yields exactly what shell sourcing
# would assign. First match wins (active preferred by file order). EXIT STATUS carries presence: 0 when
# KEY is documented in the template (value may be empty, e.g. SHARE_LINKS=""), 1 when KEY is absent from
# the template altogether (its fallback lives inside the engine scripts, not the defaults template) — so
# the caller can distinguish an empty default from an undocumented one instead of printing a bare "".
_config_example_default() {
  awk -v k="$2" '
    { line=$0; sub(/^[[:space:]]*#?[[:space:]]*/,"",line) }   # tolerate one leading "# " (commented default)
    index(line, k "=")==1 {
      v=substr(line, length(k)+2)
      if (v ~ /^"/) {                       # quoted: the value is everything up to the closing quote
        rest=substr(v,2); q=index(rest,"\"")
        if (q>0) { print substr(rest,1,q-1); found=1; exit }
      }
      sub(/[[:space:]]+#.*/,"",v)           # bareword: drop a trailing inline comment
      sub(/[[:space:]]+$/,"",v)
      print v; found=1; exit
    }
    END { exit(found?0:1) }' "$1"
}

# _config_secret_key <KEY> → success when the key NAME looks credential-shaped, so its value is
# masked in list/get and refused by set (secrets belong in .herd/secrets, never the committed config).
_config_secret_key() {
  case "$1" in
    *SECRET*|*TOKEN*|*PASSWORD*|*PASSWD*|*APIKEY*|*_KEY|*_PAT) return 0 ;;
    *) return 1 ;;
  esac
}

# _config_file_value <cfg> <KEY> → the raw value assigned to KEY in the config file (one layer of
# surrounding double-quotes stripped), or empty when unset. First assignment only; comments ignored.
_config_file_value() {
  awk -v k="$2" '
    { line=$0; sub(/^[[:space:]]+/,"",line) }
    index(line, k "=")==1 {
      v=substr(line, length(k)+2)
      if (v ~ /^".*"$/) v=substr(v,2,length(v)-2)
      print v; exit
    }' "$1"
}

# _config_put_value <cfg> <KEY> <VALUE> — idempotent, targeted in-place write of KEY="VALUE" into the
# config: replaces the FIRST KEY= line (preserving its leading indentation) or appends when absent,
# leaving every other line and comment untouched. This is the SAME edit primitive `herd config set`
# uses; the upgrade migration runner exports it so migration scripts reuse it instead of re-parsing.
_config_put_value() {
  local cfg="$1" key="$2" val="$3"
  local tmp; tmp="$(mktemp)"
  local replaced=0 line indent
  while IFS= read -r line || [ -n "$line" ]; do
    if [ "$replaced" -eq 0 ] && printf '%s' "$line" | grep -qE "^[[:space:]]*$key="; then
      indent="$(printf '%s' "$line" | sed -E 's/^([[:space:]]*).*/\1/')"
      printf '%s%s="%s"\n' "$indent" "$key" "$val" >> "$tmp"
      replaced=1
    else
      printf '%s\n' "$line" >> "$tmp"
    fi
  done < "$cfg"
  [ "$replaced" -eq 1 ] || printf '%s="%s"\n' "$key" "$val" >> "$tmp"
  mv "$tmp" "$cfg"
}

# _config_ensure_local <local_cfg> — create the per-user overlay .herd/config.local with an
# explanatory header if it does not exist yet (HERD-47), so `herd config set --local` (and machine-
# scoped sets) have a file to write into. Idempotent: an existing overlay is left untouched. The
# header mirrors the comment-preserving style of the baseline setter and documents the file's role.
_config_ensure_local() {
  local f="$1"
  [ -f "$f" ] && return 0
  cat > "$f" <<'HDR'
# .herd/config.local — per-user / per-machine overlay for .herd/config (gitignored, HERD-47).
# Sourced AFTER .herd/config by scripts/herd/herd-config.sh, so keys set HERE OVERRIDE the committed
# baseline — the settings.json/settings.local.json convention. Put per-machine state here (driver,
# model tiers, operator-posture opt-ins) so it never diverges the shared project baseline or dirties
# the ff-only `herd update` pull. ZERO-SECRET: credentials live in .herd/secrets, never here.
# Managed by `herd config set --local KEY VALUE`; `herd config list` shows each value's source.
HDR
}

# ── Additive config-key adoption on upgrade (issue #74) ───────────────────────────────────────────
# When an engine update adds new keys to the canonical templates/config.example, a consumer's older
# .herd/config is MISSING them and silently rides the fallback in herd-config.sh — the operator never
# sees or tunes the new knob. `herd upgrade` closes that drift: after migrations run, it appends any
# purely-additive missing key (default value + explanatory comment, verbatim from the template),
# without overwriting, reordering, or touching anything the consumer already set. These three helpers
# parse the TEMPLATE only (never re-parse the consumer config beyond a presence grep), reusing the
# same key-line shape the rest of this file recognizes.

# _config_template_keys <template> — print, in file order, every config KEY the template assigns
# (leading indentation ignored; comment lines skipped). Exact key names, no values.
_config_template_keys() {
  awk '
    { l=$0; sub(/^[[:space:]]+/,"",l) }
    l ~ /^[A-Za-z_][A-Za-z0-9_]*=/ { key=l; sub(/=.*/,"",key); print key }' "$1"
}

# _config_template_block <template> <KEY> — emit, verbatim, the template's adoption text for KEY: the
# KEY= line PLUS the contiguous comment block directly above it (walking up until a blank line or
# another key line). That block carries the explanatory comment for KEY; when several keys share a
# section header (e.g. the model map), only the FIRST key under the header collects it — the rest have
# a key line directly above, so they carry just their own inline comment. Exits 1 when KEY is absent.
_config_template_block() {
  awk -v k="$2" '
    { lines[NR]=$0 }
    END {
      target=0
      for (i=1;i<=NR;i++){ l=lines[i]; sub(/^[[:space:]]+/,"",l); if (index(l,k "=")==1){ target=i; break } }
      if (!target) exit 1
      start=target
      for (j=target-1;j>=1;j--){ c=lines[j]; sub(/^[[:space:]]+/,"",c); if (c ~ /^#/) start=j; else break }
      for (i=start;i<=target;i++) print lines[i]
    }' "$1"
}

# _config_adopt_additive <cfg> <template> — the #74 core. Append to <cfg> every key the <template>
# declares that <cfg> is MISSING, using the template's default + comment block verbatim. Purely
# additive: an existing key (any value, any custom edit) is left byte-for-byte untouched, nothing is
# reordered or overwritten. NEVER adopts DENY_PATHS (path-scoping) or any secret-shaped key
# (_config_secret_key) — credentials belong in .herd/secrets, never steered into the committed config.
# Prints the space-separated names of adopted keys to stdout ('' when none). Idempotent: a second run
# finds every key already present and adopts nothing, leaving the file unchanged.
_config_adopt_additive() {
  local cfg="$1" template="$2"
  [ -f "$template" ] || return 0
  # First pass — decide the additive-and-missing keys WITHOUT mutating the file, so a no-adopt run
  # leaves .herd/config byte-identical (idempotency).
  local pending="" key
  while IFS= read -r key; do
    [ -n "$key" ] || continue
    grep -qE "^[[:space:]]*$key=" "$cfg" && continue     # consumer already has it → preserve verbatim
    [ "$key" = "DENY_PATHS" ] && continue                # path-scoping key — never auto-adopt
    _config_secret_key "$key" && continue                # secret-shaped — belongs in .herd/secrets
    pending="${pending:+$pending }$key"
  done < <(_config_template_keys "$template")
  [ -n "$pending" ] || return 0
  # Ensure the config ends with a newline so the first appended block starts on its own line (a
  # config whose last line lacks a trailing newline would otherwise get the block glued onto it).
  [ -n "$(tail -c1 "$cfg" 2>/dev/null)" ] && printf '\n' >> "$cfg"
  local adopted=""
  for key in $pending; do
    _config_template_block "$template" "$key" >> "$cfg" && adopted="${adopted:+$adopted }$key"
  done
  printf '%s' "$adopted"
}

cmd_config() {
  local sub="${1:-}"; [ "$#" -gt 0 ] && shift
  case "$sub" in
    list)         cmd_config_list "$@" ;;
    get)          cmd_config_get "$@" ;;
    set)          cmd_config_set "$@" ;;
    sync)         cmd_config_sync "$@" ;;
    lint)         _config_lint "$@" ;;
    ""|-h|--help) say "usage: herd config list | get <KEY> | set [--local|--shared] [--reason <why>] <KEY> <VALUE> | sync | lint" ;;
    *)            die "unknown 'herd config' subcommand '$sub' — usage: herd config list | get <KEY> | set [--local|--shared] [--reason <why>] <KEY> <VALUE> | sync | lint" ;;
  esac
}

# _config_lint — surface DUPLICATE keys in .herd/config (issue #115), the handler behind
# `herd config lint`. The config is shell-sourced, so a key assigned twice silently LAST-WINS and can
# disable a gate; this lists every duplicated key and exits NON-ZERO when any exist (a scriptable
# gate), while a clean config is silent and exits 0. It does NOT edit the file — value resolution
# (shell last-wins) is unchanged; this only surfaces it. (Named `_config_*` like the other private
# config helpers, not `cmd_config_*`: it is a subcommand handler, not a new top-level command.)
_config_lint() {
  local root cfg; root="$(pwd)"; cfg="$root/.herd/config"
  [ -f "$cfg" ] || die "no .herd/config at $root — run 'herd init' first"
  # The scanner lives in herd-config.sh. Pre-set the once-per-process marker so sourcing the loader
  # does not ALSO emit its passive dup warning — this command is the authoritative report.
  _HERD_CONFIG_DUP_WARNED=1
  # shellcheck source=/dev/null
  . "$SCRIPTS_DIR/herd-config.sh"
  local dupes; dupes="$(_herd_config_dup_keys "$cfg")"
  if [ -z "$dupes" ]; then
    ok "no duplicate keys in .herd/config ($cfg)"
    return 0
  fi
  say "${c_bold}duplicate key(s) in .herd/config${c_rst}  ($cfg)"
  local k
  while IFS= read -r k; do
    [ -n "$k" ] && printf '  %s%s%s — assigned more than once; shell last-wins (the LAST assignment silently overrides the earlier one)\n' "$c_bold" "$k" "$c_rst"
  done <<< "$dupes"
  say ""
  warn "shell last-wins can SILENTLY disable a gate (issue #115) — delete the stale duplicate line(s) in $cfg (value resolution is unchanged; herd does not auto-dedup)."
  exit 1
}

cmd_config_list() {
  local root cfg local_cfg; root="$(pwd)"; cfg="$root/.herd/config"; local_cfg="$root/.herd/config.local"
  [ -f "$cfg" ] || die "no .herd/config at $root — run 'herd init' first"
  # HERD-47: show each EFFECTIVE value AND its provenance — baseline (.herd/config) vs the per-user
  # overlay (.herd/config.local, which wins). A key set in both shows the overriding local value
  # tagged [local]; a key only in the overlay is tagged [local-only]; everything else is [baseline].
  if [ -f "$local_cfg" ]; then
    say "${c_bold}.herd/config${c_rst}  ($cfg)  ${c_dim}+ .herd/config.local overlay${c_rst}"
  else
    say "${c_bold}.herd/config${c_rst}  ($cfg)"
  fi
  # HERD-47 regression fix (Windows hang): resolve every key's effective value AND provenance in a
  # SINGLE awk pass instead of the old per-key loop. That loop forked ~5 short-lived subprocesses per
  # key (a `printf|grep`, a `sed`, an overlay `grep`, an awk `_config_file_value` in `$(...)`, and
  # `_config_secret_key`) — ~300 processes over 65 keys, enough to deadlock Git-bash on Windows under
  # the fork load, so `herd config list` printed ~10 keys then HUNG. awk reads .herd/config once (and
  # .herd/config.local once, when present) and emits byte-identical rows: baseline keys in file order
  # (a key also assigned in the overlay shows the OVERRIDING local value tagged [local]), then
  # overlay-only keys tagged [local-only]. Value parsing mirrors _config_file_value (first assignment,
  # one layer of surrounding double-quotes stripped) and masking mirrors _config_secret_key.
  local prog='
    function stripws(s) { sub(/^[[:space:]]+/, "", s); return s }
    function keyof(s,   k) {
      s = stripws(s)
      if (s !~ /^[A-Za-z_][A-Za-z0-9_]*=/) return ""
      k = s; sub(/=.*/, "", k); return k
    }
    function valof(s, k,   v) {
      s = stripws(s); v = substr(s, length(k) + 2)
      if (v ~ /^".*"$/) v = substr(v, 2, length(v) - 2)
      return v
    }
    function is_secret(k) {
      return (k ~ /SECRET/ || k ~ /TOKEN/ || k ~ /PASSWORD/ || k ~ /PASSWD/ || k ~ /APIKEY/ || k ~ /_KEY$/ || k ~ /_PAT$/)
    }
    # Overlay is passed FIRST (ARGV order): record each key it assigns, first assignment only.
    FILENAME == localfile {
      k = keyof($0)
      if (k != "" && !(k in localval)) { localval[k] = valof($0, k); lorder[++ln] = k }
      next
    }
    # Baseline: one row per key line, in file order; overridden keys show the local value tagged [local].
    {
      k = keyof($0)
      if (k == "") next
      if (!(k in basefirst)) basefirst[k] = valof($0, k)
      baseseen[k] = 1
      if (k in localval) { v = localval[k]; src = "local" } else { v = basefirst[k]; src = "baseline" }
      if (is_secret(k)) v = "********"
      printf "  %-24s %-28s %s[%s]%s\n", k, v, dim, src, rst
    }
    # Keys present ONLY in the overlay (never assigned in the baseline), in overlay file order.
    END {
      for (i = 1; i <= ln; i++) {
        k = lorder[i]
        if (k in baseseen) continue
        v = localval[k]
        if (is_secret(k)) v = "********"
        printf "  %-24s %-28s %s[local-only]%s\n", k, v, dim, rst
      }
    }'
  if [ -f "$local_cfg" ]; then
    awk -v dim="$c_dim" -v rst="$c_rst" -v localfile="$local_cfg" "$prog" "$local_cfg" "$cfg"
  else
    awk -v dim="$c_dim" -v rst="$c_rst" -v localfile="" "$prog" "$cfg"
  fi
}

cmd_config_get() {
  local key="${1:-}"
  [ -n "$key" ] || die "usage: herd config get <KEY>"
  local root cfg; root="$(pwd)"; cfg="$root/.herd/config"
  [ -f "$cfg" ] || die "no .herd/config at $root — run 'herd init' first"
  local caps; caps="$(_config_caps_file)"
  _config_key_requires "$caps" "$key" >/dev/null \
    || die "unknown config key '$key' — see 'herd config list' (valid keys come from capabilities.tsv)"
  local val; val="$(_config_file_value "$cfg" "$key")"
  { _config_secret_key "$key" && [ -n "$val" ]; } && val='********'
  printf '%s\n' "$val"
}

cmd_config_set() {
  # Optional leading flags, parsed before the positional KEY/VALUE:
  #   --local  (HERD-47) force the write into the per-user overlay .herd/config.local (gitignored),
  #            never the committed baseline.
  #   --shared (HERD-62) apply a PROJECT-scoped change to the committed baseline .herd/config AND
  #            open a tiny single-file PR (branch config/<key>) proposing it to every operator, so a
  #            coordinator who cannot push to the default branch still propagates policy the normal
  #            gated way. Refused for machine-scoped keys (they must never be committed) and mutually
  #            exclusive with --local.
  #   --reason <why>  free-text rationale carried into the --shared PR body (ignored otherwise).
  local force_local=0 force_shared=0 reason=""
  while [ "$#" -gt 0 ]; do
    case "${1:-}" in
      --local)  force_local=1; shift ;;
      --shared) force_shared=1; shift ;;
      --reason) reason="${2:-}"; shift; [ "$#" -gt 0 ] && shift || true ;;
      --)       shift; break ;;
      -?*)      die "unknown flag '$1' — usage: herd config set [--local|--shared] [--reason <why>] <KEY> <VALUE>" ;;
      *)        break ;;
    esac
  done
  { [ "$force_local" -eq 1 ] && [ "$force_shared" -eq 1 ]; } \
    && die "--local and --shared are mutually exclusive: --local keeps a per-user override OUT of git; --shared proposes a committed baseline change to every operator"
  local key="${1:-}" val="${2:-}"
  { [ -n "$key" ] && [ "$#" -ge 2 ]; } || die "usage: herd config set [--local|--shared] [--reason <why>] <KEY> <VALUE>"
  local root cfg local_cfg; root="$(pwd)"; cfg="$root/.herd/config"; local_cfg="$root/.herd/config.local"
  [ -f "$cfg" ] || die "no .herd/config at $root — run 'herd init' first"
  local caps; caps="$(_config_caps_file)"

  # .herd/config is SOURCED AS SHELL (herd-config.sh and render_skill both `. "$cfg"`), but
  # `herd config get`/`list` read it back with awk (no shell). To keep get == the shell-sourced
  # value AND to guarantee a stored value can NEVER be expanded or executed at source time, reject
  # any value containing a shell-active character ($ ` \ ") or a newline — otherwise e.g.
  # `set WORKSPACE_NAME 'a$(id)'` would be echoed literally by `get` yet run `id` on every source.
  # Such values are rare in config (e.g. a regex '$' anchor); set them by editing .herd/config.
  case "$val" in
    *'$'*|*'`'*|*'\'*|*'"'*)
      die "value contains a shell-active character (\$, \`, \\, or \") — .herd/config is sourced as shell, so it would be expanded/executed at source time and would diverge from what 'herd config get' reports; edit .herd/config directly for such a value" ;;
  esac
  case "$val" in *$'\n'*) die "value may not contain a newline" ;; esac

  # 1. Safety FIRST (independent of the manifest): never touch the path-scoping key or any
  #    secret-shaped key via this command — DENY_PATHS scopes secrets away from git, and
  #    credentials belong in .herd/secrets (gitignored), never the committed config.
  [ "$key" = "DENY_PATHS" ] \
    && die "refusing to set DENY_PATHS via 'herd config' — it scopes secrets away from git; edit .herd/config directly and review carefully"
  _config_secret_key "$key" \
    && die "refusing to write secret-shaped key '$key' into the committed .herd/config — credentials belong in .herd/secrets (gitignored)"

  # 2. Validate against the manifest; capture what the change requires (watcher | render | '').
  local requires
  requires="$(_config_key_requires "$caps" "$key")" \
    || die "unknown config key '$key' — see 'herd config list' (valid keys come from capabilities.tsv)"

  # 2b. Decide the TARGET file (HERD-47). A write lands in the per-user overlay .herd/config.local
  #     when EITHER --local was passed OR the key is machine-scoped in the manifest (scope=machine:
  #     driver, model tiers, operator-posture opt-ins — per-user state that must not diverge the
  #     shared baseline). Otherwise it lands in the committed baseline .herd/config. The overlay is
  #     created on demand (with its documenting header) only when it is actually the target.
  local scope target target_label
  scope="$(_config_key_scope "$caps" "$key")"
  # HERD-62: --shared forces the committed baseline AND a propagation PR — so it is meaningless (and
  #          dangerous) for a machine-scoped key, whose per-user value must never be committed. Refuse
  #          rather than silently downgrade, so the operator picks --local for such a key instead.
  if [ "$force_shared" -eq 1 ] && [ "$scope" = "machine" ]; then
    die "refusing to --shared machine-scoped key '$key' — its value is per-user/per-machine and must never be committed to the baseline; use 'herd config set --local $key ...' instead"
  fi
  if [ "$force_local" -eq 1 ] || { [ "$scope" = "machine" ] && [ "$force_shared" -eq 0 ]; }; then
    _config_ensure_local "$local_cfg"
    target="$local_cfg"; target_label=".herd/config.local"
  else
    target="$cfg"; target_label=".herd/config"
  fi

  # 3. Idempotent targeted edit against the TARGET file: replace the first KEY= line in place
  #    (preserving leading whitespace and every other line/comment) or append when absent. A no-op
  #    set skips the write AND the restart/re-render, so re-running the same set is inert. The
  #    idempotency probe reads the TARGET, so a machine key already at VALUE in the overlay is a
  #    no-op even when the baseline holds a different value (the overlay is what wins at load time).
  #    EXCEPTION (HERD-62): a --shared set never short-circuits, so it can (re)open the propagation
  #    PR even when the local baseline already holds VALUE — the whole point of --shared is that OTHER
  #    operators may not have it yet.
  local cur changed=1; cur="$(_config_file_value "$target" "$key")"
  if [ "$cur" = "$val" ] && grep -qE "^[[:space:]]*$key=" "$target"; then
    changed=0
  fi
  if [ "$changed" -eq 0 ] && [ "$force_shared" -eq 0 ]; then
    ok "$key already = \"$val\" in $target_label (no change)"
    return 0
  fi
  if [ "$changed" -eq 1 ]; then
    _config_put_value "$target" "$key" "$val"
    ok "set $key = \"$val\" in $target_label"
    [ "$target" = "$local_cfg" ] && say "  ${c_dim}(per-user overlay — overrides the baseline .herd/config; gitignored)${c_rst}"
  else
    ok "$key already = \"$val\" in $target_label (local change already applied)"
  fi

  # 4. Change-awareness: do exactly what the change requires, reusing the shared mechanisms. Skipped
  #    on a no-local-change --shared run (nothing changed locally to re-apply — only the PR is opened).
  #    HERD_INIT_DEFER_APPLY (set only by `herd init`'s governance adoption, HERD-119) suppresses the
  #    watcher-restart / re-render: init runs BEFORE the control room exists, so the value is written
  #    and simply takes effect on first launch — no watcher to restart, no premature headless spawn.
  if [ "$changed" -eq 1 ] && [ "${HERD_INIT_DEFER_APPLY:-}" = "1" ]; then
    say "  ${c_dim}(init: watcher restart / skill re-render deferred — takes effect when the control room launches)${c_rst}"
  elif [ "$changed" -eq 1 ]; then
  case "$requires" in
    watcher)
      say ""
      say "${c_bold}→ $key is watcher-affecting — restarting the watcher (herd reload)${c_rst}"
      cmd_reload
      ok "applied: watcher restarted + coordinator skill re-rendered (via herd reload)"
      ;;
    render)
      local skill; skill="$(render_skill "$root" "$cfg")"
      ok "applied: re-rendered coordinator skill → $skill"
      ;;
    *)
      say "  ${c_dim}(no watcher restart or skill re-render required for $key)${c_rst}"
      ;;
  esac
  fi

  # 4b. HERD-62 propagation: open (or refresh) the single-file config PR so every operator receives
  #     this baseline change through the normal watcher gate + `git pull`/`herd update` sync loop.
  if [ "$force_shared" -eq 1 ]; then
    _config_open_shared_pr "$root" "$cfg" "$key" "$cur" "$val" "$reason"
  fi

  # 5. SCRIBE_BACKEND change-awareness (issue #139): flipping the backend does NOT retire an already
  #    running backlog scribe drainer. That idle/done drainer was spawned under the OLD backend and,
  #    if left running, will drain queued requests via the stale mode. scribe-step.sh now guards
  #    against filing junk, but a stale drainer still can't place file-backend items — so warn the
  #    operator to retire it now, so the next request spawns a fresh drainer on the new backend.
  if [ "$key" = "SCRIBE_BACKEND" ] && [ "$changed" -eq 1 ]; then
    say ""
    warn "SCRIBE_BACKEND changed ${cur:+from \"$cur\" }to \"$val\" — an idle backlog scribe drainer spawned under the OLD backend may still be running and would drain queued requests in the stale mode. RETIRE it now (close its 'scribe-<workspace>' tab, e.g. 'herdr agent stop scribe-<workspace>') so the next request spawns a fresh drainer on the new backend."
  fi
}

# _config_open_shared_pr <root> <cfg> <key> <old> <new> <reason> — HERD-62. Open (or refresh) a tiny
# single-file PR that carries the just-applied PROJECT-scoped baseline change to every operator via
# the normal watcher gate. The local baseline (.herd/config) is ALREADY edited by the caller; this
# only proposes the SAME one-key change on a dedicated branch so a coordinator who cannot push to the
# default branch still propagates policy the gated way. It works from a THROWAWAY git worktree so the
# operator's current checkout/branch is never switched or dirtied, bases the branch off the committed
# DEFAULT_BRANCH tip (so the diff is exactly old->new for this one key), pushes branch config/<key>,
# and runs `gh pr create`. DEGRADES GRACEFULLY: a missing gh, an unpushable/non-GitHub remote, or any
# git/gh failure warns with copy-paste manual steps instead of dying — the local change already stuck.
_config_open_shared_pr() {
  local root="$1" cfg="$2" key="$3" old="$4" new="$5" reason="$6"
  local branch="config/$key"

  # Resolve the default branch's remote + base from the committed baseline (no shell-sourcing side
  # effects): DEFAULT_BRANCH=origin/main → remote 'origin', base 'main'. Fall back to origin/main.
  local default_branch remote base
  default_branch="$(_config_file_value "$cfg" DEFAULT_BRANCH)"; : "${default_branch:=origin/main}"
  remote="${default_branch%%/*}"; base="${default_branch#*/}"
  { [ -n "$remote" ] && [ "$remote" != "$default_branch" ]; } || { remote="origin"; base="${default_branch#origin/}"; }
  [ -n "$base" ] || base="main"

  say ""
  say "${c_bold}→ --shared: opening a config PR so every operator receives $key=$new${c_rst}"

  # gh is needed to actually open the PR. Its absence is a valid, non-fatal finding — the change is
  # applied locally; tell the operator how to finish by hand. The repo slug (best-effort, for gh's
  # --repo) is derived from the default-branch remote; when it cannot be resolved (non-GitHub URL)
  # gh is instead run FROM the worktree so it can infer the repo from that checkout's origin remote.
  local slug; slug="$(_gh_repo_slug "$root" "$default_branch")"
  if ! command -v gh >/dev/null 2>&1; then
    warn "cannot auto-open the config PR — gh CLI not found. The change is APPLIED to .herd/config locally; commit it on a branch and open the PR by hand so other operators receive it:
    git switch -c $branch && git commit -am 'config: set $key=$new' && git push -u $remote $branch && gh pr create --base $base"
    return 0
  fi

  # Base the throwaway worktree off the committed default-branch tip when it resolves, else the local
  # HEAD — so the branch diff is a clean single-key change against what everyone else has.
  local base_ref="$default_branch"
  git -C "$root" rev-parse --verify --quiet "$default_branch^{commit}" >/dev/null 2>&1 || base_ref="HEAD"

  # HERD-74: the config PR's worktree must PERSIST under WORKTREES_DIR so the STANDARD watcher gate
  # adopts it. agent-watch.sh discovers work via `git worktree list` (NOT open PRs), so a config/<key>
  # branch with no worktree is invisible and sits ungated forever (observed: PRs #190/#191 required
  # hand-merging). Creating the worktree in the worktree pool and LEAVING it for the watcher lets the
  # existing discovery → healthcheck+review gate → merge → reap machinery drive it exactly like a
  # feature worktree — no bespoke PR-discovery path, and reap-on-merge (do_merge) reuses the same
  # `git worktree remove`. It is only removed here on a DEGRADE path (no PR opened → nothing to gate).
  # Resolve WORKTREES_DIR the way the watcher does (a subshell-source expands $HOME etc. in the value),
  # falling back to the herd-config.sh default of "<PROJECT_ROOT>-trees".
  local wt_dir; wt_dir="$( ( . "$cfg" 2>/dev/null; printf '%s' "${WORKTREES_DIR:-}" ) )"
  if [ -z "$wt_dir" ]; then
    local proj_root; proj_root="$( ( . "$cfg" 2>/dev/null; printf '%s' "${PROJECT_ROOT:-}" ) )"
    wt_dir="${proj_root:-$root}-trees"
  fi
  mkdir -p "$wt_dir" 2>/dev/null || true
  local wt="$wt_dir/config-$key"
  # Idempotent re-run: a prior `set --shared` for this key left its worktree here (checked out on
  # $branch). Drop any prior worktree/registration for it before re-adding, else `worktree add -B`
  # fails on the existing dir / already-checked-out branch. Safe — it is throwaway and the branch ref
  # survives on origin (the refreshed branch is force-pushed below). Unconditional: a no-op when absent.
  git -C "$root" worktree remove --force "$wt" >/dev/null 2>&1 || true
  rm -rf "$wt" 2>/dev/null || true
  git -C "$root" worktree prune >/dev/null 2>&1 || true
  # -B (re)creates or resets the branch to base_ref, so re-running `set --shared` for the same key
  # refreshes the SAME PR branch with the newest value instead of failing on an existing branch.
  if ! git -C "$root" worktree add -q -B "$branch" "$wt" "$base_ref" 2>/dev/null; then
    git -C "$root" worktree remove --force "$wt" >/dev/null 2>&1 || true
    rm -rf "$wt" 2>/dev/null || true
    warn "could not create a work branch for the config PR (git worktree add -B $branch failed) — the change is applied locally; open the PR by hand (branch $branch off $base)."
    return 0
  fi

  # Apply the SAME one-key edit in the worktree's baseline copy (the committed, pre-change value), so
  # the branch carries exactly old->new for this key and nothing else. Reuse the shared edit primitive.
  local push_ok=0 keep_wt=0
  if [ -f "$wt/.herd/config" ]; then
    _config_put_value "$wt/.herd/config" "$key" "$new"
    if ! git -C "$wt" diff --quiet -- .herd/config; then
      git -C "$wt" add .herd/config
      git -C "$wt" commit -q -m "config: set $key=$new (herd config set --shared)" \
        -m "Propagate a PROJECT-scoped policy change to every operator (HERD-62)." 2>/dev/null || true
      # --force: the config/<key> branch is owned entirely by this command (one branch per key), so a
      # re-run legitimately replaces its own prior proposal; -B reset above makes the history diverge.
      if git -C "$wt" push -q --force "$remote" "$branch" 2>/dev/null; then
        push_ok=1
      fi
    else
      # Baseline tip already carries this value — nothing to propose (already merged upstream).
      ok "the default branch already has $key=$new — no config PR needed"
      git -C "$root" worktree remove --force "$wt" >/dev/null 2>&1 || true
      rm -rf "$wt"
      return 0
    fi
  else
    warn ".herd/config is not committed on $base — cannot build a single-file config PR; commit the baseline first."
  fi

  if [ "$push_ok" -eq 1 ]; then
    local title body reason_line
    title="config: set $key=$new"
    [ -n "$reason" ] && reason_line="**Why:** $reason" || reason_line="**Why:** _(none given — pass \`--reason\` to record one)_"
    body="Shared config change opened by \`herd config set --shared\` (HERD-62).

**Key:** \`$key\`
**Change:** \`${old:-<unset>}\` → \`$new\`
$reason_line

Applies a PROJECT-scoped policy change to the committed \`.herd/config\` baseline so every operator
picks it up on the next \`git pull\` + \`herd update\`. Single-file diff; the normal watcher gate
(healthcheck + review) merges it."
    # Run gh FROM the worktree so it can infer the repo from that checkout's origin remote; pass
    # --repo too when a slug resolved (belt-and-suspenders, and lets a non-default remote name work).
    # No bash arrays here — an empty-array expansion under `set -u` aborts on bash 3.2 (macOS).
    local created=0 exists=0
    if [ -n "$slug" ]; then
      ( cd "$wt" && gh pr create --repo "$slug" --base "$base" --head "$branch" --title "$title" --body "$body" ) >/dev/null 2>&1 && created=1
    else
      ( cd "$wt" && gh pr create --base "$base" --head "$branch" --title "$title" --body "$body" ) >/dev/null 2>&1 && created=1
    fi
    if [ "$created" -eq 1 ]; then
      keep_wt=1
      ok "opened config PR for $branch → merges the change to every operator (watcher-gated)"
    else
      # A PR for this branch may already be open (re-run) — the force push above updated its diff.
      if [ -n "$slug" ]; then
        ( cd "$wt" && gh pr view "$branch" --repo "$slug" ) >/dev/null 2>&1 && exists=1
      else
        ( cd "$wt" && gh pr view "$branch" ) >/dev/null 2>&1 && exists=1
      fi
      if [ "$exists" -eq 1 ]; then
        keep_wt=1
        ok "refreshed the existing config PR for $branch with $key=$new"
      else
        warn "pushed branch $branch but 'gh pr create' failed — open the PR manually: gh pr create ${slug:+--repo $slug }--base $base --head $branch"
      fi
    fi
  elif [ -f "$wt/.herd/config" ]; then
    warn "could not push $branch to $remote (permission or network) — the change is applied locally; push $branch and open the PR by hand."
  fi

  # HERD-74: a PR is open → LEAVE the worktree in the pool for the watcher to adopt (discover → gate →
  # merge → reap). Otherwise (any degrade path: no PR opened) remove it so no orphan worktree lingers.
  if [ "$keep_wt" -eq 1 ]; then
    # Best-effort handoff marker so the adoption is auditable in the engine journal (fail-soft: a
    # missing WORKTREES_DIR just drops the event). The watcher journals the eventual merge + reap.
    { type journal_append >/dev/null 2>&1 && WORKTREES_DIR="$wt_dir" journal_append config_pr_adopt \
        slug "config-$key" branch "$branch" key "$key" reason left_for_watcher_gate; } >/dev/null 2>&1 || true
    say "  ${c_dim}(worktree left in the pool → the watcher gates + merges + reaps it like a feature)${c_rst}"
  else
    git -C "$root" worktree remove --force "$wt" >/dev/null 2>&1 || true
    rm -rf "$wt" 2>/dev/null || true
    git -C "$root" worktree prune >/dev/null 2>&1 || true
  fi
  return 0
}

# ── herd config sync: surface engine config keys missing from this project's .herd/config (HERD-38) ─
# After an engine update the manifest (capabilities.tsv) may document config keys this project's
# .herd/config never assigned — the project silently rides the built-in fallback and the operator never
# sees the new knob. `herd config sync` closes that visibility gap WITHOUT writing: it diffs the
# manifest's kind==config key set against the keys actually assigned in .herd/config and reports each
# MISSING key with its default value (from templates/config.example, the canonical defaults template)
# and its when-to-surface guidance (manifest column 4). STRICTLY READ-ONLY — it reads three template/
# config files and writes NONE; a value is only ever applied by the operator via the validated
# `herd config set`. Exit non-zero when any key is missing (a scriptable gate), 0 and quiet when in sync.

# _config_sync_report <cfg> <caps> <example> — the read-only core, shared by `herd config sync` and the
# post-render summary in `herd upgrade`/`herd update`. Prints the missing-key report and RETURNS 1 when
# any manifest config key is unassigned, 0 (one quiet ok line) when in sync. NEVER calls exit, so the
# upgrade path can print the summary without aborting.
_config_sync_report() {
  local cfg="$1" caps="$2" example="$3"
  # Keys the operator has actually assigned in .herd/config (active KEY= lines; comments skipped) —
  # reuse the same assigned-key parser the upgrade adoption path uses, so "assigned" means the same
  # thing everywhere.
  local assigned; assigned="$(_config_template_keys "$cfg")"
  # Walk the manifest's config keys in manifest order; collect the ones not assigned.
  local missing="" key
  while IFS= read -r key; do
    [ -n "$key" ] || continue
    grep -qxF "$key" <<<"$assigned" && continue
    missing="${missing:+$missing }$key"
  done < <(_config_manifest_config_keys "$caps")

  if [ -z "$missing" ]; then
    ok "config in sync — every engine config key is assigned in .herd/config ($cfg)"
    return 0
  fi

  local n; n="$(printf '%s\n' $missing | grep -c .)"
  say "${c_bold}$n engine config key(s) documented by the manifest but MISSING from .herd/config${c_rst}  ($cfg)"
  say "${c_dim}each rides its built-in default; apply the ones this project cares about with 'herd config set <KEY> <VALUE>' — this command never writes:${c_rst}"
  say ""
  # No secret-masking here: the default VALUES come from the defaults template, which is ZERO-SECRET by
  # contract (credentials live only in .herd/secrets). Masking on the name heuristic would only false-
  # positive legitimate keys whose name contains a secret-shaped substring (e.g. TOKEN_MODE → "TOKEN").
  local def whn
  for key in $missing; do
    if def="$(_config_example_default "$example" "$key")"; then
      printf '  %s%-26s%s default="%s"\n' "$c_bold" "$key" "$c_rst" "$def"
    else
      # Not in the defaults template — an advanced knob whose fallback lives in the engine scripts.
      printf '  %s%-26s%s default=%s(engine built-in)%s\n' "$c_bold" "$key" "$c_rst" "$c_dim" "$c_rst"
    fi
    whn="$(_config_when_to_surface "$caps" "$key")"
    [ -n "$whn" ] && printf '    %s↳ %s%s\n' "$c_dim" "$whn" "$c_rst"
  done
  return 1
}

cmd_config_sync() {
  local root cfg; root="$(pwd)"; cfg="$root/.herd/config"
  [ -f "$cfg" ] || die "no .herd/config at $root — run 'herd init' first"
  # Return status IS the process exit status (missing → non-zero gate), by tail position under set -e.
  _config_sync_report "$cfg" "$(_config_caps_file)" "$(_config_example_file)"
}

# cmd_doctor — run the one-pass dependency doctor (scripts/herd/herd-preflight.sh). Exposed so a
# user with a broken/weird setup can self-diagnose anytime; also the gate cmd_init runs before it
# writes any config, and install.sh runs (advisory) at install time. Exits non-zero when a HARD dep
# is missing/broken so `herd doctor` is scriptable in CI.
cmd_doctor() {
  # Source the config loader too: herd_doctor's config-dup check (issue #115) uses its scanner
  # (_herd_config_dup_keys). Pre-set the once-per-process marker so the loader's PASSIVE dup warning
  # stays silent here — the doctor reports duplicates itself in its own Config section.
  _HERD_CONFIG_DUP_WARNED=1
  # shellcheck source=/dev/null
  . "$SCRIPTS_DIR/herd-config.sh"
  # shellcheck source=/dev/null
  . "$SCRIPTS_DIR/herd-preflight.sh"
  herd_doctor || exit 1
}

cmd_status() {
  # ONE-SHOT, READ-ONLY control-room health snapshot for THIS project — human- and cron-friendly,
  # DETERMINISTIC, no LLM, no mutation. Prints: (a) watcher alive? (b) in-flight builders +
  # DEAD detection, (c) open PRs + gate state, (d) backlog counts. Exits NON-ZERO when something
  # needs attention (a DEAD builder, a CONFLICTING PR, or a review-blocked PR); 0 when healthy.
  # All the work lives in scripts/herd/status.sh (sourced at startup); this just loads config and
  # runs it, mirroring cmd_backlog's loader so `herd status` binds to THIS repo's project.
  local root; root="$(pwd)"
  local cfg="$root/.herd/config"
  [ -f "$cfg" ] || die "no .herd/config at $root — run 'herd init' first"
  export HERD_CONFIG_FILE="$cfg"
  # shellcheck source=/dev/null
  . "$SCRIPTS_DIR/herd-config.sh"
  # Re-theme the CLI palette from THIS project's HERD_THEME (startup default was tokyonight).
  if command -v herd_theme_load_cli >/dev/null 2>&1; then herd_theme_load_cli; fi
  command -v _status_run >/dev/null 2>&1 || die "status helpers not loaded (scripts/herd/status.sh missing)"
  local rc=0
  _status_run || rc=$?
  return "$rc"
}

cmd_backlog() {
  # Print the project's OPEN work items via the active SCRIBE_BACKEND — the generic,
  # backend-agnostic "what's my open work?" command. The file backend greps $BACKLOG_FILE,
  # the github backend runs `gh issue list`, the linear backend queries Linear; every backend
  # emits the same "#<id> <title>" line shape via _backend_list_open, so a non-file-backend
  # project surfaces its issue tracker as actionable work rather than a tracked file.
  #
  # Modes (default output is byte-identical to before — the plain list IS the contract):
  #   herd backlog              plain "#<id> <title>" lines (_backend_list_open)
  #   herd backlog --rich       TSV lines with workflow state + description snippet when the
  #                             backend defines _backend_list_open_rich (linear); backends
  #                             without the op fall back to the plain list, so a consumer can
  #                             always ask for --rich and key its rendering off the line shape
  #   herd backlog show <#id>   one item's full detail (_backend_show_item) — state, title,
  #                             untruncated description, URL
  #   herd backlog browse       interactive fzf picker over the open list with a live detail
  #                             preview pane; ENTER prints the selection's full detail. Without
  #                             fzf it degrades soft: plain list + a one-line install hint
  #   herd backlog queued       list live PLANNED-work markers (HERD-52): items a coordinator has
  #                             sequenced-to-spawn-next but not yet spawned, so a second operator
  #                             sees plan-time intent. Markers older than 24h are flagged ADVISORY.
  #   herd backlog queue <#id> [--after <blocker>]
  #                             publish such a marker (I'm building this next, after <blocker>)
  #   herd backlog unqueue <#id>  clear my marker (plan dropped; a spawn's claim supersedes it too)
  # queue/unqueue/queued are BACKEND-OPTIONAL: a backend without the op prints a soft note (or an
  # empty list) and exits 0 — a plan marker is advisory, never a gate.
  local mode="plain" ref="" blocker=""
  case "${1:-}" in
    --rich)  mode="rich" ;;
    show)    mode="show"; ref="${2:-}"
             [ -n "$ref" ] || die "usage: herd backlog show <#id>" ;;
    browse)  mode="browse" ;;
    queued)  mode="queued" ;;
    queue)   mode="queue"; ref="${2:-}"
             [ -n "$ref" ] || die "usage: herd backlog queue <#id> [--after <blocker>]"
             case "${3:-}" in --after) blocker="${4:-}" ;; '') ;; *) blocker="${3:-}" ;; esac ;;
    unqueue) mode="unqueue"; ref="${2:-}"
             [ -n "$ref" ] || die "usage: herd backlog unqueue <#id>" ;;
    '')      ;;
    *)       die "usage: herd backlog [--rich | show <#id> | browse | queued | queue <#id> [--after <blocker>] | unqueue <#id>]" ;;
  esac
  local root; root="$(pwd)"
  local cfg="$root/.herd/config"
  [ -f "$cfg" ] || die "no .herd/config at $root — run 'herd init' first"
  # Load the project's answers through the shared loader (sets SCRIBE_BACKEND, BACKLOG_FILE,
  # PROJECT_ROOT, HERD_REPO, …). Pin it to this repo's config so the loader doesn't walk elsewhere.
  export HERD_CONFIG_FILE="$cfg"
  # shellcheck source=/dev/null
  . "$SCRIPTS_DIR/herd-config.sh"
  # API backends (e.g. linear) read credentials from .herd/secrets (gitignored); file/github do
  # not. Best-effort + absent-file-safe, mirroring how scribe-step.sh sources secrets.
  local secrets="$PROJECT_ROOT/.herd/secrets"
  # shellcheck source=/dev/null
  [ -f "$secrets" ] && . "$secrets"
  # Source the pluggable backend keyed on SCRIBE_BACKEND (default: file). Loud if it is missing.
  local backend_file="$SCRIPTS_DIR/backends/${SCRIBE_BACKEND}.sh"
  [ -f "$backend_file" ] || die "unknown SCRIBE_BACKEND '$SCRIBE_BACKEND' — no backends/${SCRIBE_BACKEND}.sh"
  # shellcheck source=/dev/null
  . "$backend_file"
  command -v _backend_list_open >/dev/null 2>&1 \
    || die "backend '$SCRIBE_BACKEND' defines no _backend_list_open op"
  # Run the op from the project root: the file backend greps $BACKLOG_FILE (repo-relative); the
  # tracker backends ignore cwd. A backend with a missing dep (no gh / no key) fails loud + non-zero.
  cd "$PROJECT_ROOT" 2>/dev/null || true
  case "$mode" in
    plain)
      _backend_list_open ;;
    rich)
      # Rich is opt-in per backend; a backend without the op serves the plain list so the caller
      # (backlog-view.sh) can always request --rich and detect the shape from the output itself.
      if command -v _backend_list_open_rich >/dev/null 2>&1; then
        _backend_list_open_rich
      else
        _backend_list_open
      fi ;;
    show)
      if command -v _backend_show_item >/dev/null 2>&1; then
        _backend_show_item "$ref"
      else
        # No detail op (file/github today): grep the plain list for the id so `show` still answers.
        _backend_list_open | grep -F -- "${ref#\#}" \
          || { echo "no open item matching '$ref' (backend '$SCRIBE_BACKEND' has no detail op)" >&2; return 1; }
      fi ;;
    browse)
      local list self sel
      list="$(_backend_list_open)" || true
      if [ -z "$list" ]; then echo "(no open items)"; return 0; fi
      if command -v fzf >/dev/null 2>&1; then
        # {1} is the '#<id>' token of the highlighted line; the preview pane runs `backlog show`
        # on it live. Invoke ourselves via an absolute path — fzf's preview shell has no
        # guarantee this herd is first on PATH (or on PATH at all).
        self="$HERDKIT_HOME/bin/herd"
        sel="$(printf '%s\n' "$list" | fzf --no-sort \
                 --prompt='backlog> ' \
                 --header='enter: print full detail · esc: quit' \
                 --preview="$self backlog show {1}" \
                 --preview-window=right,60%,wrap)" || return 0
        [ -n "$sel" ] && cmd_backlog show "${sel%% *}"
      else
        printf '%s\n' "$list"
        echo "herd backlog browse: fzf not found — showing the plain list (brew install fzf / apt install fzf for interactive browsing)" >&2
      fi ;;
    queued)
      # Print live planned markers, readable, with a >24h ADVISORY flag computed off the epoch.
      # A backend without the op simply prints nothing (no markers exist there).
      command -v _backend_list_queued >/dev/null 2>&1 || return 0
      local now; now="$(date +%s 2>/dev/null || echo 0)"
      _backend_list_queued | NOW="$now" python3 -c 'import sys, os
now = int(os.environ.get("NOW") or 0)
for line in sys.stdin:
    parts = line.rstrip("\n").split("\t")
    if len(parts) < 4:
        continue
    ref, who, detail, ts = parts[0], parts[1], parts[2], parts[3]
    try: age = now - int(ts)
    except ValueError: age = -1
    if age < 0:
        when = ""
    elif age >= 86400:
        when = " (%dh ago — ADVISORY: >24h stale)" % (age // 3600)
    elif age >= 3600:
        when = " (%dh ago)" % (age // 3600)
    else:
        when = " (%dm ago)" % (age // 60)
    print("%s — queued by %s: %s%s" % (ref, who, detail, when))' 2>/dev/null || true ;;
    queue|unqueue)
      # Publish / clear a planned marker synchronously (like a claim, unlike the async scribe) so a
      # second operator sees the plan promptly. Resolve the operator identity the same order the
      # claimant does, and attribute the tracker_write to the 'plan' component (HERD-85).
      if ! command -v "_backend_${mode}_item" >/dev/null 2>&1; then
        echo "herd backlog $mode: backend '$SCRIBE_BACKEND' has no planned-marker op — skipping (advisory feature, fail-soft)." >&2
        return 0
      fi
      local who="${WATCHER_OWNER:-}"
      [ -n "$who" ] || who="${WATCHER_VIEW_AUTHOR:-}"
      [ -n "$who" ] || who="$(gh api user -q .login 2>/dev/null || true)"
      [ -n "$who" ] || who="unknown-operator"
      export HERD_COMPONENT="plan"
      _BACKEND_RESULT=""
      if [ "$mode" = "queue" ]; then
        _backend_queue_item "$ref" "$who" "$blocker"
      else
        _backend_unqueue_item "$ref" "$who"
      fi
      case "${_BACKEND_RESULT:-}" in
        DONE) [ "$mode" = "queue" ] \
                && echo "📌 queued $ref as '$who'${blocker:+ (after $blocker)} — visible to other operators via 'herd backlog queued'." \
                || echo "🧹 cleared the planned marker on $ref." ;;
        *)    [ "$mode" = "queue" ] \
                && echo "herd backlog queue: no change (item '$ref' not resolvable, or already marked) — see stderr above." >&2 \
                || echo "herd backlog unqueue: no planned marker on '$ref' to clear." >&2 ;;
      esac ;;
  esac
}

# ── herd backend: guided work-tracker backend switching ─────────────────────────────────────────
# cmd_backend_switch — the PROCESS around flipping SCRIBE_BACKEND, in gate order:
#   1. PREFLIGHT (loud, before ANY change): target adapter exists; linear → LINEAR_API_KEY present
#      (prompted interactively when on a tty, stored in .herd/secrets chmod 600 + gitignored,
#      never echoed, never in .herd/config) AND a live viewer{} API round-trip proves it works;
#      github → gh installed + authenticated. A failed preflight changes NOTHING.
#   2. FLIP via cmd_config_set — inherits key validation, the #139 stale-drainer warning, and the
#      coordinator-skill re-render.
#   3. MIGRATE (optional): replay the OLD backend's open items into the NEW one via its
#      _backend_add_item, skipping items whose title already appears in the new backend's open
#      list (idempotent re-runs). --migrate / --no-migrate decide non-interactively; a tty is
#      asked. Titles carry a '(migrated from <old>)' suffix so provenance survives.
#   4. FREEZE: leaving the file backend stamps $BACKLOG_FILE with a dated frozen-archive banner —
#      the file becomes history, not the work source, and should say so to every future reader.
#   5. RESTART the backlog viewer pane (best-effort — it binds its backend at process start) and
#      journal a backend_switched event.
cmd_backend() {
  local sub="${1:-}"; [ "$#" -gt 0 ] && shift
  case "$sub" in
    switch) cmd_backend_switch "$@" ;;
    *) die "usage: herd backend switch <file|github|linear|changelog> [--migrate|--no-migrate] [--yes]" ;;
  esac
}

cmd_backend_switch() {
  local target="" migrate=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --migrate)    migrate=1 ;;
      --no-migrate) migrate=0 ;;
      -*)           die "herd backend switch: unknown flag '$1'" ;;
      *)            [ -z "$target" ] && target="$1" || die "herd backend switch: one backend name only" ;;
    esac
    shift
  done
  [ -n "$target" ] || die "usage: herd backend switch <file|github|linear|changelog> [--migrate|--no-migrate]"

  # Load the project (mirrors cmd_backlog's loader).
  local root; root="$(pwd)"
  local cfg="$root/.herd/config"
  [ -f "$cfg" ] || die "no .herd/config at $root — run 'herd init' first"
  export HERD_CONFIG_FILE="$cfg"
  # shellcheck source=/dev/null
  . "$SCRIPTS_DIR/herd-config.sh"
  local secrets="$PROJECT_ROOT/.herd/secrets"
  # shellcheck source=/dev/null
  [ -f "$secrets" ] && . "$secrets"

  local target_file="$SCRIPTS_DIR/backends/${target}.sh"
  [ -f "$target_file" ] || die "unknown backend '$target' — no backends/${target}.sh"
  local current="${SCRIBE_BACKEND:-file}"
  if [ "$target" = "$current" ]; then
    say "already on SCRIBE_BACKEND=$current — nothing to do"
    return 0
  fi

  # ── 1. preflight — fail loud BEFORE any change ─────────────────────────────────────────────────
  case "$target" in
    linear)
      if [ -z "${LINEAR_API_KEY:-}" ]; then
        if [ -t 0 ]; then
          printf 'Linear API key (stored in %s, gitignored; input hidden): ' "$secrets" >&2
          local _key=""; IFS= read -rs _key </dev/tty || true; printf '\n' >&2
          [ -n "$_key" ] || die "no key entered — nothing was changed"
          touch "$secrets" && chmod 600 "$secrets"
          printf 'LINEAR_API_KEY="%s"\n' "$_key" >> "$secrets"
          local gi="$PROJECT_ROOT/.gitignore"
          if ! { [ -f "$gi" ] && grep -qxF '.herd/secrets' "$gi"; }; then
            printf '.herd/secrets\n' >> "$gi"
          fi
          LINEAR_API_KEY="$_key"; export LINEAR_API_KEY
        else
          die "LINEAR_API_KEY missing — add LINEAR_API_KEY=\"lin_api_…\" to $secrets (gitignored) and re-run; nothing was changed"
        fi
      fi
      # Live round-trip: prove the key works before touching config. viewer{} is the cheapest
      # authenticated query; any error/HTML/empty response fails the grep.
      # shellcheck source=/dev/null
      . "$target_file"
      _linear_gql 'query { viewer { id } }' 2>/dev/null | grep -q '"id"' \
        || die "Linear API round-trip FAILED (bad key or network) — nothing was changed"
      say "✓ Linear API reachable (viewer check passed)"
      ;;
    github)
      command -v gh >/dev/null 2>&1 || die "github backend needs the gh CLI — install it first; nothing was changed"
      gh auth status >/dev/null 2>&1 || die "gh is not authenticated (run 'gh auth login') — nothing was changed"
      say "✓ gh authenticated"
      ;;
  esac

  # Capture the OLD backend's open items BEFORE the flip (subshell: keep its functions out of
  # this process, where the target backend may already be sourced).
  local old_open=""
  old_open="$(
    # shellcheck source=/dev/null
    cd "$PROJECT_ROOT" && . "$SCRIPTS_DIR/backends/${current}.sh" 2>/dev/null && _backend_list_open 2>/dev/null
  )" || true

  # ── 2. flip (validation + #139 stale-drainer warning + skill re-render live in config set) ────
  cmd_config set SCRIBE_BACKEND "$target"

  # ── 3. optional migration of open items ───────────────────────────────────────────────────────
  local n_old=0
  [ -n "$old_open" ] && n_old="$(printf '%s\n' "$old_open" | grep -c .)"
  if [ "$n_old" -gt 0 ] && [ -z "$migrate" ]; then
    if [ -t 0 ]; then
      printf 'Migrate %s open item(s) from %s into %s? [y/N] ' "$n_old" "$current" "$target" >&2
      local _ans=""; IFS= read -r _ans </dev/tty || true
      case "$_ans" in y|Y|yes) migrate=1 ;; *) migrate=0 ;; esac
    else
      migrate=0
      say "(non-interactive: NOT migrating $n_old open item(s) — re-run with --migrate to replay them)"
    fi
  fi
  if [ "${migrate:-0}" = "1" ] && [ "$n_old" -gt 0 ]; then
    # New backend's current open titles, for idempotent dedup on re-runs.
    local new_open=""
    new_open="$(
      # shellcheck source=/dev/null
      cd "$PROJECT_ROOT" && . "$target_file" 2>/dev/null && _backend_list_open 2>/dev/null
    )" || true
    local migrated=0 skipped=0 ln text _mig_title
    while IFS= read -r ln; do
      [ -n "$ln" ] || continue
      # Normalize to a clean title: drop list bullets and the file backend's state emoji; keep a
      # tracker line's '#id ' prefix out of the new title but preserve it as provenance.
      text="$(printf '%s' "$ln" | sed -e 's/^[-*] *//' -e 's/^🔜 *//' -e 's/^🚧 *//')"
      case "$text" in
        '#'*' '*) text="${text#* } (migrated from ${current} ${ln%% *})" ;;
        *)        text="$text (migrated from ${current})" ;;
      esac
      # Idempotency dedup: EXACT normalized-title equality, never a substring test. A substring
      # match (grep -F without -x) silently DROPS a genuine open item whenever its title happens
      # to be contained in any unrelated pre-existing target item — e.g. file item 'add login'
      # vs existing issue '#7 Fix the add login flow crash' (review-gate finding on this PR).
      # Normalize both sides identically: the candidate is the clean title with its
      # '(migrated from …)' provenance stripped; each target line drops its '#id ' prefix,
      # bullets/state emoji, and any provenance suffix from an earlier partial migration.
      # -x anchors the comparison to the WHOLE line.
      _mig_title="${text%% (migrated*}"
      if [ -n "$new_open" ] && printf '%s\n' "$new_open" \
           | sed -e 's/^#[^ ]* //' -e 's/^[-*] *//' -e 's/^🔜 *//' -e 's/^🚧 *//' -e 's/ (migrated from [^)]*)$//' \
           | grep -qxF -- "$_mig_title"; then
        skipped=$((skipped + 1)); continue
      fi
      if (
        # shellcheck source=/dev/null
        cd "$PROJECT_ROOT" && . "$target_file" 2>/dev/null
        _BACKEND_RESULT=""
        _backend_add_item "MIGRATE" "$text" >/dev/null 2>&1
        [ "${_BACKEND_RESULT:-}" = "DONE" ]
      ); then migrated=$((migrated + 1)); else
        warn "could not migrate: $text"
      fi
    done <<EOF
$old_open
EOF
    say "migrated $migrated item(s) into $target${skipped:+ ($skipped already present, skipped)}"
  fi

  # ── 4. frozen-archive banner when leaving the file backend ────────────────────────────────────
  if [ "$current" = "file" ] && [ "$target" != "file" ] && [ -f "$PROJECT_ROOT/$BACKLOG_FILE" ] \
     && ! grep -q 'FROZEN ARCHIVE' "$PROJECT_ROOT/$BACKLOG_FILE"; then
    local _tmp; _tmp="$(mktemp)"
    {
      printf '> ⚠️ **FROZEN ARCHIVE (%s)** — the live work queue moved to the **%s** backend\n' "$(date +%Y-%m-%d)" "$target"
      printf '> (`herd backend switch %s`). This file is history; see `herd backlog` for open work.\n\n' "$target"
      cat "$PROJECT_ROOT/$BACKLOG_FILE"
    } > "$_tmp" && mv "$_tmp" "$PROJECT_ROOT/$BACKLOG_FILE"
    say "stamped $BACKLOG_FILE as a frozen archive"
  fi

  # ── 5. restart the backlog viewer + journal ───────────────────────────────────────────────────
  # The viewer binds SCRIBE_BACKEND at process start; best-effort restart, loud hint if it can't.
  if ! "$HERDKIT_HOME/bin/herd" pane backlog >/dev/null 2>&1; then
    warn "could not restart the backlog pane — run 'herd pane backlog' (and if it still shows the old backend, close the stale viewer process first)"
  fi
  # shellcheck source=/dev/null
  { . "$SCRIPTS_DIR/journal.sh" 2>/dev/null && journal_append backend_switched from "$current" to "$target"; } || true
  say ""
  say "✅ SCRIBE_BACKEND: $current → $target (scribe drainer, herd backlog, watcher mark-shipped, and the coordinator skill all follow this key)"
}

# ── herd link: registry of peer repos for cross-project filing ──────────────────────────────────
cmd_link_list() {
  local root; root="$(pwd)"
  local cfg="$root/.herd/config"
  [ -f "$cfg" ] && export HERD_CONFIG_FILE="$cfg"
  # shellcheck source=/dev/null
  . "$SCRIPTS_DIR/herd-config.sh"
  # shellcheck source=/dev/null
  . "$SCRIPTS_DIR/herd-links.sh"
  local links_file; links_file="$(_herd_find_links)"
  if [ -z "$links_file" ] || [ ! -f "$links_file" ]; then
    say "no .herd/links file found"
    say "create .herd/links to register peer repos (format: name|owner/repo|backend|tracker_target)"
    return 0
  fi
  say "Links ($links_file):"
  local line count=0 lname lrepo lbackend ltarget lrest
  while IFS= read -r line; do
    case "$line" in '#'*|'') continue ;; esac
    lname="${line%%|*}"; lrest="${line#*|}"
    lrepo="${lrest%%|*}"; lrest="${lrest#*|}"
    lbackend="${lrest%%|*}"; ltarget="${lrest#*|}"
    printf '  %-20s  %-30s  [%s]%s\n' "$lname" "$lrepo" "${lbackend:-github}" "${ltarget:+  target=$ltarget}"
    count=$((count + 1))
  done < "$links_file"
  if [ "$count" -eq 0 ]; then say "(no links defined)"; fi
}

cmd_link() {
  local sub="${1:-list}"
  case "$sub" in
    list)   cmd_link_list ;;
    # TODO(backlog): herd link --scan — walk sibling repos' .herd/config to auto-populate links
    --scan) warn "herd link --scan: scanning sibling repos to populate links is TODO"; return 0 ;;
    *)      die "usage: herd link list" ;;
  esac
}

# ── Cross-repo dependency intent (.herd/deps) ────────────────────────────────────────────────────
# `herd report --to` is fire-and-forget dispatch. `herd depend` records a WATCHED dependency:
# a "blocked-on: <link>#<id>" row in .herd/deps that dep-watcher.sh polls until the upstream item
# closes. A dep is EDITABLE DATA — `herd deps list/rm/demote` inspect, drop, or reclassify it into a
# non-blocking "watch:" row — never stuck. The row format is exactly the one dep-watcher.sh already
# reads ("blocked-on: <ref>", ref = up to first whitespace); we only APPEND backward-compatible
# " since=<epoch>" trailing fields the watcher ignores. "watch:" rows (demoted) are invisible to the
# watcher's blocked-on parser by design, so a demote instantly un-blocks the lane.

_deps_epoch() { date +%s 2>/dev/null || python3 -c 'import time; print(int(time.time()))'; }

# _deps_file_path — the project's .herd/deps (DEPS_FILE override mirrors dep-watcher.sh, for tests).
_deps_file_path() { printf '%s' "${DEPS_FILE:-$PROJECT_ROOT/.herd/deps}"; }

# _deps_load_ctx — load .herd/config + the links resolver, exactly as cmd_link_list does, so
# PROJECT_ROOT / _herd_resolve_link are available. Runs in the current shell (vars propagate).
_deps_load_ctx() {
  local root; root="$(pwd)"
  local cfg="$root/.herd/config"
  [ -f "$cfg" ] && export HERD_CONFIG_FILE="$cfg"
  # shellcheck source=/dev/null
  . "$SCRIPTS_DIR/herd-config.sh"
  # shellcheck source=/dev/null
  . "$SCRIPTS_DIR/herd-links.sh"
}

# _deps_validate_ref <ref> — a ref is <link-name>#<id>: a '#', non-empty on both sides, no whitespace.
_deps_validate_ref() {
  local ref="$1"
  case "$ref" in *'#'*) ;; *) return 1 ;; esac
  case "$ref" in *[[:space:]]*) return 1 ;; esac
  [ -n "${ref%%#*}" ] && [ -n "${ref#*#}" ]
}

# _deps_ensure_file <file> — create .herd/deps with a self-documenting header if absent.
_deps_ensure_file() {
  local f="$1"
  [ -f "$f" ] && return 0
  mkdir -p "$(dirname "$f")" 2>/dev/null || true
  {
    printf '# .herd/deps — recorded cross-repo dependencies (herd deps). Commit this; zero-secret.\n'
    printf '# Format: blocked-on: <link>#<id>  since=<epoch>   — watched by dep-watcher.sh\n'
    printf '#         watch: <link>#<id>  since=<epoch>        — demoted, non-blocking (ignored by the watcher)\n'
  } > "$f"
}

# _deps_kind_of <file> <ref> → prints "blocked-on" | "watch" | "" (empty = not present).
_deps_kind_of() {
  local f="$1" ref="$2" line r
  [ -f "$f" ] || return 0
  while IFS= read -r line; do
    case "$line" in
      'blocked-on: '*) r="${line#blocked-on: }" ;;
      'watch: '*)      r="${line#watch: }" ;;
      *) continue ;;
    esac
    r="${r%%[[:space:]]*}"
    [ "$r" = "$ref" ] || continue
    case "$line" in 'blocked-on: '*) printf 'blocked-on' ;; *) printf 'watch' ;; esac
    return 0
  done < "$f"
}

# _deps_set_kind <file> <ref> <new-kind> — rewrite the row's prefix, PRESERVING trailing fields
# (since=…). Atomic via temp file + mv, the same shape dep-watcher.sh uses.
_deps_set_kind() {
  local f="$1" ref="$2" newkind="$3" tmp line rest r
  [ -f "$f" ] || return 1
  tmp="${f}.$$"
  while IFS= read -r line; do
    case "$line" in
      'blocked-on: '*) rest="${line#blocked-on: }" ;;
      'watch: '*)      rest="${line#watch: }" ;;
      *) printf '%s\n' "$line"; continue ;;
    esac
    r="${rest%%[[:space:]]*}"
    if [ "$r" = "$ref" ]; then printf '%s: %s\n' "$newkind" "$rest"; else printf '%s\n' "$line"; fi
  done < "$f" > "$tmp"
  mv "$tmp" "$f"
}

# _deps_remove <file> <ref> — drop the row (blocked-on OR watch) for <ref>. Returns 0 if one was
# removed, 1 if the ref was absent. Atomic temp-file + mv.
_deps_remove() {
  local f="$1" ref="$2" tmp line r removed=1
  [ -f "$f" ] || return 1
  tmp="${f}.$$"
  while IFS= read -r line; do
    case "$line" in
      'blocked-on: '*) r="${line#blocked-on: }" ;;
      'watch: '*)      r="${line#watch: }" ;;
      *) printf '%s\n' "$line"; continue ;;
    esac
    r="${r%%[[:space:]]*}"
    if [ "$r" = "$ref" ]; then removed=0; continue; fi
    printf '%s\n' "$line"
  done < "$f" > "$tmp"
  mv "$tmp" "$f"
  return "$removed"
}

# _deps_state <ref> — best-effort current state of the upstream item (open|in-progress|closed|
# unknown). Resolves the link + report backend in a SUBSHELL so HERD_REPO is not clobbered; any
# failure (no link, no backend, no gh) degrades to "unknown". Never fatal.
_deps_state() {
  local ref="$1"
  (
    link="${ref%%#*}"
    _herd_resolve_link "$link" 2>/dev/null || { printf 'unknown'; exit 0; }
    bf="$SCRIPTS_DIR/backends/${HERD_REPORT_BACKEND:-github}.sh"
    [ -f "$bf" ] || { printf 'unknown'; exit 0; }
    # github (the default) shells out to gh; skip when it is absent so we never hit its die path.
    case "${HERD_REPORT_BACKEND:-github}" in
      github) command -v gh >/dev/null 2>&1 || { printf 'unknown'; exit 0; } ;;
    esac
    ITEM_STATE=""
    # shellcheck source=/dev/null
    . "$bf"
    command -v _backend_item_state >/dev/null 2>&1 || { printf 'unknown'; exit 0; }
    _backend_item_state "$ref" 2>/dev/null || true
    printf '%s' "${ITEM_STATE:-unknown}"
  )
}

# _deps_record <file> <ref> — append a "blocked-on:" row (idempotent; promotes a demoted "watch:").
# Prints a one-line human confirmation. Caller has validated <ref> and resolved its link.
_deps_record() {
  local f="$1" ref="$2" kind
  _deps_ensure_file "$f"
  kind="$(_deps_kind_of "$f" "$ref")"
  case "$kind" in
    blocked-on) say "already tracking blocked-on: $ref (herd deps list)"; return 0 ;;
    watch)      _deps_set_kind "$f" "$ref" "blocked-on"
                ok "promoted $ref back to a blocking dependency" ;;
    *)          printf 'blocked-on: %s  since=%s\n' "$ref" "$(_deps_epoch)" >> "$f"
                ok "recorded blocked-on: $ref — dep-watcher.sh will poll it until the item closes" ;;
  esac
}

cmd_depend() {
  local ref="${1:-}"
  [ -n "$ref" ] || die "usage: herd depend <link>#<id>   (e.g. herd depend provider-lib#42)"
  _deps_validate_ref "$ref" \
    || die "invalid dependency ref '$ref' — expected <link>#<id> (e.g. provider-lib#42)"
  _deps_load_ctx
  local link="${ref%%#*}"
  _herd_resolve_link "$link" \
    || die "no link named '$link' in .herd/links — run 'herd link list' to see configured peers"
  _deps_record "$(_deps_file_path)" "$ref"
}

cmd_deps_list() {
  _deps_load_ctx
  local f; f="$(_deps_file_path)"
  if [ ! -f "$f" ]; then say "no dependencies recorded (.herd/deps absent)"; return 0; fi
  local any=0 line kind rest ref since state age agestr now
  now="$(_deps_epoch)"
  say "Dependencies ($f):"
  while IFS= read -r line; do
    case "$line" in
      'blocked-on: '*) kind="blocked-on"; rest="${line#blocked-on: }" ;;
      'watch: '*)      kind="watch";      rest="${line#watch: }" ;;
      *) continue ;;
    esac
    ref="${rest%%[[:space:]]*}"
    [ -n "$ref" ] || continue
    since=""
    case "$rest" in *since=*) since="${rest#*since=}"; since="${since%%[[:space:]]*}" ;; esac
    state="$(_deps_state "$ref" 2>/dev/null || printf 'unknown')"
    agestr=""
    case "$since" in ''|*[!0-9]*) ;; *) age=$(( now - since )); agestr="  age=${age}s" ;; esac
    printf '  %-11s  %-26s  state=%-8s%s\n' "$kind" "$ref" "${state:-unknown}" "$agestr"
    any=$((any + 1))
  done < "$f"
  [ "$any" -eq 0 ] && say "(no dependencies recorded)"
  return 0
}

cmd_deps_rm() {
  local ref="${1:-}"
  [ -n "$ref" ] || die "usage: herd deps rm <link>#<id>"
  _deps_load_ctx
  local f; f="$(_deps_file_path)"
  [ -f "$f" ] || die "no .herd/deps file — nothing to remove"
  local kind; kind="$(_deps_kind_of "$f" "$ref")"
  [ -n "$kind" ] || die "no dependency '$ref' recorded — run 'herd deps list'"
  # A dep is editable data: always remove, but warn if a blocking one is still open upstream.
  if [ "$kind" = "blocked-on" ]; then
    local state; state="$(_deps_state "$ref" 2>/dev/null || printf 'unknown')"
    case "$state" in
      open|in-progress) warn "removing $ref while it is still $state upstream — the blocker may not be resolved" ;;
    esac
  fi
  _deps_remove "$f" "$ref" && ok "removed $kind: $ref" || die "failed to remove $ref"
}

cmd_deps_demote() {
  local ref="${1:-}"
  [ -n "$ref" ] || die "usage: herd deps demote <link>#<id>"
  _deps_load_ctx
  local f; f="$(_deps_file_path)"
  [ -f "$f" ] || die "no .herd/deps file — nothing to demote"
  local kind; kind="$(_deps_kind_of "$f" "$ref")"
  case "$kind" in
    blocked-on) _deps_set_kind "$f" "$ref" "watch"
                ok "demoted $ref to a non-blocking watch — dep-watcher.sh no longer blocks on it" ;;
    watch)      say "$ref is already a non-blocking watch — nothing to do" ;;
    *)          die "no blocking dependency '$ref' recorded — run 'herd deps list'" ;;
  esac
}

cmd_deps() {
  local sub="${1:-list}"; shift 2>/dev/null || true
  case "$sub" in
    list)         cmd_deps_list "$@" ;;
    rm)           cmd_deps_rm "$@" ;;
    demote)       cmd_deps_demote "$@" ;;
    -h|--help)    say "usage: herd deps list | rm <link>#<id> | demote <link>#<id>" ;;
    *)            die "unknown 'herd deps' subcommand '$sub' — usage: herd deps list | rm <id> | demote <id>" ;;
  esac
}

# ── herd report dedup helpers (pure shell — no LLM dependency) ──────────────────────────────────
# A semantic/LLM-judged dedup pass could be a later enhancement; these stay heuristic + offline.
_report_norm() {
  # Normalize a title for comparison: lowercase, strip punctuation to spaces, collapse runs.
  # Prints a single space-delimited token stream (may have a leading/trailing space).
  printf '%s' "${1:-}" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9' ' ' | tr -s ' '
}

_report_find_dups() {
  # $1 = the new report title; $2 = newline-separated open items ("#<id> <title>" or backlog
  # lines). Prints each open item judged a LIKELY duplicate: a normalized substring match
  # (either direction) or >=60% overlap of the new title's significant (>=3-char) words.
  local new="$1" items="$2" new_norm cand cand_norm w total hit
  new_norm="$(_report_norm "$new")"; new_norm="${new_norm# }"; new_norm="${new_norm% }"
  [ -n "$new_norm" ] || return 0
  while IFS= read -r cand; do
    [ -n "$cand" ] || continue
    cand_norm="$(_report_norm "$cand")"; cand_norm="${cand_norm# }"; cand_norm="${cand_norm% }"
    [ -n "$cand_norm" ] || continue
    # Whole-title substring either direction → strong signal.
    case " $cand_norm " in *" $new_norm "*) printf '%s\n' "$cand"; continue ;; esac
    case " $new_norm "  in *" $cand_norm "*) printf '%s\n' "$cand"; continue ;; esac
    # Keyword overlap: fraction of the new title's significant words present in the candidate.
    total=0; hit=0
    for w in $new_norm; do
      [ "${#w}" -ge 3 ] || continue
      total=$((total + 1))
      case " $cand_norm " in *" $w "*) hit=$((hit + 1)) ;; esac
    done
    [ "$total" -gt 0 ] && [ $((hit * 10)) -ge $((total * 6)) ] && printf '%s\n' "$cand"
  done <<EOF
$items
EOF
  return 0   # never let a no-match (false && chain) propagate as failure under set -e
}

cmd_report() {
  local to_name="" dep_flag=""
  while true; do
    case "${1:-}" in
      --to)
        to_name="${2:-}"
        [ -n "$to_name" ] || die "--to requires a link name"
        shift 2 ;;
      --to=*) to_name="${1#--to=}"; shift ;;
      # --dep: after filing, ALSO record a blocked-on dep on the filed item (default stays
      # fire-and-forget). A dep must name its target peer, so --dep requires --to.
      --dep) dep_flag=1; shift ;;
      *) break ;;
    esac
  done
  local symptom="${1:-}"
  [ -n "$symptom" ] || die "usage: herd report [--to <link>] [--dep] \"<symptom + which lane>\""
  [ -z "$dep_flag" ] || [ -n "$to_name" ] \
    || die "herd report --dep requires --to <link> (a dependency must name the peer it blocks on)"
  local root; root="$(pwd)"
  local cfg="$root/.herd/config"
  # Load the project's answers through the shared loader (HERD_REPO, WORKSPACE_NAME, HERD_VERSION,
  # …). Pin it to this repo's config when present so the loader doesn't walk elsewhere. Capture any
  # env HERD_REPORT_BACKEND first so env wins over a config value.
  local env_backend="${HERD_REPORT_BACKEND:-}"
  [ -f "$cfg" ] && export HERD_CONFIG_FILE="$cfg"
  # shellcheck source=/dev/null
  . "$SCRIPTS_DIR/herd-config.sh"
  # API report backends (e.g. linear) read credentials from .herd/secrets (gitignored); github does
  # not. Best-effort + absent-file-safe, mirroring cmd_backlog / scribe-step.sh.
  local secrets="$PROJECT_ROOT/.herd/secrets"
  # shellcheck source=/dev/null
  [ -f "$secrets" ] && . "$secrets"
  local project ver
  project="${WORKSPACE_NAME:-$(basename "$root")}"
  ver="${HERD_VERSION:-?}"

  # Report backend: when --to is given, resolve the named link from .herd/links, which sets
  # HERD_REPO and HERD_REPORT_BACKEND for the target peer. Without --to the existing precedence
  # holds: env wins over config over the github default.
  local report_backend
  if [ -n "$to_name" ]; then
    # shellcheck source=/dev/null
    . "$SCRIPTS_DIR/herd-links.sh"
    _herd_resolve_link "$to_name" \
      || die "no link named '$to_name' in .herd/links — run 'herd link list' to see configured links"
    report_backend="${HERD_REPORT_BACKEND:-github}"
    # Wire tracker_target to the backend-specific routing variable so the link's value
    # wins over any .herd/secrets default. Currently: linear → LINEAR_TEAM_ID.
    if [ -n "${HERD_LINK_TARGET:-}" ]; then
      case "$report_backend" in
        linear) export LINEAR_TEAM_ID="$HERD_LINK_TARGET" ;;
      esac
    fi
  else
    report_backend="${env_backend:-${HERD_REPORT_BACKEND:-github}}"
  fi

  # HERD_REPO routes github-backed reports. It used to fall back to the engine author's own repo
  # (briankeegan1/herdkit) when unset — silently filing an external consumer's engine-bug reports
  # against a stranger's repo (external-consumer audit, Leak E). Now, for the github backend, an
  # unset HERD_REPO REFUSES with an actionable error — UNLESS this project IS the herdkit engine
  # itself (its origin remote resolves to briankeegan1/herdkit), where the self-target is correct
  # (this dogfood repo). The --to path has already set HERD_REPO from the resolved link above.
  if [ "$report_backend" = "github" ] && [ -z "${HERD_REPO:-}" ]; then
    if [ "$(_gh_repo_slug "$root" origin)" = "briankeegan1/herdkit" ]; then
      HERD_REPO="briankeegan1/herdkit"
    else
      die "HERD_REPO is not set — set it in .herd/config to the repo where engine bugs should be filed, e.g. owner/herdkit"
    fi
  fi

  local backend_file="$SCRIPTS_DIR/backends/${report_backend}.sh"
  [ -f "$backend_file" ] \
    || die "unknown HERD_REPORT_BACKEND '$report_backend' — no backends/${report_backend}.sh"
  # shellcheck source=/dev/null
  . "$backend_file"
  command -v _backend_add_item >/dev/null 2>&1 \
    || die "report backend '$report_backend' defines no _backend_add_item op"
  command -v _backend_list_open >/dev/null 2>&1 \
    || die "report backend '$report_backend' defines no _backend_list_open op"

  local title body report_text
  title="[$project] $symptom"
  body="$(printf 'Reported from project **%s** (HERD_VERSION %s) via \`herd report\`.\n\n**Symptom / lane:** %s\n\n_Stamped automatically; add a repro below._' "$project" "$ver" "$symptom")"
  # The first line is the issue title (the github/linear backends take head -n1 as the title).
  report_text="$(printf '%s\n\n%s' "$title" "$body")"

  # ── Dedup BEFORE filing — compare the title against open items on the target ──────────────────
  # Best-effort: a list failure (e.g. a missing dep) is non-fatal here; the add path below surfaces
  # any dep error loudly. HERD_REPORT_FORCE=1 skips the check entirely.
  if [ -z "${HERD_REPORT_FORCE:-}" ]; then
    local open_items dup_hits
    open_items="$(_backend_list_open 2>/dev/null)" || true
    dup_hits="$(_report_find_dups "$title" "$open_items")"
    if [ -n "$dup_hits" ]; then
      warn "possible duplicate(s) already open on $HERD_REPO:"
      printf '%s\n' "$dup_hits" >&2
      if [ -t 0 ] && [ -z "${HERD_NONINTERACTIVE:-}" ]; then
        local ans; ans="$(ask "File anyway? [f]ile / [c]ancel" "c")"
        case "$ans" in
          f|F|file) say "filing anyway…" ;;
          *) say "cancelled — not filing (matched an open item above)"; return 0 ;;
        esac
      else
        warn "not filing a likely duplicate — re-run with HERD_REPORT_FORCE=1 to file anyway"
        return 0
      fi
    fi
  fi

  say "Filing engine bug on ${c_bold}$HERD_REPO${c_rst} via the ${report_backend} backend…"
  _BACKEND_RESULT=""
  # Default path is byte-for-byte unchanged: _backend_add_item prints its result to stdout. For
  # --dep we must ALSO read that output (the created item's URL) to recover the new item id, so we
  # capture it to a temp file (NOT a $(subshell) — _BACKEND_RESULT is set by side effect and must
  # propagate to this shell) and echo it back so the user still sees it.
  local add_out=""
  if [ -n "$dep_flag" ]; then
    local add_file; add_file="$(mktemp)"
    _backend_add_item "report" "$report_text" > "$add_file"
    add_out="$(cat "$add_file")"; rm -f "$add_file"
    [ -n "$add_out" ] && printf '%s\n' "$add_out"
  else
    _backend_add_item "report" "$report_text"
  fi
  case "${_BACKEND_RESULT:-}" in
    DONE)
      ok "filed."
      if [ -n "$dep_flag" ]; then
        # Recover the item id from the backend's result (github prints the issue URL; the id is the
        # trailing path segment of its last line). Record blocked-on: <link>#<id> in .herd/deps.
        local last num
        last="${add_out##*$'\n'}"; num="${last##*/}"
        case "$num" in
          ''|*[!0-9]*)
            warn "--dep: could not parse an item id from the backend result — dependency NOT recorded; run 'herd depend $to_name#<id>' once you have the id" ;;
          *)
            _deps_record "$(_deps_file_path)" "$to_name#$num" ;;
        esac
      fi
      ;;
    *)
      warn "backend reported no change (${_BACKEND_RESULT:-?}) — nothing filed"
      [ -n "$dep_flag" ] && warn "--dep: nothing was filed, so no dependency was recorded"
      ;;
  esac
}

# ── cmd_reload helpers: herdr JSON plumbing + verified pane launches ─────────
# `herdr pane run` types the command into the pane's tty. A run submitted before the
# pane's shell has finished initializing can execute DETACHED from the tty: the process
# runs (parented to the shell) while the visible pane sits at a bare prompt looking dead
# — the invisible-watcher bug. Every launch below therefore (a) waits for the pane's
# shell, (b) runs, (c) VERIFIES the pane's foreground actually shows the script, retrying
# once, and reports loudly on failure. Never assume a pane run landed.

# _reload_pane_state <pane_id> <match> → GONE | NOSHELL | BARE | BUSY | RUN <pid>
#   GONE     pane missing or the herdr call failed
#   NOSHELL  pane exists but its shell has not initialized yet
#   BARE     shell up, nothing in the foreground — safe to run our script here
#   RUN      a foreground process matches <match> (|-separated substrings); pid printed
#   BUSY     something else is running — never hijack this pane
_reload_pane_state() {
  herdr pane process-info --pane "$1" 2>/dev/null | M="${2:-}" python3 -c '
import sys,json,os
try: pi=json.load(sys.stdin)["result"]["process_info"]
except Exception: print("GONE"); sys.exit(0)
sh=pi.get("shell_pid") or 0
if not sh: print("NOSHELL"); sys.exit(0)
subs=[s for s in os.environ.get("M","").split("|") if s]
fg=[p for p in (pi.get("foreground_processes") or []) if p.get("pid")!=sh]
for p in fg:
    if any(s in (p.get("cmdline") or "") for s in subs):
        print("RUN", p.get("pid",0)); sys.exit(0)
print("BUSY" if fg else "BARE")
' 2>/dev/null || printf 'GONE\n'
}

# _reload_pane_alive <pane_id> <match> → prints "<pid>" and returns 0 iff a foreground process in
# the pane is a GENUINE `bash …/<script>` invocation of the expected viewer; returns 1 otherwise.
# This is the STRICT post-launch liveness gate (vs _reload_pane_state's loose readiness substring):
# it demands the script name sit on a real argv-token boundary — `bash` led by start/space/slash,
# whitespace, then a path ending in the script. A stale shell whose buffered/typed-ahead text merely
# CONTAINS the token — e.g. 'rrrr…bash …/backlog-view.sh' glued onto junk, the real 2026-07-06
# incident where a dead viewer's leftover keystrokes concatenated onto our run — is rejected, so a
# false ✓ can't survive. <match> is a '|'-separated set of accepted script names.
_reload_pane_alive() {
  herdr pane process-info --pane "$1" 2>/dev/null | M="${2:-}" python3 -c '
import sys,json,os,re
try: pi=json.load(sys.stdin)["result"]["process_info"]
except Exception: sys.exit(1)
sh=pi.get("shell_pid") or 0
subs=[s for s in os.environ.get("M","").split("|") if s]
if not subs: sys.exit(1)
pats=[re.compile(r"(?:^|[\s/])bash\s+\S*"+re.escape(s)+r"(?:\s|$)") for s in subs]
for p in (pi.get("foreground_processes") or []):
    if p.get("pid")==sh: continue
    cl=p.get("cmdline") or ""
    if any(pat.search(cl) for pat in pats):
        print(p.get("pid",0)); sys.exit(0)
sys.exit(1)
' 2>/dev/null
}

# _reload_pane_ready <pane_id> — bounded wait for the pane's shell to initialize.
_reload_pane_ready() {
  local pane="$1" tries="${HERD_RELOAD_PANE_POLLS:-25}" i=0 st
  while [ "$i" -lt "$tries" ]; do
    st="$(_reload_pane_state "$pane" "")"
    case "$st" in BARE|BUSY|RUN*) return 0 ;; esac
    sleep 0.2; i=$((i+1))
  done
  return 1
}

# _reload_pane_run_verified <pane_id> <command> <match> — readiness-gate, clear stale input, run,
# then STRICTLY verify the pane's foreground is a real invocation of <match>; retries the whole
# sequence once. Prints the visible PID on success; callers must treat failure loudly (see
# invisible-watcher note above). The pre-run ctrl+c/ctrl+u clears any typed-ahead junk a dead viewer
# left on the prompt, so `herdr pane run` can't concatenate onto it (2026-07-06 incident); the
# post-run gate is _reload_pane_alive (strict), not _reload_pane_state (loose), so a stale shell that
# merely echoes the script token never earns a false ✓.
_reload_pane_run_verified() {
  local pane="$1" cmd="$2" match="$3" vp="${HERD_RELOAD_VERIFY_POLLS:-25}" attempt i pid
  for attempt in 1 2; do
    _reload_pane_ready "$pane" || true   # bounded wait; the verify below is the real gate
    # Flush any pending/typed-ahead input BEFORE injecting the command: ctrl+c aborts a partial
    # line, ctrl+u kills the line buffer back to a clean prompt. Otherwise a dead viewer's buffered
    # keystrokes prepend onto our run and the shell rejects the malformed line — the viewer never
    # starts, yet the old loose poll reported success off the stale shell.
    herdr pane send-keys "$pane" ctrl+c ctrl+u >/dev/null 2>&1 || true
    herdr pane run "$pane" "$cmd" >/dev/null 2>&1 || true
    i=0
    while [ "$i" -lt "$vp" ]; do
      if pid="$(_reload_pane_alive "$pane" "$match")" && [ -n "$pid" ]; then
        printf '%s' "$pid"; return 0
      fi
      sleep 0.2; i=$((i+1))
    done
  done
  return 1
}

# _reload_neighbor <pane_id> <direction> → adjacent pane_id, or empty when none.
_reload_neighbor() {
  herdr pane neighbor --direction "$2" --pane "$1" 2>/dev/null | python3 -c '
import sys,json
try: n=json.load(sys.stdin)["result"]["neighbor"]
except Exception: n={}
print(n.get("neighbor_pane_id") or "", end="")
' 2>/dev/null || true
}

# _reload_split_pane <pane_id> <direction> <ratio> <cwd> → new pane_id, or empty.
_reload_split_pane() {
  herdr pane split "$1" --direction "$2" --ratio "$3" --cwd "$4" --no-focus 2>/dev/null | python3 -c '
import sys,json
try: print(json.load(sys.stdin)["result"]["pane"]["pane_id"], end="")
except Exception: pass
' 2>/dev/null || true
}

# _reload_tab_by_label lives in layout-reconcile.sh (sourced above) — shared with coordinator.sh.

# _reload_tab_create <workspace_id> <cwd> <label> → "tab_id pane_id", or empty.
_reload_tab_create() {
  herdr tab create --workspace "$1" --cwd "$2" --label "$3" --no-focus 2>/dev/null | python3 -c '
import sys,json
try: d=json.load(sys.stdin)["result"]
except Exception: d={}
print(d.get("tab",{}).get("tab_id",""), d.get("root_pane",{}).get("pane_id",""))
' 2>/dev/null || true
}

# _reload_agent_pane <agent_name> [tab_id] → pane_id of the named herdr agent, or empty.
_reload_agent_pane() {
  herdr agent list 2>/dev/null | NAME="$1" TAB="${2:-}" python3 -c '
import sys,json,os
try: ag=json.load(sys.stdin)["result"]["agents"]
except Exception: ag=[]
name=os.environ["NAME"]; tab=os.environ.get("TAB","")
print(next((a.get("pane_id","") for a in ag
            if a.get("name")==name and (not tab or a.get("tab_id")==tab)), ""), end="")
' 2>/dev/null || true
}

# _reload_any_agent_in_tab <tab_id> → pane_id of ANY herdr agent in that tab, or empty. Covers
# long-lived control rooms whose coordinator agent predates workspace-scoped naming (a legacy
# name), so the name-matched lookup above misses it but a tab-scoped one still anchors the layout.
_reload_any_agent_in_tab() {
  herdr agent list 2>/dev/null | TAB="$1" python3 -c '
import sys,json,os
try: ag=json.load(sys.stdin)["result"]["agents"]
except Exception: ag=[]
tab=os.environ.get("TAB","")
print(next((a.get("pane_id","") for a in ag if not tab or a.get("tab_id")==tab),""),end="")
' 2>/dev/null || true
}

# _reload_tab_panes and _reload_pane_role live in layout-reconcile.sh (sourced above) — the shared
# eyes-on-layout scan/classify primitives, consumed here and by layout_snapshot/layout_reconcile.

# ── .herd-panes per-workspace hint validation (issue #60, failure mode 3) ──────────────────────────
# Registry rows are `role pane_id tab_id [workspace_id]`. Readers historically trusted a row on the
# process-info of its raw pane_id alone — nothing asserted the pane still belonged to THIS workspace,
# and role was validated for existence but not for WHICH role the pane actually serves. The two
# helpers below close both gaps; every registry hint passes through them before it is adopted.

# _reg_pane_validated <registry_file> <role> <ws> → the row's pane_id IFF its recorded workspace_id
# equals <ws> OR the row is LEGACY (no workspace_id column = 'unknown', pre-#60 writers); empty when
# the row is stamped with a DIFFERENT workspace. This drops a foreign hint here so it can never be
# validated against a foreign pane by raw id. A legacy row falls through to the existing live-roster
# validation (its pane_id is still checked for existence/role downstream), preserving back-compat.
_reg_pane_validated() {
  [ -f "$1" ] || return 0
  awk -v role="$2" -v ws="$3" '
    $1==role {
      rws=(NF>=4 ? $4 : "")
      if (rws=="" || rws==ws) printf "%s", $2
      exit
    }' "$1" 2>/dev/null || true
}

# _reg_role_ok <pane_id> <claimed_role> → success UNLESS the pane is LIVE in a DIFFERENT concrete role
# than the registry claims (the drifted-registry misroute: a `watch` row pointing at a pane that is
# actually serving the backlog viewer, or vice versa). A bare/gone/busy pane is NOT rejected here —
# a bare pane is exactly what we want to reuse, and existence/foreground-match checks handle the rest.
# Roles map: watch↔watch, backlog↔backlog, coordinator-agent↔agent.
_reg_role_ok() {
  local live want="$2"
  live="$(_reload_pane_role "$1")"
  case "$live" in bare|gone|busy) return 0 ;; esac   # no concrete role conflict
  case "$want" in coordinator-agent) want="agent" ;; esac
  [ "$live" = "$want" ]
}

# _reload_move <pane> <tab> <direction> <target> <ratio> → echoes the move verdict:
#   yes       the move changed the layout
#   same_tab  herdr no-ops a move whose source pane already lives in <tab>
#   no|err    move rejected / call failed
_reload_move() {
  herdr pane move "$1" --tab "$2" --split "$3" --target-pane "$4" --ratio "$5" --no-focus 2>/dev/null \
    | python3 -c '
import sys,json
try: r=json.load(sys.stdin)["result"]
except Exception: print("err"); sys.exit(0)
print("yes" if r.get("changed") else (r.get("reason") or "no"))
' 2>/dev/null || printf 'err\n'
}

# _reload_reparent <pane> <tab> <direction> <target> <ratio> — re-parent a LIVE pane (its
# process keeps running) beside <target>. A same-tab move is a silent herdr no-op, so bounce the
# pane out to a throwaway tab (which auto-closes when emptied) and move it back — the recipe
# proven live for re-parenting within a tab. Returns 0 when the layout actually changed.
_reload_reparent() {
  local v; v="$(_reload_move "$@")"
  if [ "$v" = "same_tab" ]; then
    herdr pane move "$1" --new-tab --no-focus >/dev/null 2>&1 || true
    v="$(_reload_move "$@")"
  fi
  [ "$v" = "yes" ]
}

# _list_project_watchers — enumerate ONLY this project's watcher PIDs, one per line, de-duplicated:
# the union of (a) the lockfile PID (if alive) and (b) every process whose argv0 is EXACTLY
# $HERD_WATCH_ARGV0 (herd-watch-<slug>). argv0 is the attribution mechanism — see agent-watch.sh's
# startup re-exec: it is visible in ps/pgrep on every platform, unlike an env-var marker which modern
# macOS will not read back via ps. We match argv0 EXACTLY (the ps command's first token), NOT as a
# pgrep substring, so workspace "north" never captures "northern"'s watcher and "app" never captures
# "apple"'s. This finds lock-ABSENT strays too (the "no running watcher found while 2 alive" case).
# UNTAGGED legacy watchers (started before the argv0 marker existed) carry no marker and are NOT
# returned here — _stop_project_watcher still reaps those via its lsof cwd/lockfile fallback.
# Requires HERD_WATCHER_LOCK + HERD_WATCH_ARGV0 in scope (from .herd/config).
_list_project_watchers() {
  local pid argv0 seen=" "
  # (a) lockfile PID — the watcher this project recorded.
  if [ -f "$HERD_WATCHER_LOCK" ]; then
    pid="$(cat "$HERD_WATCHER_LOCK" 2>/dev/null || true)"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      printf '%s\n' "$pid"; seen="$seen$pid "
    fi
  fi
  # (b) argv0-tagged processes — exact first-token match on the ps command string. pgrep narrows the
  # candidate set (substring); the ps first-token check makes attribution exact and cross-platform.
  while IFS= read -r pid; do
    [ -n "$pid" ] || continue
    case "$seen" in *" $pid "*) continue ;; esac
    # `|| true`: ps on a since-dead pid exits non-zero and, under `set -euo pipefail`, would abort
    # this function before it reaches later (still-alive) pids — dropping real strays. Neutralize it.
    argv0="$(ps -o command= -p "$pid" 2>/dev/null | awk 'NR==1{print $1}' || true)"
    [ "$argv0" = "$HERD_WATCH_ARGV0" ] || continue
    printf '%s\n' "$pid"; seen="$seen$pid "
  done < <(pgrep -f "$HERD_WATCH_ARGV0" 2>/dev/null || true)
}

# _stop_project_watcher — stop THIS project's watcher(s) with the SIGTERM-poll-SIGKILL-abort
# sequence + duplicate-watcher guard. Requires HERD_WATCHER_LOCK, HERD_WATCH_ARGV0 and PROJECT_ROOT
# in scope (loaded from .herd/config). DIES (aborts the caller) when a watcher cannot be stopped,
# rather than risk spawning a duplicate over a still-live one. Reaps this project's lock-absent
# strays via the argv0 marker and NEVER touches a process whose argv0 belongs to another workspace.
# Prints one progress line per stopped watcher and says so when none were running. Shared by `herd
# reload` and `herd pane watch`. Honors HERD_RELOAD_SIGTERM_POLLS (default 50 × 0.2s = 10s) for the
# SIGTERM window.
_stop_project_watcher() {
  local lockpid="" killed=0

  # Primary: PID from the per-project lockfile.
  if [ -f "$HERD_WATCHER_LOCK" ]; then
    lockpid="$(cat "$HERD_WATCHER_LOCK" 2>/dev/null || true)"
    if [ -n "$lockpid" ] && kill -0 "$lockpid" 2>/dev/null; then
      kill "$lockpid" 2>/dev/null || true
      # Wait for SIGTERM: the watcher runs long foreground children synchronously
      # (herd-review.sh can take minutes; healthcheck; gh pr merge) and bash defers
      # the SIGTERM trap until the child returns. Poll up to HERD_RELOAD_SIGTERM_POLLS
      # × 0.2s (default 50 = 10s) before escalating. Tests may set a shorter value.
      local _tp="${HERD_RELOAD_SIGTERM_POLLS:-50}" i=0
      while [ "$i" -lt "$_tp" ] && kill -0 "$lockpid" 2>/dev/null; do
        sleep 0.2; i=$((i+1))
      done
      # Escalate to SIGKILL if still alive after the SIGTERM window.
      if kill -0 "$lockpid" 2>/dev/null; then
        say "  watcher PID $lockpid still alive — sending SIGKILL"
        kill -9 "$lockpid" 2>/dev/null || true
        local j=0
        while [ "$j" -lt 10 ] && kill -0 "$lockpid" 2>/dev/null; do
          sleep 0.2; j=$((j+1))
        done
      fi
      # Abort rather than spawn a duplicate watcher: on Linux, rm-ing the lockfile while
      # the old watcher still holds flock fd 9 lets a new exec 9> open a fresh inode and
      # succeed while the old owner keeps the unlinked one — defeating the singleton.
      if kill -0 "$lockpid" 2>/dev/null; then
        die "watcher PID $lockpid could not be stopped — aborting to prevent duplicate watchers (manual: kill -9 $lockpid)"
      fi
      killed=$((killed+1))
      say "  stopped watcher PID $lockpid (lockfile)"
    fi
    # Remove the lockfile ONLY after the old watcher is confirmed gone — a live watcher's
    # EXIT trap (no-flock path) runs rm on this path and must not clobber a successor's lock.
    rm -f "$HERD_WATCHER_LOCK" 2>/dev/null || true
  fi

  # Strays, phase 1 — THIS project's watchers by ARGV0 attribution (issue #60). _list_project_watchers
  # returns the union of the lockfile PID and every process whose argv0 == $HERD_WATCH_ARGV0. This
  # reaps lock-ABSENT strays too (the "no running watcher found while 2 alive" case) and, because the
  # argv0 is per-workspace, is provably inert for a sibling project's watcher even though both run the
  # identical engine script.
  local wpid
  while IFS= read -r wpid; do
    [ -n "$wpid" ] || continue
    [ "$wpid" = "$lockpid" ] && continue  # already handled by the lockfile path above
    kill "$wpid" 2>/dev/null || true
    killed=$((killed+1))
    say "  stopped stray watcher PID $wpid (argv0 $HERD_WATCH_ARGV0)"
    journal_append watcher_reaped pid "$wpid" workspace "$WORKSPACE_NAME" via argv0
  done < <(_list_project_watchers)

  # Strays, phase 2 — UNTAGGED legacy watchers (started before the argv0 marker existed) show as
  # `bash .../agent-watch.sh` with no marker, so phase 1 misses them. Reap those too, but ONLY when
  # provably ours: cwd == PROJECT_ROOT (no-flock / macOS) or holding our lockfile open (flock /
  # Linux). CRITICAL: a process carrying a FOREIGN herd-watch-* argv0 is another workspace's tagged
  # watcher and is NEVER touched here — the argv0 gate below is the cross-project kill guard.
  local stray
  while IFS= read -r stray; do
    [ -n "$stray" ] || continue
    [ "$stray" = "$lockpid" ] && continue  # already handled above
    local sargv0; sargv0="$(ps -o command= -p "$stray" 2>/dev/null | awk 'NR==1{print $1}' || true)"
    [ "$sargv0" = "$HERD_WATCH_ARGV0" ] && continue   # already reaped in phase 1 (our tagged watcher)
    case "$sargv0" in herd-watch-*) continue ;; esac  # FOREIGN tagged watcher — never touch
    local is_ours=0
    if command -v lsof >/dev/null 2>&1; then
      # flock case: watcher holds fd 9 on the lockfile — lsof shows it.
      if lsof -p "$stray" 2>/dev/null | grep -qF "$HERD_WATCHER_LOCK"; then
        is_ours=1
      # no-flock case: check the process's current working directory.
      elif lsof -p "$stray" -a -d cwd 2>/dev/null | awk 'NR>1{print $NF}' | grep -qxF "$PROJECT_ROOT"; then
        is_ours=1
      fi
    fi
    # Linux /proc fallback when lsof is absent.
    if [ "$is_ours" -eq 0 ] && [ -L "/proc/$stray/cwd" ]; then
      local stray_cwd; stray_cwd="$(readlink -f "/proc/$stray/cwd" 2>/dev/null || true)"
      [ "$stray_cwd" = "$PROJECT_ROOT" ] && is_ours=1
    fi
    if [ "$is_ours" -eq 1 ]; then
      kill "$stray" 2>/dev/null || true
      killed=$((killed+1))
      say "  stopped stray watcher PID $stray (legacy · cwd match)"
      journal_append watcher_reaped pid "$stray" workspace "$WORKSPACE_NAME" via legacy-cwd
    fi
  done < <(pgrep -f "agent-watch.sh" 2>/dev/null || true)

  [ "$killed" -eq 0 ] && say "  no running watcher found"
  return 0
}

cmd_reload() {
  local root; root="$(pwd)"
  local cfg="$root/.herd/config"
  [ -f "$cfg" ] || die "no .herd/config at $root — run 'herd init' first"

  say "${c_bold}herd reload${c_rst} — rebuilding the control room around the coordinator (watcher + backlog pane + skill)"
  say ""

  # Load config: gives us WORKSPACE_NAME, WORKTREES_DIR, HERD_WATCHER_LOCK, PROJECT_ROOT, etc.
  export HERD_CONFIG_FILE="$cfg"
  # shellcheck source=/dev/null
  . "$SCRIPTS_DIR/herd-config.sh"
  # Side-effect-free source: defines _herd_soft_dep_startup_notice for the opt-in soft-dep reminder
  # printed at the end of the summary below (no-op unless DOCTOR_STARTUP_HINT=on).
  # shellcheck source=/dev/null
  . "$SCRIPTS_DIR/herd-preflight.sh"

  # 1. Stop this project's watcher(s) — SIGTERM-poll-SIGKILL-abort + duplicate-watcher guard.
  _stop_project_watcher
  say ""

  # 2. Re-render the coordinator skill from the (possibly updated) .herd/config.
  local skill; skill="$(render_skill "$root" "$cfg")"
  ok "re-rendered coordinator skill → $skill"
  say ""

  # 3. Rebuild the control room around the coordinator: relaunch the watcher and ensure the
  # pinned backlog pane. The coordinator tab/agent is NEVER closed or restarted — `herd reload`
  # is typically issued FROM the coordinator, so recycling it (as coordinator.sh's full rebuild
  # does) would kill the session that ran this command.
  #
  # Launch knobs (hermetic tests):
  #   HERD_RELOAD_SKIP_LAUNCH=1         suppress every launch (herdr + background fallback)
  #   HERD_RELOAD_SKIP_LAUNCH=fallback  suppress only the background fallback, so tests can
  #                                     exercise the herdr path without spawning a real watcher
  local watch_script="$SCRIPTS_DIR/herd-watch.sh"
  local backlog_script="$SCRIPTS_DIR/backlog-view.sh"
  local watch_match="agent-watch.sh|herd-watch.sh"   # herd-watch.sh execs agent-watch.sh
  local launch_desc="background" watch_pid="" watch_pane=""
  local backlog_desc="not managed (herdr unavailable)"
  local herdr_attempted=0
  # rebuild_desc — the ALWAYS-printed verdict distinguishing a full control-room rebuild from a
  # skill-only + headless-watcher fallback, so `herd reload`'s outcome is never ambiguous (issue #60,
  # comment 1). Set to the rebuild summary once the workspace resolves; the fail-loud branches below
  # leave it as this default so the final summary names exactly what did NOT happen.
  local rebuild_desc="NOT rebuilt — skill re-rendered + watcher headless only (see warnings above)"

  if [ "${HERD_RELOAD_SKIP_LAUNCH:-}" = "1" ]; then
    launch_desc="skipped (HERD_RELOAD_SKIP_LAUNCH=1)"
    backlog_desc="skipped (HERD_RELOAD_SKIP_LAUNCH=1)"
    rebuild_desc="skipped (HERD_RELOAD_SKIP_LAUNCH=1)"
  elif ! command -v herdr >/dev/null 2>&1; then
    # herdr NOT installed → we cannot manage panes at all. Give this its OWN line (distinct from a
    # workspace-not-found miss) instead of sliding silently into the headless background relaunch.
    warn "herd reload: herdr not found — cannot manage panes; control room NOT rebuilt, watcher will be relaunched headless (no visible console)"
  else
    # herdr IS available. Resolve THIS project's workspace by exact label==WORKSPACE_NAME. Capture the
    # raw list AND its exit status SEPARATELY, so a herdr CLI/parse error is distinguishable from a
    # genuine no-match — the old `2>/dev/null || true` collapsed both into "empty $ws", turning EVERY
    # failure (herdr error, workspace closed, label mismatch) into a silent headless relaunch with no
    # message naming the cause (issue #60, comment 1). Each case below FAILS LOUD.
    local ws="" ws_list="" ws_rc=0
    ws_list="$(herdr workspace list 2>/dev/null)" || ws_rc=$?
    if [ "$ws_rc" -ne 0 ]; then
      warn "herd reload: 'herdr workspace list' failed (exit $ws_rc) — cannot resolve workspace '${WORKSPACE_NAME}'; control room NOT rebuilt, watcher relaunched headless"
    else
      ws="$(printf '%s' "$ws_list" | LABEL="$WORKSPACE_NAME" python3 -c \
'import sys,json,os
try: d=json.load(sys.stdin)
except Exception: d={}
ws=(d.get("result") or {}).get("workspaces") or []
print(next((w["workspace_id"] for w in ws if w.get("label")==os.environ.get("LABEL","")), ""))
' 2>/dev/null || true)"
      if [ -z "$ws" ]; then
        # FAIL LOUD: herdr is up and the list parsed, but no OPEN workspace carries our label. Name
        # the expected label and the observed open labels so the mismatch is unmistakable.
        local open_labels; open_labels="$(printf '%s' "$ws_list" | python3 -c \
'import sys,json
try: d=json.load(sys.stdin)
except Exception: d={}
ws=(d.get("result") or {}).get("workspaces") or []
print(", ".join(str(w.get("label","?")) for w in ws) or "none")
' 2>/dev/null || printf 'unknown')"
        warn "herd reload: no herdr workspace labelled '${WORKSPACE_NAME}' (open: ${open_labels}) — control room NOT rebuilt. Is the workspace open and labelled to match WORKSPACE_NAME? (watcher relaunched headless)"
      fi
    fi

    if [ -n "$ws" ]; then
      herdr_attempted=1
      rebuild_desc="rebuilt around the coordinator (herdr workspace ${WORKSPACE_NAME})"
      # Bring THIS project's workspace forward before rebuilding it. Every herdr call below is
      # --no-focus (so the rebuild never yanks focus mid-flight), which means a reload launched
      # while a SIBLING project's workspace is focused would otherwise rebuild our control room
      # entirely off-screen — the user sees nothing change, or just one pane (the watcher's
      # pane run) poke through the other project's layout, and concludes reload "did nothing"
      # or "grabbed a different project's panes". coordinator.sh focuses for the same reason.
      herdr workspace focus "$ws" >/dev/null 2>&1 || true
      # `herd reload` must CONVERGE to the canonical control room from ANY starting context —
      # run inside the coordinator claude session, from the coordinator pane's bare shell after
      # Ctrl+C, or from a brand-new external terminal. The recipe: SNAPSHOT the live layout,
      # ADOPT panes already serving a role, repair GEOMETRY, REPAINT width-sensitive viewers,
      # and rewrite the REGISTRY from the OBSERVED state. The registry and neighbor queries are
      # only HINTS — every one is validated against the live pane roster before it is trusted.
      backlog_desc=""

      # Registry rows (coordinator.sh / prior reloads) — hints, validated below. Each pane_id is
      # taken ONLY when the row's recorded workspace_id matches this workspace (or the row is a legacy
      # untagged one); a row stamped with a DIFFERENT workspace is dropped here (issue #60).
      local reg_apane="" reg_wpane="" reg_bpane=""
      if [ -f "$WORKTREES_DIR/.herd-panes" ]; then
        reg_apane="$(_reg_pane_validated "$WORKTREES_DIR/.herd-panes" coordinator-agent "$ws")"
        reg_wpane="$(_reg_pane_validated "$WORKTREES_DIR/.herd-panes" watch "$ws")"
        reg_bpane="$(_reg_pane_validated "$WORKTREES_DIR/.herd-panes" backlog "$ws")"
      fi

      local coord_tab="" agent_pane="" agent_live=0 bPane="" wPane="" geom_changed=0
      coord_tab="$(_reload_tab_by_label "$ws" "$HERD_TAB_COORDINATOR")"

      if [ -z "$coord_tab" ]; then
        # ═ Coordinator tab is entirely gone → build the full canonical control room fresh.
        # Reachable only when NOT running inside the control room, so a clean build is safe.
        # Shape (coordinator.sh): [ backlog (left) | coordinator ⟂ watch (right) ]. Backlog is
        # the root pane, so splitting right then down yields the canonical geometry with no
        # swap. Per reload's invariant we NEVER start the coordinator agent — its pane is left
        # bare with a loud hint below.
        say "  no coordinator tab in workspace ${WORKSPACE_NAME} — building a fresh canonical control room"
        local created=""
        created="$(_reload_tab_create "$ws" "$root" "$HERD_TAB_COORDINATOR")"
        read -r coord_tab bPane <<< "$created"
        if [ -n "${bPane:-}" ]; then
          if _reload_pane_run_verified "$bPane" "bash $backlog_script" "backlog-view.sh" >/dev/null; then
            backlog_desc="pane $bPane · rebuilt ✓"
          else
            backlog_desc="pane $bPane · NOT visible ✗"
            warn "backlog-view did not appear in pane $bPane"
          fi
          agent_pane="$(_reload_split_pane "$bPane" right 0.5 "$root")"
          if [ -n "$agent_pane" ]; then
            wPane="$(_reload_split_pane "$agent_pane" down 0.72 "$root")"
            geom_changed=1
            if [ -n "$wPane" ]; then
              watch_pane="$wPane"
              if _reload_pane_run_verified "$wPane" "bash $watch_script" "$watch_match" >/dev/null; then
                launch_desc="pane below coordinator"
                local _lp="${HERD_RELOAD_LOCKPID_POLLS:-10}" _kk=0
                while [ "$_kk" -lt "$_lp" ] && [ ! -f "$HERD_WATCHER_LOCK" ]; do
                  sleep 0.2; _kk=$((_kk+1))
                done
                [ -f "$HERD_WATCHER_LOCK" ] && watch_pid="$(cat "$HERD_WATCHER_LOCK" 2>/dev/null || true)"
              fi
            fi
          fi
        else
          warn "could not create the coordinator tab ${HERD_TAB_COORDINATOR}"
        fi
      else
        # ═ Coordinator tab exists → SNAPSHOT / ADOPT / GEOMETRY / REPAINT inside it.

        # Fold away stray standalone control-room tabs left by earlier bad reloads; their roles
        # are re-established inside the coordinator tab below (backlog is stateless, the watcher
        # was already stopped in step 1).
        layout_fold_stray_tabs "$ws" "$WORKSPACE_NAME"

        # HERD-114 eyes sweep: flag single-pane drainer/reviewer tabs a crash stranded as a bare shell
        # (agent process gone, tab+pane persist). INFORMATIONAL ONLY — surfaced for a human, never
        # auto-closed here (a false close could kill a legitimately-quiet agent tab). Best-effort.
        local _st_tab _st_label _st_role
        while IFS="$(printf '\t')" read -r _st_tab _st_label _st_role; do
          [ -n "$_st_tab" ] || continue
          warn "stale ${_st_label} tab (${_st_role} — agent session dead) left by a crash: tab ${_st_tab} · retire with 'herdr tab close ${_st_tab}'"
        done <<< "$(layout_stale_agent_tabs "$ws" 2>/dev/null || true)"

        # SNAPSHOT: classify every pane in the coordinator tab by its foreground process (the shared
        # eyes-on-layout scan). The live roster — not the registry — is ground truth. Duplicate
        # backlog viewers (a stale registry once split a SECOND one beside a still-live viewer) are
        # collected for closing.
        local p first_backlog="" dup_backlogs="" cand_panes="" _role
        while IFS=$'\t' read -r _role p; do
          [ -n "$p" ] || continue
          case "$_role" in
            backlog) if [ -z "$first_backlog" ]; then first_backlog="$p"; else dup_backlogs="$dup_backlogs $p"; fi ;;
            *)       cand_panes="$cand_panes $p" ;;
          esac
        done <<< "$(layout_snapshot "$ws" "$coord_tab")"

        # ANCHOR: the coordinator pane is NEVER moved, closed, or restarted — it may be the very
        # shell running this reload. Resolve, in order: a live agent in the tab (authoritative;
        # also catches legacy agent names) → the registry coordinator-agent row (validated to
        # still exist; a BUSY anchor is fine, reload never runs anything in it) → inference from
        # the tab's non-backlog panes. A live agent only REFINES which pane is the coordinator's;
        # its absence NEVER gates whether the control room exists.
        agent_pane="$(_reload_agent_pane "$HERD_AGENT_COORDINATOR" "$coord_tab")"
        [ -z "$agent_pane" ] && agent_pane="$(_reload_any_agent_in_tab "$coord_tab")"
        if [ -n "$agent_pane" ]; then
          agent_live=1
        else
          if [ -n "$reg_apane" ]; then
            case "$(_reload_pane_state "$reg_apane" "")" in GONE) : ;; *) agent_pane="$reg_apane" ;; esac
          fi
          if [ -z "$agent_pane" ]; then
            for p in $cand_panes; do
              [ "$p" = "$reg_wpane" ] && continue
              agent_pane="$p"; break
            done
          fi
        fi

        # ADOPT backlog: reuse an already-live viewer instead of splitting a duplicate. Prefer an
        # observed viewer; else the registry pane if it still runs the viewer (RUN) or is a dead
        # console (BARE, relaunched below).
        if [ -n "$first_backlog" ]; then
          bPane="$first_backlog"
          backlog_desc="pane $bPane · already live ✓ (adopted)"
        elif [ -n "$reg_bpane" ] && [ "$reg_bpane" != "$agent_pane" ] && _reg_role_ok "$reg_bpane" backlog; then
          # Adopt the registry backlog pane only when it is not the anchor and is not LIVE in a
          # different role (a `backlog` row that actually points at the watch/coordinator pane is
          # dropped here → recreated below at canonical geometry).
          case "$(_reload_pane_state "$reg_bpane" "backlog-view.sh")" in
            RUN*) bPane="$reg_bpane"; backlog_desc="pane $bPane · already live ✓" ;;
            BARE) bPane="$reg_bpane" ;;
          esac
        fi
        # Close DUPLICATE backlog viewers (the stale-registry double-split bug).
        for p in $dup_backlogs; do
          herdr pane close "$p" >/dev/null 2>&1 || true
        done

        if [ -n "$agent_pane" ]; then
          # BACKLOG pane: if not yet adopted, try the neighbor to the coordinator's LEFT, else
          # split the coordinator and swap the new pane into the LEFT slot — the canonical
          # [ backlog | coordinator ] shape.
          if [ -z "$bPane" ]; then
            local nb; nb="$(_reload_neighbor "$agent_pane" left)"
            if [ -n "$nb" ]; then
              case "$(_reload_pane_state "$nb" "backlog-view.sh")" in
                RUN*) bPane="$nb"; backlog_desc="pane $bPane · already live ✓" ;;
                BARE) bPane="$nb" ;;
              esac
            fi
          fi
          if [ -z "$bPane" ]; then
            bPane="$(_reload_split_pane "$agent_pane" right 0.5 "$root")"
            if [ -n "$bPane" ]; then
              herdr pane swap --source-pane "$bPane" --target-pane "$agent_pane" >/dev/null 2>&1 || true
              geom_changed=1
              if _reload_pane_run_verified "$bPane" "bash $backlog_script" "backlog-view.sh" >/dev/null; then
                backlog_desc="pane $bPane · recreated ✓"
              else
                backlog_desc="pane $bPane · NOT visible ✗"
                warn "backlog-view did not appear in recreated pane $bPane"
              fi
            else
              backlog_desc="FAILED to create pane ✗"
              warn "could not create a backlog pane beside the coordinator"
            fi
          fi
          # Adopted-but-dead viewer console → relaunch it in place.
          if [ -n "$bPane" ] && [ -z "$backlog_desc" ]; then
            if _reload_pane_run_verified "$bPane" "bash $backlog_script" "backlog-view.sh" >/dev/null; then
              backlog_desc="pane $bPane · relaunched ✓"
            else
              backlog_desc="pane $bPane · NOT visible ✗"
              warn "backlog-view did not appear in pane $bPane — inspect it manually"
            fi
          fi

          # WATCH pane: adopt the registry pane, else the neighbor BELOW the coordinator, else
          # split a fresh one below it (ratio 0.72). BARE/RUN are reusable; BUSY/GONE never are.
          # Never adopt the anchor pane or a pane LIVE in a different role as the watch (the exact
          # drift from the incident: a `watch` row pointing at the coordinator pane id) — drop it and
          # recreate below.
          if [ -n "$reg_wpane" ] && [ "$reg_wpane" != "$agent_pane" ] && _reg_role_ok "$reg_wpane" watch; then
            case "$(_reload_pane_state "$reg_wpane" "$watch_match")" in
              BARE|RUN*) wPane="$reg_wpane" ;;
            esac
          fi
          if [ -z "$wPane" ]; then
            local nbd; nbd="$(_reload_neighbor "$agent_pane" down)"
            if [ -n "$nbd" ]; then
              case "$(_reload_pane_state "$nbd" "$watch_match")" in
                BARE|RUN*) wPane="$nbd" ;;
              esac
            fi
          fi
          if [ -z "$wPane" ]; then
            wPane="$(_reload_split_pane "$agent_pane" down 0.72 "$root")"
            [ -n "$wPane" ] && geom_changed=1
          fi

          # GEOMETRY repair: the watch pane must sit directly BELOW the coordinator, not span the
          # full bottom width (which would rob the backlog of its full-height left column). If the
          # backlog's downward neighbor IS the watch pane, the watch spans the bottom → re-parent
          # it below the coordinator (bounce-out/in handles the same-tab no-op).
          if [ -n "$wPane" ] && [ -n "$bPane" ]; then
            local bdown; bdown="$(_reload_neighbor "$bPane" down)"
            if [ -n "$bdown" ] && [ "$bdown" = "$wPane" ]; then
              _reload_reparent "$wPane" "$coord_tab" down "$agent_pane" 0.72 && geom_changed=1
            fi
          fi

          # Drive the watcher into the watch pane (verified; the stray/zombie guard is below).
          if [ -n "$wPane" ]; then
            watch_pane="$wPane"
            if _reload_pane_run_verified "$wPane" "bash $watch_script" "$watch_match" >/dev/null; then
              launch_desc="pane below coordinator"
              local _lp="${HERD_RELOAD_LOCKPID_POLLS:-10}" _kk=0
              while [ "$_kk" -lt "$_lp" ] && [ ! -f "$HERD_WATCHER_LOCK" ]; do
                sleep 0.2; _kk=$((_kk+1))
              done
              [ -f "$HERD_WATCHER_LOCK" ] && watch_pid="$(cat "$HERD_WATCHER_LOCK" 2>/dev/null || true)"
            fi
          fi
        else
          warn "coordinator tab ${coord_tab} has no resolvable coordinator pane — skipping layout"
        fi
      fi

      # REPAINT: width-sensitive viewers render lazily — backlog-view.sh reads `tput cols` per
      # frame but only repaints on an mtime/banner change, so it stays at a stale width after a
      # geometry change. Touch the backlog file to force a correct-width repaint.
      if [ "$geom_changed" -eq 1 ] && [ -n "${BACKLOG_FILE:-}" ] && [ -f "$PROJECT_ROOT/$BACKLOG_FILE" ]; then
        touch "$PROJECT_ROOT/$BACKLOG_FILE" 2>/dev/null || true
      fi

      # COORDINATOR AGENT: reload never starts or hijacks it. If none is live, everything else is
      # restored and we tell the human exactly how to bring it back — never type into a shell they
      # may be using.
      if [ "$agent_live" -eq 0 ] && [ -n "$agent_pane" ]; then
        warn "no coordinator agent is live in pane ${agent_pane} — start it yourself:  claude ${COORDINATOR_CMD}"
      fi

      # REGISTRY: rewrite from the OBSERVED final state on every path via the shared writer,
      # stamping each row with the resolved workspace_id ($ws) so a later reader can drop a hint
      # that names a foreign workspace (issue #60). The writer mkdir -p's — WORKTREES_DIR may not
      # exist yet on a control room that predates the first feature build.
      layout_write_registry "$WORKTREES_DIR/.herd-panes" "$ws" "$coord_tab" \
        "${agent_pane:-}" "${bPane:-}" "${wPane:-}"
    fi
  fi

  # Never leave a silent zombie: if pane verification failed, a detached watcher may still
  # be running invisibly (it grabs the lockfile on start). Say so LOUDLY instead of silently
  # double-spawning — the singleton in agent-watch.sh would refuse the duplicate anyway.
  if [ "$launch_desc" = "background" ] && [ "$herdr_attempted" -eq 1 ]; then
    local zpid=""
    [ -f "$HERD_WATCHER_LOCK" ] && zpid="$(cat "$HERD_WATCHER_LOCK" 2>/dev/null || true)"
    if [ -n "$zpid" ] && kill -0 "$zpid" 2>/dev/null; then
      launch_desc="DETACHED — running, but NOT visible in pane ${watch_pane:-?}"
      watch_pid="$zpid"
      warn "watcher PID $zpid is RUNNING but NOT visible in pane ${watch_pane:-?} — its pane run detached from the tty; re-run 'herd reload' or kill $zpid and inspect the pane"
    fi
  fi

  if [ "$launch_desc" = "background" ]; then
    if [ "${HERD_RELOAD_SKIP_LAUNCH:-}" = "fallback" ]; then
      launch_desc="NOT relaunched (fallback suppressed)"
      warn "watcher NOT relaunched — herdr pane launch failed and the background fallback is suppressed (HERD_RELOAD_SKIP_LAUNCH=fallback)"
    else
      [ "$herdr_attempted" -eq 1 ] && warn "herdr pane launch failed verification — relaunching the watcher in the BACKGROUND (no visible console)"
      ( cd "$PROJECT_ROOT" && HERD_CONFIG_FILE="$cfg" nohup bash "$watch_script" >/dev/null 2>&1 & )
      say "  watcher relaunched in background"
      # agent-watch.sh writes its PID to the lockfile on start — bounded poll for the summary.
      local k=0
      while [ "$k" -lt 10 ] && [ ! -f "$HERD_WATCHER_LOCK" ]; do sleep 0.2; k=$((k+1)); done
      [ -f "$HERD_WATCHER_LOCK" ] && watch_pid="$(cat "$HERD_WATCHER_LOCK" 2>/dev/null || true)"
    fi
  fi

  # 4. Resolve and display the effective merge policy so the human can confirm.
  local effective_policy
  case "${MERGE_POLICY:-}" in
    auto|approve|observe) effective_policy="$MERGE_POLICY" ;;
    *)
      case "${WATCHER_AUTOMERGE:-true}" in
        false|no|off|0) effective_policy="approve" ;;
        *)              effective_policy="auto" ;;
      esac ;;
  esac

  # 5. Per-component summary — one line per rebuilt piece so the human can confirm state.
  local wsum="$launch_desc"
  [ -n "$watch_pid" ] && wsum="$wsum · pid $watch_pid"
  case "$launch_desc" in
    "pane below coordinator"|"herdr tab"*) wsum="$wsum · pane $watch_pane · visible ✓" ;;
  esac

  # Journal the outcome of each rebuilt component so a post-mortem can see when/what a reload touched.
  journal_append reload_outcome component skill   result rendered
  journal_append reload_outcome component watcher result "$launch_desc"
  journal_append reload_outcome component backlog result "$backlog_desc"
  journal_append reload_outcome component control_room result "$rebuild_desc"

  say ""
  ok "reload complete"
  say "  workspace:     $WORKSPACE_NAME"
  say "  control room:  $rebuild_desc"
  say "  skill:         $skill"
  say "  watcher:       $wsum"
  say "  backlog:       $backlog_desc"
  say "  MERGE_POLICY:  ${c_bold}$effective_policy${c_rst}"

  # PROACTIVE soft-dep surfacing (HERD-45) — opt-in via DOCTOR_STARTUP_HINT; a no-op (byte-identical
  # summary) unless it is "on". Surfaces any missing soft dep + the `herd doctor` fix at startup.
  _herd_soft_dep_startup_notice
}

# ── herd pane <watch|backlog|coordinator>: single-pane restart shortcuts ─────────────────────────
# Re-run ONE control-room pane in place without a full `herd reload`. Each reuses the reload helpers
# (observe-before-mutate pane plumbing) and the `.herd-panes` role registry, rewrites that registry
# from the OBSERVED final state, and prints a one-line per-component outcome like cmd_reload's
# summary. All refuse when no project `.herd/config` resolves — never the engine dogfood fallback.

# _pane_agent_start <name> <workspace> <cwd> <tab> <direction> → new pane_id, or empty. Reuses
# coordinator.sh's agent-start invocation so the relaunched coordinator runs the same skill.
_pane_agent_start() {
  herd_driver_launch_agent name="$1" workspace="$2" cwd="$3" tab="$4" split="$5" focus=yes \
    pointer="$COORDINATOR_CMD" 2>/dev/null \
    | python3 -c '
import sys,json
try: print(json.load(sys.stdin)["result"]["agent"]["pane_id"], end="")
except Exception: pass
' 2>/dev/null || true
}

# _pane_write_registry <agent> <backlog> <watch> — rewrite $WORKTREES_DIR/.herd-panes from the
# OBSERVED final pane IDs (empty rows omitted) via the shared writer. All three rows carry the
# coordinator tab id and the resolved workspace_id (4th column) so a later reader can drop a hint
# naming a foreign workspace.
_pane_write_registry() {
  layout_write_registry "$WORKTREES_DIR/.herd-panes" "$PANE_WS" "$PANE_COORD_TAB" "$1" "$2" "$3"
}

# _pane_init — shared preamble for the pane subcommands. Resolves and PINS this project's
# .herd/config (refusing the dogfood fallback), requires herdr, resolves the workspace +
# coordinator tab + anchor (coordinator) pane, and reads the .herd-panes registry rows. Dies with a
# clear message when the control room is not up. Sets PANE_* globals for the caller:
#   PANE_ROOT PANE_CFG PANE_WS PANE_COORD_TAB PANE_AGENT PANE_AGENT_LIVE PANE_REG_A/W/B
_pane_init() {
  PANE_ROOT="$(pwd)"
  PANE_CFG="$PANE_ROOT/.herd/config"
  [ -f "$PANE_CFG" ] || die "no .herd/config at $PANE_ROOT — run 'herd init' first (refusing the engine dogfood config)"
  export HERD_CONFIG_FILE="$PANE_CFG"
  # shellcheck source=/dev/null
  . "$SCRIPTS_DIR/herd-config.sh"

  command -v herdr >/dev/null 2>&1 \
    || die "herdr not on PATH — 'herd pane' needs the herdr control room (launch it: bash $SCRIPTS_DIR/coordinator.sh)"

  # Resolve THIS project's workspace, distinguishing a herdr CLI/parse error from a genuine no-match
  # and — on a miss — naming the observed open labels (mirrors cmd_reload's fail-loud, issue #60).
  local _ws_list="" _ws_rc=0
  _ws_list="$(herdr workspace list 2>/dev/null)" || _ws_rc=$?
  [ "$_ws_rc" -eq 0 ] \
    || die "'herdr workspace list' failed (exit $_ws_rc) — cannot resolve workspace '$WORKSPACE_NAME'; is the herdr control room running? (launch it: bash $SCRIPTS_DIR/coordinator.sh)"
  PANE_WS="$(printf '%s' "$_ws_list" | LABEL="$WORKSPACE_NAME" python3 -c '
import sys,json,os
try: d=json.load(sys.stdin)
except Exception: d={}
ws=(d.get("result") or {}).get("workspaces") or []
print(next((w["workspace_id"] for w in ws if w.get("label")==os.environ.get("LABEL","")), ""), end="")
' 2>/dev/null || true)"
  if [ -z "$PANE_WS" ]; then
    local _open; _open="$(printf '%s' "$_ws_list" | python3 -c '
import sys,json
try: d=json.load(sys.stdin)
except Exception: d={}
ws=(d.get("result") or {}).get("workspaces") or []
print(", ".join(str(w.get("label","?")) for w in ws) or "none")
' 2>/dev/null || printf 'unknown')"
    die "no herdr workspace labelled '$WORKSPACE_NAME' (open: ${_open}) — launch the control room first: bash $SCRIPTS_DIR/coordinator.sh"
  fi

  PANE_COORD_TAB="$(_reload_tab_by_label "$PANE_WS" "$HERD_TAB_COORDINATOR")"
  [ -n "$PANE_COORD_TAB" ] \
    || die "no coordinator tab in workspace '$WORKSPACE_NAME' — run 'herd reload' or coordinator.sh to build the control room"

  # Registry rows (coordinator.sh / prior reloads) — hints, validated against the live roster below.
  # Each pane_id is taken ONLY when the row's recorded workspace_id matches this workspace (or the
  # row is a legacy untagged one); a row stamped with a DIFFERENT workspace is dropped (issue #60).
  PANE_REG_A=""; PANE_REG_W=""; PANE_REG_B=""
  if [ -f "$WORKTREES_DIR/.herd-panes" ]; then
    PANE_REG_A="$(_reg_pane_validated "$WORKTREES_DIR/.herd-panes" coordinator-agent "$PANE_WS")"
    PANE_REG_W="$(_reg_pane_validated "$WORKTREES_DIR/.herd-panes" watch "$PANE_WS")"
    PANE_REG_B="$(_reg_pane_validated "$WORKTREES_DIR/.herd-panes" backlog "$PANE_WS")"
  fi

  # ANCHOR: resolve the coordinator pane — a live agent in the tab (authoritative; also catches
  # legacy agent names) → the registry coordinator-agent row (validated to still exist) →
  # inference from the tab's non-backlog panes. This anchors watch/backlog placement and is the
  # pane `herd pane coordinator` relaunches.
  PANE_AGENT=""; PANE_AGENT_LIVE=0
  PANE_AGENT="$(_reload_agent_pane "$HERD_AGENT_COORDINATOR" "$PANE_COORD_TAB")"
  [ -z "$PANE_AGENT" ] && PANE_AGENT="$(_reload_any_agent_in_tab "$PANE_COORD_TAB")"
  if [ -n "$PANE_AGENT" ]; then
    PANE_AGENT_LIVE=1
  elif [ -n "$PANE_REG_A" ]; then
    case "$(_reload_pane_state "$PANE_REG_A" "")" in GONE) : ;; *) PANE_AGENT="$PANE_REG_A" ;; esac
  fi
  if [ -z "$PANE_AGENT" ]; then
    local p
    for p in $(_reload_tab_panes "$PANE_WS" "$PANE_COORD_TAB"); do
      [ "$p" = "$PANE_REG_W" ] && continue
      [ "$(_reload_pane_role "$p")" = "backlog" ] && continue
      PANE_AGENT="$p"; break
    done
  fi
  [ -n "$PANE_AGENT" ] \
    || die "no coordinator pane in tab $PANE_COORD_TAB — run 'herd reload' to rebuild the control room"
  return 0
}

cmd_pane_watch() {
  _pane_init
  say "${c_bold}herd pane watch${c_rst} — restarting the watcher in its pane"
  say ""

  local watch_script="$SCRIPTS_DIR/herd-watch.sh"
  local watch_match="agent-watch.sh|herd-watch.sh"   # herd-watch.sh execs agent-watch.sh

  # 1. Stop this project's watcher (SIGTERM-poll-SIGKILL-abort; dies if unstoppable).
  _stop_project_watcher
  say ""

  # 2. Resolve the watch pane: reuse the registered pane (now BARE, its watcher just stopped),
  #    else the coordinator's downward neighbor, else recreate it below the coordinator (0.72).
  #    Never adopt the anchor pane or a pane LIVE in a different role as the watch (issue #60).
  local wPane="" recreated=0 geom_changed=0
  if [ -n "$PANE_REG_W" ] && [ "$PANE_REG_W" != "$PANE_AGENT" ] && _reg_role_ok "$PANE_REG_W" watch; then
    case "$(_reload_pane_state "$PANE_REG_W" "$watch_match")" in
      BARE|RUN*) wPane="$PANE_REG_W" ;;
    esac
  fi
  if [ -z "$wPane" ]; then
    local nbd; nbd="$(_reload_neighbor "$PANE_AGENT" down)"
    if [ -n "$nbd" ]; then
      case "$(_reload_pane_state "$nbd" "$watch_match")" in
        BARE|RUN*) wPane="$nbd" ;;
      esac
    fi
  fi
  if [ -z "$wPane" ]; then
    wPane="$(_reload_split_pane "$PANE_AGENT" down 0.72 "$PANE_ROOT")"
    [ -n "$wPane" ] && { recreated=1; geom_changed=1; }
  fi

  # 3. Run the watcher in the pane, verified. On a detached run the watcher still grabs the
  #    lockfile — surface that loudly rather than double-spawning (the singleton refuses anyway).
  local wsum="FAILED ✗" watch_pid=""
  if [ -n "$wPane" ]; then
    if _reload_pane_run_verified "$wPane" "bash $watch_script" "$watch_match" >/dev/null; then
      wsum="pane $wPane · visible ✓"
      [ "$recreated" -eq 1 ] && wsum="pane $wPane · recreated ✓"
      local _lp="${HERD_RELOAD_LOCKPID_POLLS:-10}" _kk=0
      while [ "$_kk" -lt "$_lp" ] && [ ! -f "$HERD_WATCHER_LOCK" ]; do sleep 0.2; _kk=$((_kk+1)); done
      [ -f "$HERD_WATCHER_LOCK" ] && watch_pid="$(cat "$HERD_WATCHER_LOCK" 2>/dev/null || true)"
    else
      local zpid=""
      [ -f "$HERD_WATCHER_LOCK" ] && zpid="$(cat "$HERD_WATCHER_LOCK" 2>/dev/null || true)"
      if [ -n "$zpid" ] && kill -0 "$zpid" 2>/dev/null; then
        wsum="DETACHED — running, but NOT visible in pane $wPane"
        watch_pid="$zpid"
        warn "watcher PID $zpid is RUNNING but NOT visible in pane $wPane — its pane run detached from the tty; re-run 'herd pane watch' or kill $zpid and inspect the pane"
      else
        wsum="pane $wPane · NOT visible ✗"
        warn "watcher did not appear in pane $wPane"
      fi
    fi
  else
    warn "could not resolve or create a watch pane below the coordinator"
  fi
  [ -n "$watch_pid" ] && wsum="$wsum · pid $watch_pid"

  # REPAINT the width-sensitive backlog viewer if the geometry changed (see cmd_reload).
  if [ "$geom_changed" -eq 1 ] && [ -n "${BACKLOG_FILE:-}" ] && [ -f "$PANE_ROOT/$BACKLOG_FILE" ]; then
    touch "$PANE_ROOT/$BACKLOG_FILE" 2>/dev/null || true
  fi

  # 4. Registry from the observed final state (backlog row preserved from the registry).
  _pane_write_registry "$PANE_AGENT" "$PANE_REG_B" "$wPane"

  say ""
  ok "pane watch complete"
  say "  workspace:  $WORKSPACE_NAME"
  say "  watcher:    $wsum"
  return 0
}

cmd_pane_backlog() {
  _pane_init
  say "${c_bold}herd pane backlog${c_rst} — restarting the backlog viewer in its pane"
  say ""

  local backlog_script="$SCRIPTS_DIR/backlog-view.sh"

  # Resolve the backlog pane: the registered pane if it still serves the role, else the
  # coordinator's LEFT neighbor, else a scan of the coordinator tab for a live viewer. Never adopt
  # the anchor pane or a pane LIVE in a different role as the backlog (issue #60).
  local bPane="" recreated=0 geom_changed=0
  if [ -n "$PANE_REG_B" ] && [ "$PANE_REG_B" != "$PANE_AGENT" ] && _reg_role_ok "$PANE_REG_B" backlog; then
    case "$(_reload_pane_state "$PANE_REG_B" "backlog-view.sh")" in
      RUN*|BARE) bPane="$PANE_REG_B" ;;
    esac
  fi
  if [ -z "$bPane" ]; then
    local nb; nb="$(_reload_neighbor "$PANE_AGENT" left)"
    if [ -n "$nb" ]; then
      case "$(_reload_pane_state "$nb" "backlog-view.sh")" in
        RUN*|BARE) bPane="$nb" ;;
      esac
    fi
  fi
  if [ -z "$bPane" ]; then
    local p
    for p in $(_reload_tab_panes "$PANE_WS" "$PANE_COORD_TAB"); do
      [ "$(_reload_pane_role "$p")" = "backlog" ] && { bPane="$p"; break; }
    done
  fi

  if [ -z "$bPane" ]; then
    # Gone → recreate beside the coordinator and swap into the LEFT slot (canonical shape).
    bPane="$(_reload_split_pane "$PANE_AGENT" right 0.5 "$PANE_ROOT")"
    if [ -n "$bPane" ]; then
      herdr pane swap --source-pane "$bPane" --target-pane "$PANE_AGENT" >/dev/null 2>&1 || true
      recreated=1; geom_changed=1
    fi
  else
    # In place: interrupt a live viewer safely first. backlog-view.sh traps INT/TERM, restores the
    # tty, and exits 0, so SIGTERM-ing its foreground pid stops it cleanly (it is stateless — no
    # loss). A pane run into a still-looping viewer would type into its muted stdin, not execute.
    local bstate; bstate="$(_reload_pane_state "$bPane" "backlog-view.sh")"
    case "$bstate" in
      RUN\ *)
        local vpid="${bstate#RUN }"
        [ -n "$vpid" ] && kill "$vpid" 2>/dev/null || true
        ;;
    esac
  fi

  # Rerun the viewer, verified.
  local bsum="FAILED ✗"
  if [ -n "$bPane" ]; then
    if _reload_pane_run_verified "$bPane" "bash $backlog_script" "backlog-view.sh" >/dev/null; then
      bsum="pane $bPane · visible ✓"
      [ "$recreated" -eq 1 ] && bsum="pane $bPane · recreated ✓"
    else
      bsum="pane $bPane · NOT visible ✗"
      warn "backlog-view did not appear in pane $bPane"
    fi
  else
    warn "could not resolve or create a backlog pane beside the coordinator"
  fi

  if [ "$geom_changed" -eq 1 ] && [ -n "${BACKLOG_FILE:-}" ] && [ -f "$PANE_ROOT/$BACKLOG_FILE" ]; then
    touch "$PANE_ROOT/$BACKLOG_FILE" 2>/dev/null || true
  fi

  # Registry from the observed final state (watch row preserved from the registry).
  _pane_write_registry "$PANE_AGENT" "$bPane" "$PANE_REG_W"

  say ""
  ok "pane backlog complete"
  say "  workspace:  $WORKSPACE_NAME"
  say "  backlog:    $bsum"
  return 0
}

cmd_pane_coordinator() {
  local assume_yes=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --yes|-y) assume_yes=1; shift ;;
      *) die "unknown option '$1' for 'herd pane coordinator' (expected --yes)" ;;
    esac
  done

  _pane_init
  say "${c_bold}herd pane coordinator${c_rst} — relaunching the coordinator agent in its pane"

  # DESTRUCTIVE: this KILLS the live coordinator claude session in the anchor pane. Require an
  # explicit, typed confirmation (or --yes). Non-interactive without --yes always refuses.
  if [ -z "$assume_yes" ]; then
    if [ -t 0 ] && [ -z "${HERD_NONINTERACTIVE:-}" ]; then
      local ans; ans="$(ask "This KILLS the live coordinator claude in pane $PANE_AGENT and relaunches it — type 'yes' to proceed" "")"
      [ "$ans" = "yes" ] || die "aborted — coordinator left running (type 'yes' or pass --yes)"
    else
      die "refusing to relaunch the coordinator without confirmation — it kills the live coordinator session; re-run with --yes"
    fi
  fi
  say ""

  # Close the old coordinator pane (kills claude), then relaunch the agent with coordinator.sh's
  # invocation. Keep the watcher canonical by re-parenting it below the fresh coordinator pane.
  local watch_before="$PANE_REG_W"
  herdr pane close "$PANE_AGENT" >/dev/null 2>&1 || true
  local new_pane; new_pane="$(_pane_agent_start "$HERD_AGENT_COORDINATOR" "$PANE_WS" "$PANE_ROOT" "$PANE_COORD_TAB" right)"

  local csum="FAILED ✗"
  if [ -n "$new_pane" ]; then
    csum="pane $new_pane · relaunched ✓"
    if [ -n "$watch_before" ]; then
      case "$(_reload_pane_state "$watch_before" "")" in
        GONE) : ;;
        *) _reload_reparent "$watch_before" "$PANE_COORD_TAB" down "$new_pane" 0.72 || true ;;
      esac
    fi
  else
    warn "coordinator agent did not start — inspect tab $PANE_COORD_TAB"
  fi

  # Registry from the observed final state (new coordinator pane; backlog/watch preserved).
  _pane_write_registry "$new_pane" "$PANE_REG_B" "$watch_before"

  say ""
  ok "pane coordinator complete"
  say "  workspace:    $WORKSPACE_NAME"
  say "  coordinator:  $csum"
  return 0
}

_pane_usage() {
  cat <<EOF
herd pane <target> — restart ONE control-room pane in place (no full reload)

  herd pane watch          stop this project's watcher and rerun it in the registered watch
                           pane (recreated below the coordinator if gone), pane visibility verified
  herd pane backlog        rerun the backlog viewer in the registered backlog pane, interrupting a
                           live viewer safely first (recreated at canonical geometry if gone)
  herd pane coordinator    relaunch the coordinator agent pane — KILLS the live coordinator claude
                           session, so it requires a typed 'yes' or --yes
    [--yes|-y]             skip the confirmation prompt (still destructive)
EOF
}

cmd_pane() {
  local sub="${1:-}"
  if [ "$#" -gt 0 ]; then shift; fi
  case "$sub" in
    watch)        cmd_pane_watch "$@" ;;
    backlog)      cmd_pane_backlog "$@" ;;
    coordinator)  cmd_pane_coordinator "$@" ;;
    ''|help|-h|--help) _pane_usage ;;
    *) die "unknown 'herd pane' target '$sub' — expected: watch | backlog | coordinator" ;;
  esac
}

cmd_update() {
  local force=""
  while true; do
    case "${1:-}" in
      --force|-f) force=1; shift ;;
      *) break ;;
    esac
  done

  local root; root="$(pwd)"
  local cfg="$root/.herd/config"
  [ -f "$cfg" ] || die "no .herd/config at $root — run 'herd init' first"

  say "${c_bold}herd update${c_rst} — pull the herdkit engine, upgrade the skill, reload the workspace"
  say ""

  # Load config (sets PROJECT_ROOT, WORKTREES_DIR, WORKSPACE_NAME, etc.)
  export HERD_CONFIG_FILE="$cfg"
  # shellcheck source=/dev/null
  . "$SCRIPTS_DIR/herd-config.sh"

  # Test knob: override which dir gets the git pull (never touches real HERDKIT_HOME in tests).
  local engine_dir="${HERD_UPDATE_ENGINE_DIR:-$HERDKIT_HOME}"

  # 1. Refuse if the engine checkout is dirty (uncommitted changes would be pulled over).
  local git_status
  git_status="$(git -C "$engine_dir" status --porcelain 2>/dev/null || true)"
  if [ -n "$git_status" ]; then
    warn "engine checkout at $engine_dir has uncommitted changes:"
    printf '%s\n' "$git_status" >&2
    if [ -n "$force" ]; then
      warn "proceeding anyway (--force)"
    else
      die "refusing to pull over a dirty engine checkout — commit or stash changes first, or re-run with --force"
    fi
  fi

  # 2. Warn (and require confirmation) if builders are mid-flight: their lane scripts
  #    reference the engine path live, so a mid-pull engine swap can corrupt a running build.
  local working_builders=""
  if command -v herdr >/dev/null 2>&1; then
    local agents_json wt_list
    agents_json="$(herdr agent list 2>/dev/null || echo '{}')"
    wt_list="$(git -C "$PROJECT_ROOT" worktree list --porcelain 2>/dev/null || true)"
    working_builders="$(AGENTS_JSON="$agents_json" WT="$wt_list" \
      MAIN="$PROJECT_ROOT" python3 -c '
import os, json
MAIN = os.environ.get("MAIN", "")
try: agents = (json.loads(os.environ.get("AGENTS_JSON","{}")).get("result") or {}).get("agents") or []
except Exception: agents = []
ag_status = {a.get("name"): a.get("agent_status") for a in agents if a.get("name")}
working = []
for line in (os.environ.get("WT","")).splitlines():
    if line.startswith("worktree "):
        wt = line[9:]
        if wt and wt != MAIN:
            slug = os.path.basename(wt)
            if ag_status.get(slug) == "working":
                working.append(slug)
print("\n".join(working))
' 2>/dev/null || true)"
  fi

  if [ -n "$working_builders" ]; then
    warn "builders are mid-flight in this workspace (their lanes reference engine scripts live):"
    printf '%s\n' "$working_builders" >&2
    if [ -n "$force" ]; then
      warn "proceeding anyway (--force) — in-flight builders may pick up engine changes mid-build"
    elif [ -t 0 ] && [ -z "${HERD_NONINTERACTIVE:-}" ]; then
      local ans; ans="$(ask "Proceed with mid-flight builders? [y/N]" "n")"
      case "$ans" in y|Y) : ;; *) die "aborted — wait for builders to finish, then re-run 'herd update'"; esac
    else
      die "aborting — builders are mid-flight; re-run with --force to proceed anyway"
    fi
  fi

  # 3. Pull the engine (fast-forward only — divergence is always a human decision).
  local old_sha
  old_sha="$(git -C "$engine_dir" rev-parse HEAD 2>/dev/null || true)"
  say "  pulling $engine_dir …"
  local pull_out
  if ! pull_out="$(git -C "$engine_dir" pull --ff-only 2>&1)"; then
    printf '%s\n' "$pull_out" >&2
    die "git pull --ff-only failed — the engine branch may have diverged; run 'git -C $engine_dir fetch && git -C $engine_dir merge --ff-only' to diagnose, then re-run 'herd update'"
  fi
  printf '%s\n' "$pull_out"

  # 4. Show what came in.
  local new_sha
  new_sha="$(git -C "$engine_dir" rev-parse HEAD 2>/dev/null || true)"
  if [ -n "$old_sha" ] && [ "$old_sha" != "$new_sha" ]; then
    say ""
    say "${c_bold}Engine delta (${old_sha:0:7}..${new_sha:0:7}):${c_rst}"
    git -C "$engine_dir" log --oneline "${old_sha}..${new_sha}" 2>/dev/null || true
  else
    say "  (already up to date — no new commits)"
  fi
  say ""

  # 5. Upgrade: re-render skill preserving .herd/config answers, bump version, warn on new keys.
  say "${c_bold}Upgrading skill + config…${c_rst}"
  cmd_upgrade

  # 6. Reload: stop old watcher, re-render, relaunch watcher + backlog pane.
  say ""
  say "${c_bold}Reloading workspace…${c_rst}"
  cmd_reload
}

# ── herd log / herd why: read the engine journal ────────────────────────────────────────────────
# The journal is the append-only forensic record written by the engine components (agent-watch.sh,
# herd-review.sh, cmd_reload) via scripts/herd/journal.sh. `herd log` pages it; `herd why <pr>`
# summarizes one PR's full gate history chronologically. Both are READ-ONLY.

# _journal_load_config — resolve WORKTREES_DIR (and thus the journal path) via the shared loader,
# pinned to this repo's .herd/config when present. Sets the global JOURNAL_MAIN to the live journal.
_journal_load_config() {
  local root; root="$(pwd)"
  local cfg="$root/.herd/config"
  [ -f "$cfg" ] && export HERD_CONFIG_FILE="$cfg"
  # shellcheck source=/dev/null
  . "$SCRIPTS_DIR/herd-config.sh"
  JOURNAL_MAIN="$WORKTREES_DIR/.herd/journal.jsonl"
}

# _journal_all_files — print the live journal plus any rotated archives (journal-*.jsonl), oldest
# first, one path per line. Used by `herd why` to aggregate across a rotation boundary.
_journal_all_files() {
  local dir="$WORKTREES_DIR/.herd"
  [ -d "$dir" ] || return 0
  # Archives sort chronologically by their -<stamp> suffix; the live journal is newest, so it goes last.
  ls -1 "$dir"/journal-*.jsonl 2>/dev/null | sort || true
  [ -f "$JOURNAL_MAIN" ] && printf '%s\n' "$JOURNAL_MAIN"
}

# The shared JSONL line formatter (python): reads journal lines on stdin, prints one readable line
# each. HERD_LOG_PR filters to a single PR when set.
_JOURNAL_FMT='
import sys, os, json
want_pr = os.environ.get("HERD_LOG_PR", "")
def pr_of(o):
    v = o.get("pr")
    return "" if v is None else str(v)
for raw in sys.stdin:
    raw = raw.strip()
    if not raw:
        continue
    try:
        o = json.loads(raw)
    except Exception:
        continue
    if want_pr and pr_of(o) != want_pr:
        continue
    ts = str(o.get("ts", ""))
    ev = str(o.get("event", "?"))
    rest = " ".join("%s=%s" % (k, o[k]) for k in o if k not in ("ts", "event"))
    print("%s  %-22s %s" % (ts, ev, rest))
'

cmd_log() {
  local pr="" tail=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --pr)   pr="${2:-}"; [ -n "$pr" ] || die "--pr requires a PR number"; shift 2 ;;
      --pr=*) pr="${1#--pr=}"; shift ;;
      --tail) tail=1; shift ;;
      *) die "usage: herd log [--pr N] [--tail]" ;;
    esac
  done
  _journal_load_config
  if [ ! -f "$JOURNAL_MAIN" ]; then
    say "no engine journal yet at ${c_dim}$JOURNAL_MAIN${c_rst}"
    say "  (the watcher and review gate create it on the first gate event)"
    return 0
  fi
  export HERD_LOG_PR="$pr"
  if [ "$tail" -eq 1 ]; then
    say "${c_dim}tailing $JOURNAL_MAIN${pr:+ · PR #$pr} — Ctrl-C to stop${c_rst}"
    tail -n 20 -f "$JOURNAL_MAIN" | python3 -c "$_JOURNAL_FMT"
  else
    python3 -c "$_JOURNAL_FMT" < "$JOURNAL_MAIN"
  fi
}

cmd_why() {
  local pr="${1:-}"
  [ -n "$pr" ] || die "usage: herd why <pr#>"
  case "$pr" in \#*) pr="${pr#\#}" ;; esac
  [ -n "$pr" ] && [ -z "${pr//[0-9]/}" ] || die "herd why: <pr#> must be a number (got '$1')"
  _journal_load_config
  if command -v herd_theme_load_cli >/dev/null 2>&1; then herd_theme_load_cli; fi
  local files; files="$(_journal_all_files)"
  if [ -z "$files" ]; then
    say "no engine journal yet at ${c_dim}$WORKTREES_DIR/.herd/journal.jsonl${c_rst}"
    return 0
  fi
  # Aggregate all events for this PR across the live journal + archives, chronologically.
  printf '%s\n' "$files" | HERD_WHY_PR="$pr" python3 -c '
import sys, os, json
pr = os.environ["HERD_WHY_PR"]
rows = []
for path in sys.stdin.read().split("\n"):
    path = path.strip()
    if not path:
        continue
    try:
        f = open(path, encoding="utf-8")
    except OSError:
        continue
    with f:
        for raw in f:
            raw = raw.strip()
            if not raw:
                continue
            try:
                o = json.loads(raw)
            except Exception:
                continue
            if str(o.get("pr", "")) == pr:
                rows.append(o)
rows.sort(key=lambda o: str(o.get("ts", "")))
if not rows:
    print("PR #%s — no journal entries found." % pr)
    sys.exit(0)

def g(o, *ks):
    return next((str(o[k]) for k in ks if o.get(k) not in (None, "")), "")

def describe(o):
    ev = o.get("event", "?")
    if ev == "review_dispatched":
        return "review dispatched", "sha %s · model %s · pid %s" % (g(o,"sha")[:12] or "?", g(o,"model") or "?", g(o,"pid") or "?")
    if ev == "verdict_recorded":
        return "verdict recorded", "%s (%s) · sha %s" % (g(o,"value") or "?", g(o,"source") or "?", g(o,"sha")[:12] or "?")
    if ev == "healthcheck_attempted":
        return "healthcheck attempt", "attempt %s → %s" % (g(o,"attempt") or "1", g(o,"result") or "?")
    if ev == "healthcheck_retried":
        return "healthcheck retry", "attempt %s → %s" % (g(o,"attempt") or "?", g(o,"result") or "?")
    if ev == "healthcheck_outcome":
        d = g(o,"detail")
        return "healthcheck outcome", g(o,"outcome") + (" · " + d if d else "")
    if ev == "refix_bounce":
        return "auto-refix bounce", "round %s · agent was %s" % (g(o,"round") or "?", g(o,"agent_status_before") or "?")
    if ev == "refix_wake_result":
        return "auto-refix wake", "woke=%s escalated=%s (%s → %s)" % (g(o,"woke") or "?", g(o,"escalated") or "?", g(o,"agent_status_before") or "?", g(o,"agent_status_after") or "?")
    if ev == "hold_applied":
        return "hold applied", "%s hold · sha %s" % (g(o,"kind") or "approve", g(o,"sha")[:12] or "?")
    if ev == "hold_released":
        return "hold released", "%s hold · sha %s · %s" % (g(o,"kind") or "approve", g(o,"sha")[:12] or "?", g(o,"reason") or "")
    if ev == "merge":
        return "MERGED", "sha %s · %s · %s" % (g(o,"sha")[:12] or "?", g(o,"method") or "?", g(o,"reason") or "")
    if ev == "reap":
        return "reaped worktree", "reason %s" % (g(o,"reason") or "?")
    if ev == "review_log_retained":
        return "review log kept", g(o,"path")
    if ev == "infra_event":
        return "INFRA event", "%s · exit %s · %s" % (g(o,"component") or "?", g(o,"exit_code") or "?", g(o,"stderr_tail") or "")
    if ev == "sweep_closed":
        return "tab swept", "%s (%s)" % (g(o,"tab_id") or "?", g(o,"reason") or "?")
    if ev == "reload_outcome":
        return "reload", "%s → %s" % (g(o,"component") or "?", g(o,"result") or "?")
    if ev == "cost":
        return "cost", "%s · %s · $%s (in %s out %s cache_r %s cache_w %s)" % (
            g(o,"component") or "?", g(o,"model") or "?", g(o,"usd") or "?",
            g(o,"in") or "0", g(o,"out") or "0", g(o,"cache_read") or "0", g(o,"cache_write") or "0")
    extra = " ".join("%s=%s" % (k, o[k]) for k in o if k not in ("ts","event","pr"))
    return ev, extra

print("PR #%s — gate history (%d event%s)" % (pr, len(rows), "" if len(rows)==1 else "s"))
for o in rows:
    label, detail = describe(o)
    print("  %s  %-20s %s" % (str(o.get("ts","")), label, detail))
'
}

# cmd_cost — the token/cost READER: aggregate the journal's `cost` events (written by the watcher
# at merge time via scripts/herd/cost.sh) into per-PR cost, cost-per-merged-PR, and running totals
# by component + model. READ-ONLY. `herd cost` shows the full rollup; `herd cost --pr N` drills into
# one PR's cost lines. The denominator for cost-per-merged-PR is the set of PRs with a builder cost
# event (a builder cost is emitted only at merge, so those PRs merged).
cmd_cost() {
  local pr="" full=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --pr)   pr="${2:-}"; [ -n "$pr" ] || die "--pr requires a PR number"; shift 2 ;;
      --pr=*) pr="${1#--pr=}"; shift ;;
      --full) full=1; shift ;;
      *) die "usage: herd cost [--pr N] [--full]" ;;
    esac
  done
  case "$pr" in \#*) pr="${pr#\#}" ;; esac
  [ -z "$pr" ] || [ -z "${pr//[0-9]/}" ] || die "herd cost: --pr must be a number (got '$pr')"
  # --pr drills into one PR's merge-recorded lines; the coordinator/scribe/researcher have no PR, so
  # --full only augments the full rollup. Ignore --full silently when --pr is given.
  [ -n "$pr" ] && full=0
  _journal_load_config
  if command -v herd_theme_load_cli >/dev/null 2>&1; then herd_theme_load_cli; fi
  # `herd cost --full`: ALSO scan the live transcripts of the long-lived session agents (coordinator,
  # scribe, researcher). All three run with --cwd $PROJECT_ROOT, so they share MAIN's munged
  # transcript dir. A missing dir is skipped with a note rather than an error.
  local full_lines="" full_note=""
  if [ "$full" -eq 1 ]; then
    local maindir; maindir="$(_cost_transcript_dir "$PROJECT_ROOT")"
    if [ -d "$maindir" ]; then
      full_lines="$(cost_report_full "$maindir")"
      [ -n "$full_lines" ] || full_note="no coordinator/scribe/researcher transcript found in $maindir — nothing to add"
    else
      full_note="no transcript dir at $maindir — coordinator/scribe/researcher scan skipped"
    fi
  fi
  local files; files="$(_journal_all_files)"
  if [ -z "$files" ] && [ "$full" -ne 1 ]; then
    say "no engine journal yet at ${c_dim}$WORKTREES_DIR/.herd/journal.jsonl${c_rst}"
    say "  (the watcher writes cost events at merge time — none recorded yet)"
    return 0
  fi
  printf '%s\n' "$files" | HERD_COST_PR="$pr" HERD_COST_FULL="$full" \
    HERD_COST_FULL_LINES="$full_lines" HERD_COST_FULL_NOTE="$full_note" python3 -c '
import sys, os, json
want_pr = os.environ.get("HERD_COST_PR", "")
rows = []
for path in sys.stdin.read().split("\n"):
    path = path.strip()
    if not path:
        continue
    try:
        f = open(path, encoding="utf-8")
    except OSError:
        continue
    with f:
        for raw in f:
            raw = raw.strip()
            if not raw:
                continue
            try:
                o = json.loads(raw)
            except Exception:
                continue
            if o.get("event") != "cost":
                continue
            rows.append(o)

def fnum(v):
    try:
        return float(v)
    except (TypeError, ValueError):
        return 0.0

# `herd cost --full` augmentation: the live-scanned coordinator/scribe/researcher spend, passed in
# as pre-formatted "component=.. model=.. in=.. .. usd=.. msgs=.." lines from cost_report_full. This
# section is APPENDED to the merge-recorded rollup and never alters it, so default `herd cost`
# (FULL != "1") is byte-for-byte unchanged.
FULL = os.environ.get("HERD_COST_FULL", "") == "1"
FULL_LINES = os.environ.get("HERD_COST_FULL_LINES", "")
FULL_NOTE = os.environ.get("HERD_COST_FULL_NOTE", "")

def _parse_kv_lines(s):
    out = []
    for line in s.split("\n"):
        line = line.strip()
        if not line:
            continue
        d = {}
        for kv in line.split():
            if "=" in kv:
                k, v = kv.split("=", 1)
                d[k] = v
        if d.get("component"):
            out.append(d)
    return out

def print_full_section(base_usd):
    # base_usd = the merge-recorded (builder+review) total; the session total sums it with the
    # live-scanned agents so the operator sees a COMPLETE session figure, not just per-PR spend.
    print("")
    print("Live session agents (herd cost --full — scanned live from transcripts):")
    agents = _parse_kv_lines(FULL_LINES)
    extra = 0.0
    if not agents:
        print("  %s" % (FULL_NOTE or "no coordinator/scribe/researcher transcript found — nothing to add"))
    else:
        for d in agents:
            usd = fnum(d.get("usd")); extra += usd
            print("  %-11s %-18s $%9.4f  (in %s out %s cache_r %s cache_w %s · %s msgs)" % (
                d.get("component", "?"), d.get("model", "?"), usd,
                d.get("in", "0"), d.get("out", "0"), d.get("cache_read", "0"), d.get("cache_write", "0"), d.get("msgs", "0")))
    print("")
    print("Session total (builder+review+coordinator+scribe+researcher): $%.4f" % (base_usd + extra))

if want_pr:
    rows = [o for o in rows if str(o.get("pr", "")) == want_pr]

if not rows:
    if want_pr:
        print("PR #%s — no cost events recorded." % want_pr)
    else:
        print("No cost events recorded yet.")
        print("  (the watcher journals a `cost` event for each builder at merge time)")
        if FULL:
            print_full_section(0.0)
    sys.exit(0)

if want_pr:
    print("PR #%s — cost breakdown" % want_pr)
    total = 0.0
    for o in sorted(rows, key=lambda o: str(o.get("component",""))):
        usd = fnum(o.get("usd")); total += usd
        print("  %-8s %-18s $%9.4f  (in %s out %s cache_r %s cache_w %s · %s msgs)" % (
            str(o.get("component","?")), str(o.get("model","?")), usd,
            o.get("in",0), o.get("out",0), o.get("cache_read",0), o.get("cache_write",0), o.get("msgs",0)))
    print("  %-8s %-18s $%9.4f" % ("TOTAL", "", total))
    sys.exit(0)

# Full rollup.
per_pr = {}          # pr -> usd
by_component = {}     # component -> usd
by_model = {}         # model -> usd
merged = set()        # PRs with a builder cost event
grand = 0.0
for o in rows:
    prn = str(o.get("pr", "?"))
    usd = fnum(o.get("usd"))
    comp = str(o.get("component", "?"))
    model = str(o.get("model", "?"))
    per_pr[prn] = per_pr.get(prn, 0.0) + usd
    by_component[comp] = by_component.get(comp, 0.0) + usd
    by_model[model] = by_model.get(model, 0.0) + usd
    grand += usd
    if comp == "builder":
        merged.add(prn)

def _prkey(p):
    try:
        return (0, int(p))
    except ValueError:
        return (1, p)

print("Cost per PR (%d PR%s with cost events):" % (len(per_pr), "" if len(per_pr)==1 else "s"))
for prn in sorted(per_pr, key=_prkey):
    print("  PR #%-6s $%9.4f" % (prn, per_pr[prn]))
print("")
print("By component:")
for comp in sorted(by_component, key=lambda c: -by_component[c]):
    print("  %-10s $%9.4f" % (comp, by_component[comp]))
print("By model:")
for model in sorted(by_model, key=lambda m: -by_model[m]):
    print("  %-18s $%9.4f" % (model, by_model[model]))
print("")
print("Total spend recorded:   $%.4f" % grand)
print("Merged PRs (billed):     %d" % len(merged))
if merged:
    print("Cost per merged PR:      $%.4f" % (grand / len(merged)))
if FULL:
    print_full_section(grand)
'
}

# ── cmd_fleet — the DETERMINISTIC (no-LLM) multi-project fan-out (P0 of the fleet-coordinator EPIC) ──
# A parent orchestration layer above the per-project coordinators: a flat project REGISTRY plus a
# read-mostly rollup (`status`) and bulk delegation of the existing per-project `herd update`/`herd
# reload` (`upgrade`/`reload`). All logic lives in scripts/herd/fleet.sh; this is just the router.
cmd_fleet() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    register)  fleet_register "$@" ;;
    list)      fleet_list "$@" ;;
    discover)  fleet_discover "$@" ;;
    status)    fleet_status "$@" ;;
    digest)    fleet_digest "$@" ;;
    inbox)     fleet_inbox "$@" ;;
    governance) fleet_governance "$@" ;;
    room)      fleet_room "$@" ;;
    upgrade)   fleet_upgrade "$@" ;;
    reload)    fleet_reload "$@" ;;
    set)       fleet_set "$@" ;;
    ""|-h|--help)
      cat <<EOF
usage: herd fleet <subcommand>

  register <path>            add a herd project (reads its .herd/config) to the registry
  list                       list registered projects (name · path · repo)
  discover [--register|--yes] [<root>...]
                             scan roots (default: sensible parent dirs) for .herd/config; print each
                             project + whether it is already registered; --register adds the new ones
                             (dry-run by default — writes nothing)
  status                     per-project rollup: branch, open PRs, watcher alive?, last activity
  digest [--since <dur>]     cross-project standup from each project's journal (shipped / needs-you /
                             blocked / in-flight / gate failures over a window; default 24h; no LLM)
  inbox                      cross-project ATTENTION INBOX: one view of what needs you right now
                             (blocked PRs, human-verify/approval holds, CONFLICTING PRs, failed
                             health gates) per project · PR# · reason · suggested action; no LLM
  governance                 fleet-wide GLOBAL CONCURRENCY view: total in-flight builders + reviews
                             summed across all projects (the usage limit is account-wide, so this
                             helps avoid a fleet-wide limit-hit); read-only, no LLM
  room                       open the NL MASTER-COORDINATOR agent in its own meta-workspace: an LLM
                             seat that rolls up + delegates across every registered project (thin over
                             the deterministic helpers above; never edits files or merges). Refuses
                             when the registry is empty. (herd fleet room --help for details)
  set <KEY> <VALUE>          propagate a policy across the fleet by delegating to each project's own
                             VALIDATED 'herd config set' (e.g. MERGE_POLICY / model tier / TOKEN_MODE)
  upgrade                    run 'herd update' in every registered project (per-project outcomes)
  reload                     run 'herd reload' in every registered project (per-project outcomes)

Registry file: $(_fleet_registry_file)
EOF
      ;;
    *) die "unknown fleet subcommand: $sub (try: herd fleet --help)" ;;
  esac
}

usage() {
  cat <<EOF
herd — the herdkit CLI (engine contract v$HERDKIT_CONTRACT_VERSION)

  herd init                           stand up herdkit in the current repo (interview + scout)
  herd doctor                         one-pass dependency doctor: check git, gh (+auth), claude,
                                      python3, herdr (+JSON contract) and python3's UTF-8 output;
                                      report every problem at once with per-platform install hints;
                                      soft deps (glow, shellcheck, bats) warn only. Exits non-zero
                                      when a required dep is missing/broken. (bypass: HERD_SKIP_DOCTOR=1)
  herd upgrade                        bump HERD_VERSION + re-render the coordinator skill
  herd render                         re-render only the coordinator skill from .herd/config
  herd codemap [--check]              regenerate docs/codemap.md: a deterministic native map of the
                                        repo (engine tree here, or a consuming project's own source
                                        tree; module roles, who-imports/sources-whom, config→consumer);
                                        --check probes staleness read-only (0 fresh / non-zero stale)
  herd symbol-index [--check]         regenerate docs/symbol-index.md: a deterministic function-level
                                        def→caller index of the engine tree (who-defines / who-calls);
                                        --check probes staleness read-only (0 fresh / non-zero stale)
  herd ledger <set|get|list|rm|compact|path>  coordinator PROGRESS LEDGER — durable, cross-session
                                      per-work-item state (slug/worktree/PR, sequencing, planned
                                      markers) keyed by tracker id, so you resume with an accurate
                                      picture instead of re-deriving it. Coordinator-side only (no
                                      watcher gate); local + never committed. Default-dormant:
                                        set <id> [k v]...  append/update an item's fields
                                        get <id> [--json]  print one item's folded state
                                        list [--json]      list live items ([--planned] filters)
                                        rm <id>            tombstone an item out of get/list
                                        compact            fold history to one line per live item
                                        path               print the ledger file path
  herd advise "<question>" [context…] mid-flight ADVISOR: a builder pulls a ONE-SHOT second opinion
                                      from a strong advisor model (MODEL_ADVISE, default the
                                      MODEL_FEATURE/Opus tier) on a hard decision WITHOUT escalating
                                      its whole lane; prints the advice to stdout. Extra args (and
                                      piped stdin) are appended as context. Additive + fail-soft: an
                                      absent model or a failed call degrades to a clear message
  herd config <list|get|set|sync|lint> view/validate/set .herd/config keys (key set + metadata from
                                        list          print effective keys+values (secrets masked)
                                        get <KEY>     print one validated key's value
                                        set <KEY> <V> validate against capabilities.tsv, edit in place,
                                                      then restart the watcher (watcher keys) or
                                                      re-render the coordinator skill (coordinator keys);
                                                      never touches DENY_PATHS / .herd/secrets
                                        sync          READ-ONLY: list engine config keys documented by
                                                      the manifest but missing from .herd/config (with
                                                      each default + when-to-surface); non-zero if any
                                        lint          flag DUPLICATE keys (silent shell last-wins can
                                                      disable a gate); exits non-zero if any exist
  herd governance hooks render        render SESSION-TIME Claude Code hooks from the governance map's
              [--shared]              hook rows (dual-surface: the same rules the merge gate enforces,
                                      now blocking at the keyboard). Propose-then-write, per-hook
                                      accept; merges into .claude/settings.local.json (or
                                      .claude/settings.json with --shared) preserving existing entries;
                                      marker-keyed so re-render is idempotent. No hook rows → no-op
  herd reload                         rebuild the control room around the coordinator: stop +
                                      relaunch the watcher (pane visibility verified), ensure
                                      the pinned backlog pane, re-render the coordinator skill;
                                      prints a per-component summary + effective MERGE_POLICY.
                                      Never closes the coordinator tab/agent — safe to run
                                      from inside the coordinator
  herd pane <target>                  restart ONE control-room pane in place (no full reload):
                                        watch        stop + rerun the watcher in its pane
                                        backlog      rerun the backlog viewer in its pane
                                        coordinator  relaunch the coordinator agent (KILLS the
                                                     live session; needs a typed yes or --yes)
  herd update [--force]               pull the herdkit engine (git pull --ff-only), upgrade the
                                      coordinator skill, and reload the workspace in one step;
                                      refuses if the engine checkout is dirty or builders are
                                      mid-flight (--force overrides both guards)
  herd log [--pr N] [--tail]          page the engine journal (.herd/journal.jsonl): one line per
                                      gate event; --pr filters to one PR, --tail follows live
  herd status                         one-shot READ-ONLY control-room snapshot for THIS project:
                                      watcher alive?, in-flight builders (+ DEAD detection), open
                                      PRs + gate state, backlog counts. Deterministic, no LLM, no
                                      mutation; exits non-zero when something needs attention
  herd why <pr#>                      summarize one PR's full gate history from the journal —
                                      dispatches, verdicts (+provenance), health attempts, refixes,
                                      merge/reap — chronologically; the first post-mortem tool
  herd cost [--pr N] [--full]         aggregate the journal's token/cost events (measured per builder
                                      + review at merge time): per-PR cost, cost-per-merged-PR, and
                                      running totals by component + model; --pr N drills into one PR.
                                      --full ALSO scans the live coordinator/scribe/researcher
                                      transcripts and appends their token/USD + a complete session
                                      total (the default view stays merge-gated + unchanged).
                                      Prices are PERISHABLE (scripts/herd/cost.sh) — verify vs current
  herd backlog                        list open work items via the active backend
              [--rich]                TSV with workflow state + description (backends that
                                      support it; others fall back to the plain list)
              [show <#id>]            one item's full detail (state, description, URL)
              [browse]                interactive fzf picker with a live detail preview
                                      (soft-degrades to the plain list without fzf)
  herd backend switch <name>          guided work-tracker switch (file|github|linear|changelog):
              [--migrate|--no-migrate]  preflight creds FIRST (linear: prompts for the API key on
                                      a tty → .herd/secrets + live viewer{} check; github: gh
                                      auth) — a failed preflight changes nothing; then flips
                                      SCRIBE_BACKEND via config set, optionally replays the old
                                      backend's open items into the new one (idempotent), stamps
                                      a frozen-archive banner on BACKLOG.md when leaving the file
                                      backend, restarts the backlog pane, journals the switch
  herd report [--to <link>] [--dep]   file a report on HERD_REPO (or a peer from .herd/links
              "<sym>"                 via --to) using HERD_REPORT_BACKEND (default: github);
                                      deduplicates first (HERD_REPORT_FORCE=1 to override).
                                      --dep also records the filed item as a blocked-on
                                      dependency in .herd/deps (requires --to); without it
                                      report stays fire-and-forget
  herd link list                      list peer repos registered in .herd/links
  herd depend <link>#<id>             record a blocked-on dependency in .herd/deps (watched by
                                      dep-watcher.sh until the upstream item closes)
  herd deps <list|rm|demote>          manage recorded dependencies:
                                        list                print each dep + its current state
                                        rm <link>#<id>      drop a dep (editable data, never stuck)
                                        demote <link>#<id>  reclassify a blocker into a non-
                                                            blocking watch (un-blocks the lane)
  herd fleet <sub>                    DETERMINISTIC multi-project fan-out (no LLM) over a project
                                      registry (default ~/.herd/fleet):
                                        register <path>     add a herd project to the registry
                                        list                list registered projects
                                        discover [--register] [<root>...]
                                                            scan roots (default: sensible parents) for
                                                            .herd/config projects; dedups already-
                                                            registered; --register adds the new ones
                                        status              per-project rollup (branch, open PRs,
                                                            watcher alive?, last journal activity)
                                        digest [--since D]  cross-project standup from journals
                                                            (shipped/needs-you/blocked/in-flight)
                                        inbox               attention inbox: what needs you now
                                                            (blocks/holds/conflicts/failed gates)
                                        governance          global concurrency: total in-flight
                                                            builders + reviews across all projects
                                        room                open the NL master-coordinator agent in
                                                            its own meta-workspace (rolls up +
                                                            delegates; never edits files or merges)
                                        set <KEY> <VALUE>   propagate a policy fleet-wide via each
                                                            project's validated 'herd config set'
                                        upgrade             run 'herd update' in every project
                                        reload              run 'herd reload' in every project
  herd help                           this help

Engine scripts: $SCRIPTS_DIR
Templates:      $TEMPLATES_DIR
EOF
}

case "${1:-help}" in
  init)    shift; cmd_init "$@" ;;
  doctor)  shift; cmd_doctor "$@" ;;
  upgrade) shift; cmd_upgrade "$@" ;;
  render)  shift; cmd_render "$@" ;;
  codemap) shift; cmd_codemap "$@" ;;
  symbol-index) shift; cmd_symbol_index "$@" ;;
  ledger)  shift; cmd_ledger "$@" ;;
  advise)  shift; cmd_advise "$@" ;;
  config)  shift; cmd_config "$@" ;;
  governance) shift; cmd_governance "$@" ;;
  reload)  shift; cmd_reload "$@" ;;
  pane)    shift; cmd_pane "$@" ;;
  log)     shift; cmd_log "$@" ;;
  status)  shift; cmd_status "$@" ;;
  why)     shift; cmd_why "$@" ;;
  cost)    shift; cmd_cost "$@" ;;
  update)  shift; cmd_update "$@" ;;
  backlog) shift; cmd_backlog "$@" ;;
  backend) shift; cmd_backend "$@" ;;
  report)  shift; cmd_report "$@" ;;
  link)    shift; cmd_link "$@" ;;
  depend)  shift; cmd_depend "$@" ;;
  deps)    shift; cmd_deps "$@" ;;
  fleet)   shift; cmd_fleet "$@" ;;
  help|-h|--help) usage ;;
  *) usage; exit 2 ;;
esac
