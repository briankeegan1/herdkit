{
  "document": { "block_prefix": "", "block_suffix": "", "color": "#ebdbb2", "margin": 2 },
  "block_quote": { "indent": 1, "indent_token": "│ ", "color": "#928374", "italic": true },
  "paragraph": {},
  "list": { "level_indent": 2 },
  "heading": { "block_suffix": "\n", "color": "#83a598", "bold": true },
  "h1": { "prefix": " ", "suffix": " ", "color": "#282828", "background_color": "#83a598", "bold": true },
  "h2": { "prefix": "▌ ", "color": "#d3869b", "bold": true },
  "h3": { "prefix": "▌ ", "color": "#8ec07c", "bold": true },
  "h4": { "prefix": "▌ ", "color": "#689d6a", "bold": true },
  "h5": { "prefix": "▌ ", "color": "#b8bb26", "bold": true },
  "h6": { "prefix": "▌ ", "color": "#b8bb26" },
  "text": {},
  "strikethrough": { "crossed_out": true, "color": "#928374" },
  "emph": { "color": "#fabd2f", "italic": true },
  "strong": { "color": "#fe8019", "bold": true },
  "hr": { "color": "#504945", "format": "\n──────────────────────────\n" },
  "item": { "block_prefix": "• " },
  "enumeration": { "block_prefix": ". " },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link": { "color": "#8ec07c", "underline": true },
  "link_text": { "color": "#83a598", "bold": true },
  "code": { "prefix": " ", "suffix": " ", "color": "#d3869b", "background_color": "#3c3836" },
  "code_block": {
    "color": "#ebdbb2",
    "margin": 2,
    "chroma": {
      "text": { "color": "#ebdbb2" },
      "error": { "color": "#fb4934" },
      "comment": { "color": "#928374", "italic": true },
      "keyword": { "color": "#d3869b", "bold": true },
      "literal_string": { "color": "#b8bb26" },
      "name_builtin": { "color": "#8ec07c" },
      "name_function": { "color": "#83a598" },
      "number": { "color": "#fe8019" }
    }
  },
  "table": { "center_separator": "┼", "column_separator": "│", "row_separator": "─" },
  "definition_term": { "color": "#83a598" }
}
