# templates/drivers/herdr-claude.driver — the DEFAULT (and only shipped) driver:
#   multiplexer = herdr · agent runtime = Claude Code.
#
# A "driver" binds each runtime-specific coordinator capability to a concrete command incantation.
# render_skill() (bin/herd) sources the driver selected by the HERD_DRIVER config key
# (default: herdr-claude) and substitutes each {{DRIVER_*}} token in templates/coordinator.md.tmpl
# with the value below — the SAME {{TOKEN}} machinery that fills {{WORKSPACE_NAME}}, {{SCRIPTS_DIR}},
# {{CAPABILITIES}}, … See docs/driver-abstraction.md for the capability model + phase-2 design.
#
# CONTRACT (mirrors .herd/config): shell-sourceable KEY=value, COMMITTED, ZERO-SECRET — command
# SHAPES only, never credentials. With HERD_DRIVER unset/default the rendered coordinator skill is
# FUNCTIONALLY IDENTICAL to before this abstraction existed (the render-equivalence test is the rail).
# A different runtime ships its own <name>.driver binding these same keys to its control surface;
# a driver missing a key the template tokenizes fails the render loudly (an unrendered {{DRIVER_*}}).

# ── Capabilities the coordinator skill binds INLINE (greppable as DRIVER:<cap> in the skill) ──────
DRIVER_LIST_AGENTS='herdr agent list'
DRIVER_FOCUS_AGENT='herdr agent focus <slug>'
DRIVER_SEND_TEXT='herdr pane run <agent-pane> "<text>"; herdr pane send-keys <agent-pane> Enter'
DRIVER_SWITCH_MODEL='herdr pane run <builder-agent-pane> "/model <MODEL_FEATURE value>"'

# ── Capabilities the LANE SCRIPTS + watcher exercise (not inline skill text) — bound here so a
#    phase-2 driver covers the FULL runtime surface, not just the four the skill names inline. ──────
DRIVER_START_AGENT='bash {{SCRIPTS_DIR}}/herd-feature.sh <slug> "<task>"'
DRIVER_CREATE_TAB='herdr tab create --workspace <ws>'
DRIVER_READ_PANE='herdr pane read <pane>'
DRIVER_SEND_KEYS='herdr pane send-keys <pane> <keys>'

# ── Agent-runtime EXEC bindings (HERD-150 phase 1) ────────────────────────────────────────────────
# The keys above bind the MULTIPLEXER (herdr) surface. The keys below factor out the AGENT RUNTIME
# (Claude Code) exec surface: the `claude`-specific incantations the lanes, drainers, watcher and CLI
# invoke directly. Phase 1 (HERD-150) only CATALOGUES them here as data + docs — NOTHING renders or
# consumes these tokens yet, so the tree stays byte-identical; phases 2-4 route the call sites in the
# audit table (docs/driver-abstraction.md § agent-runtime portability) through these bindings. Each
# value is TODAY'S EXACT string for its capability class; a non-Claude runtime rebinds this block
# (keeping herdr as the mux). Same contract as above: COMMITTED, ZERO-SECRET, command SHAPES only.
DRIVER_AGENT_INTERACTIVE_SPAWN='claude --model <model> --dangerously-skip-permissions "<prompt>"'
DRIVER_AGENT_ONESHOT_EXEC='claude -p "<prompt>" --model <model> --dangerously-skip-permissions'
DRIVER_AGENT_RESUME='claude --dangerously-skip-permissions --continue "<prompt>"'
DRIVER_AGENT_MODEL_SWITCH='/model <model>'
DRIVER_AGENT_PERMISSION_FLAG='--dangerously-skip-permissions'
DRIVER_AGENT_LIMIT_PATTERN='usage limit|session limit|hit your (usage|session) limit'
DRIVER_AGENT_SESSION_ID='${HERD_TRANSCRIPT_ROOT:-$HOME/.claude/projects}/<cwd:tr-/.-to-dash>/*.jsonl'
DRIVER_AGENT_COST_USAGE_KEYS='input_tokens output_tokens cache_creation_input_tokens cache_read_input_tokens'

# ── Agent-runtime UPDATE bindings (HERD-149 — the AGENT_UPDATE knob) ───────────────────────────────
# The runtime-specific data the AGENT_UPDATE mechanism (scripts/herd/agent-update.sh) needs to keep
# THIS driver's agent runtime current: the CLI binary (command-resolved for installer detection AND
# the macOS de-quarantine target), the npm global package + Homebrew formula/cask names, and the
# native self-update command. A non-Claude runtime (codex/grok) rebinds this block so `herd
# agent-update` updates ITS binary, not claude's — that is what makes the knob DRIVER-AWARE. Same
# contract as the exec block: COMMITTED, ZERO-SECRET, command SHAPES only. Read ONLY when
# AGENT_UPDATE=on (opt-in); nothing consumes them otherwise, so the tree stays byte-identical off.
DRIVER_AGENT_BINARY='claude'
DRIVER_AGENT_NPM_PKG='@anthropic-ai/claude-code'
DRIVER_AGENT_BREW_PKG='claude-code'
DRIVER_AGENT_NATIVE_UPDATE='claude update'
